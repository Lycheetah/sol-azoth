BENCHMARK_PATH = Path("/home/guestpc/SOLPRIME-NETWORK/benchmark_results.json")

# ── Slug generation ──
def _make_slug(model_id: str) -> str:
    """Generate a clean short slug from a full model ID.

    Design: lookup-before-parsing. SHORT_NAMES (a curated manual dict) is
    consulted first — if the exact full model_id is found there, the mapped
    shorthand is returned immediately. This handles models whose naming is
    irregular enough that regex mangling would produce a misleading slug.
    Only exact string matches on the full model_id (including provider prefix)
    are recognised; the lookup does not do partial or fuzzy matching.

    Falls back to regex-based cleanup if no SHORT_NAMES entry exists:
    strips the provider prefix, lowercases, replaces runs of non-alphanumeric
    characters with a single dash, and strips leading/trailing dashes.

    This function returns a slug, not a display name — it is used as a compact
    identifier in logs, file naming, and internal routing. For user-facing
    labels, a separate display-name lookup should be used.

    Examples:
        'meta/llama-4-maverick-17b-128e-instruct' -> 'maverick'   (SHORT_NAMES)
        'deepseek-ai/deepseek-v4-pro' -> 'deepseek-v4-pro'        (SHORT_NAMES)
        'nvidia/nemotron-mini-4b-instruct' -> 'nemotron-mini'     (fallback)
    """
    # Strip provider prefix
    parts = model_id.split("/", 1)
    name = parts[1] if len(parts) > 1 else parts[0]
    # Known short names
    SHORT_NAMES = {
        "meta/llama-4-maverick-17b-128e-instruct": "maverick",
        "meta/llama-3.1-8b-instruct": "llama8b",
        "meta/llama-3.2-1b-instruct": "llama1b",
        "meta/llama-3.2-3b-instruct": "llama3b",
        "meta/llama-3.2-11b-vision-instruct": "llama11bv",
        "meta/llama-3.3-70b-instruct": "llama33-70b",
        "meta/llama-3.1-70b-instruct": "llama70b",
        "nvidia/nvidia-nemotron-nano-9b-v2": "nemotron-nano",
        "nvidia/nemotron-mini-4b-instruct": "nemotron-mini",
        "nvidia/llama-3.3-nemotron-super-49b-v1.5": "super49b",
        "nvidia/nemotron-3-super-120b-a12b": "super120b",
        "google/gemma-2-2b-it": "gemma2",
        "google/gemma-3n-e2b-it": "gemma3n",
        "google/gemma-3n-e4b-it": "gemma3n4b",
        "mistralai/ministral-14b-instruct-2512": "ministral",
        "mistralai/mistral-nemotron": "mistral-nemotron",
        "mistralai/mistral-large-3-675b-instruct-2512": "mistral-large",
        "microsoft/phi-4-mini-instruct": "phi4-mini",
        "openai/gpt-oss-20b": "gptoss",
        "moonshotai/kimi-k2.6": "kimi",
        "deepseek-ai/deepseek-v4-pro": "deepseek-v4-pro",
        "deepseek-ai/deepseek-r1": "deepseek-r1",
        "minimaxai/minimax-m2.7": "minimax-m2",
        "minimaxai/minimax-m3": "minimax-m3",
        "stepfun-ai/step-3.7-flash": "step37",
        "bytedance/seed-oss-36b-instruct": "seed-oss",
        "sarvamai/sarvam-m": "sarvam",
        "qwen/qwen3.5-397b-a17b": "qwen",
    }
    if model_id in SHORT_NAMES:
        return SHORT_NAMES[model_id]
    # Fallback: lowercase, replace non-alnum with dash, collapse dashes
    import re
    slug = re.sub(r'[^a-z0-9-]', '', name.lower().replace(' ', '-').replace('_', '-'))
    slug = re.sub(r'-+', '-', slug).strip('-')
    return slug[:20] if slug else "unknown"


def _load_models_from_benchmark() -> dict[str, tuple[str, str, str, str]]:
    """Load models from benchmark file. Returns a dict keyed by model slug.
    Format: {slug: (provider, full_id, category, description)}
    Only includes models with no errors.
    """
    data = []
    if BENCHMARK_PATH.exists():
        raw = BENCHMARK_PATH.read_text()
        # Try strict JSON first, then JSONL (one object per line — the file drifted to this).
        try:
            data = json.loads(raw)
        except Exception:
            try:
                data = [json.loads(line) for line in raw.splitlines() if line.strip().startswith("{")]
            except Exception:
                data = []  # fall through to the guaranteed fallback dict below

    models = {}

    for entry in data:
        model_id = entry.get("model", "")
        chat_tps = entry.get("chat_tps", 0.0)
        tool_ms = entry.get("tool_ms")
        tool_ok = entry.get("tool_ok")
        err = entry.get("error")

        # Skip models with errors
        if err:
            continue

        # Determine provider from model_id prefix
        provider = model_id.split("/")[0] if "/" in model_id else "nvidia"

        # Generate slug
        slug = _make_slug(model_id)

        # Categorize
        if chat_tps >= 40.0:
            cat = "speed"
        elif chat_tps >= 15.0:
            cat = "speed"
        elif chat_tps >= 8.0:
            cat = "reasoning"
        elif chat_tps >= 2.0:
            cat = "coding"
        elif chat_tps >= 0.5:
            cat = "beast"
        else:
            cat = "beast"  # slow but powerful

        # Build description
        parts = [model_id]
        parts.append(f"{chat_tps:.1f} tps")
        if tool_ok is True:
            parts.append("[TOOL]")
        elif tool_ok is False:
            parts.append("[text-only]")
        if tool_ms:
            parts.append(f"~{tool_ms}ms")
        desc = " · ".join(parts)

        models[slug] = (provider, model_id, cat, desc)

    # Fallback defaults if benchmark is empty
    if not models:
        models = {
            "deepseek-v4-pro": ("nvidia", "deepseek-ai/deepseek-v4-pro", "speed", "DeepSeek V4 Pro · FREE · flagship · [TOOL]"),
            "maverick": ("nvidia", "meta/llama-4-maverick-17b-128e-instruct", "speed", "Llama 4 Maverick · 128 experts · [TOOL]"),
            "llama8b": ("nvidia", "meta/llama-3.1-8b-instruct", "speed", "Llama 3.1 8B · tiny · [TOOL]"),
            "gptoss": ("nvidia", "openai/gpt-oss-20b", "speed", "GPT OSS 20B · small MoE"),
            "gemma3n": ("nvidia", "google/gemma-3n-e2b-it", "speed", "Gemma 3n · edge multimodal"),
            "kimi": ("nvidia", "moonshotai/kimi-k2.6", "speed", "Kimi K2 · Moonshot · [TOOL]"),
            "mistral-large": ("nvidia", "mistralai/mistral-large-3-675b-instruct-2512", "beast", "Mistral Large 3 · 675B frontier · [TOOL]"),
        }

    return models


# Load models dynamically at startup
MODELS = _load_models_from_benchmark()

# Mac's PREMIUM DeepSeek key (api.deepseek.com) — opt-in, never default.
# These route through the PAID `deepseek` client. VAEL reaches for them with
# /model deepseek-r1 when a reach genuinely needs frontier reasoning. Supervised
# sessions only — overnight/unattended runs stay on the free NVIDIA models.
if DEEPSEEK_KEY:
    MODELS["deepseek-r1"]   = ("deepseek", "deepseek-reasoner", "beast",
                                "DeepSeek R1 · PAID · frontier reasoning · [TOOL] · supervised only")
    MODELS["deepseek-chat"] = ("deepseek", "deepseek-chat", "speed",
                                "DeepSeek V3 · PAID · fast capable · [TOOL] · supervised only")

# Defaults — derived from the dynamic MODELS dict. Boot model prefers a known
# free, tool-capable NVIDIA model (maverick) so supervised /forge never silently
# burns the paid key, and boot never lands on a slug that isn't in MODELS.
def _pick(*preferred):
    """Substring-match model selection with fallback chain.

    Iterates through preferred strings, returning the first model slug in MODELS
    that contains the preferred string as a substring (case-insensitive). If none
    match, returns the first model in MODELS, or 'maverick' if MODELS is empty.

    Used at module load time to set DEFAULT_MODEL, FALLBACK_MODEL, and LAST_RESORT
    — the three-tier model resolution chain that governs which engine the agent
    boots on and degrades through."""
    for p in preferred:
        for k in MODELS:
            if p in k.lower():
                return k
    return next(iter(MODELS.keys())) if MODELS else "maverick"

DEFAULT_MODEL  = _pick("maverick", "deepseek-v4", "kimi", "llama")
FALLBACK_MODEL = _pick("maverick", "kimi", "llama")
LAST_RESORT    = _pick("llama8b", "llama", "gptoss")

# Verified tool-capable models — extracted from benchmark file (tool_ok=true entries).
# Parse defensively: the benchmark file can drift to JSONL or partial JSON, and a
# raw json.loads here once crashed boot. Never let model-discovery kill the agent.
def _benchmark_entries() -> list:
    if not BENCHMARK_PATH.exists():
        return []
    raw = BENCHMARK_PATH.read_text()
    try:
        return json.loads(raw)
    except Exception:
        try:
            return [json.loads(l) for l in raw.splitlines() if l.strip().startswith("{")]
        except Exception:
            return []

_bench = _benchmark_entries()
TOOL_CAPABLE = {
    slug for slug, (_, model_id, _, _) in MODELS.items()
    if any(e.get("model") == model_id and e.get("tool_ok") is True for e in _bench)
} if _bench and MODELS else set()

# Ensure defaults are available even if benchmark is empty
if not TOOL_CAPABLE:
    TOOL_CAPABLE = {
        "deepseek-v4-pro", "maverick", "llama8b", "super49b", "kimi",
        "mistral-large", "gptoss", "gemma3n", "minimax-m2",
