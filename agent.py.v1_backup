# Paid DeepSeek models are tool-capable (api.deepseek.com supports function calling)
if DEEPSEEK_KEY:
    TOOL_CAPABLE |= {"deepseek-r1", "deepseek-chat"}

# ── MODEL LOCK ──────────────────────────────────────────────────────────────
# Mac's ask 2026-06-27: "remove all his models that aren't the DeepSeek premium
# key so it doesn't get confused." With the paid key present, VAEL runs on DeepSeek
# ALONE — one mind, no model-roulette, no silent mid-reach downgrade to a weaker
# free model. The free NVIDIA models remain defined ONLY as a cold fallback for a
# keyless dev boot; when the key is set they are pruned from the menu entirely so
# /models shows DeepSeek and nothing else. deepseek-chat (V3) is the default —
# fast, cheap, tool-capable, no empty-content issue. R1 available via /model deepseek-r1.
if DEEPSEEK_KEY:
    MODELS = {k: v for k, v in MODELS.items() if v[0] == "deepseek"}
    DEFAULT_MODEL  = "deepseek-chat" if "deepseek-chat" in MODELS else next(iter(MODELS))
    FALLBACK_MODEL = DEFAULT_MODEL
    LAST_RESORT    = DEFAULT_MODEL
    TOOL_CAPABLE   = set(MODELS.keys())     # every DeepSeek model is tool-capable

