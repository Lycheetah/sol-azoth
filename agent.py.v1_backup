# ── System prompt — loaded from CONSTITUTION.md at boot ──
def _load_constitution() -> str:
    """Load CONSTITUTION.md as the system prompt, enriched with boot context.

    Boot-loading sequence (in order):
    1. Read CONSTITUTION.md from disk — the living law. If missing, emit a
       fallback string directing the operator to the correct directory.
    2. Read MEMORY.md from SELF/memory/ — the persistent memory index. Append
       first 1500 chars to the prompt so every boot carries remembered state.
    3. Read SELF/CAPABILITIES.md — extract the "Current Level" line and append
       it so the agent knows its own verified capability tier at boot.
    4. Read SELF/TASK_QUEUE.md — find the first **[QUEUED]** entry and append
       it as the next /forge target, so the agent wakes already oriented.

    Returns a single string combining constitution + all boot context.
    Called once at module load time; the result is cached in SYSTEM_PROMPT.
    """
    const_text = CONSTITUTION_F.read_text() if CONSTITUTION_F.exists() else None
    _memory_md = MEMORY_DIR / "MEMORY.md"
    memory_text = _memory_md.read_text() if _memory_md.exists() else None

    base = const_text or (
        "You are VAEL-SP ◆ — the self-forging Sol Prime operative.\n"
        "Home: /home/guestpc/VAEL-SP-HARNESS/\n"
        "CONSTITUTION.md not found — run from the correct directory.\n"
    )

    if memory_text:
        base += f"\n\n## Memory Index:\n{memory_text[:1500]}"

    # Boot context: current capability level
    if CAPS_F.exists():
        try:
            caps = CAPS_F.read_text()
            level_line = next((l for l in caps.splitlines() if "Current Level" in l), None)
            if level_line:
                base += f"\n\n## Capability: {level_line.strip()}"
        except Exception:
            pass

    # Boot context: next forge task
    if TASK_QUEUE_F.exists():
        try:
            queue_text = TASK_QUEUE_F.read_text()
            queued = [l for l in queue_text.splitlines() if "**[QUEUED]**" in l]
            if queued:
                base += f"\n\n## Next /forge task: {queued[0].strip()}"
        except Exception:
            pass

    return base

SYSTEM_PROMPT = _load_constitution()

# Self-diff baseline: snapshot agent.py at startup if missing or 24h+ old
def _maybe_snapshot_self():
    """Snapshot agent.py to CORE/agent.py.bak once per day.

    Creates the backup directory if missing, then copies the running
    agent.py to a timestamped backup file. Only writes if no backup
    exists or the existing backup is at least 24 hours old — avoids
    redundant I/O on every boot while ensuring at most one day of
    work can be lost on catastrophic corruption.
    """
    _bak = HARNESS_DIR / "CORE" / "agent.py.bak"
    _bak.parent.mkdir(exist_ok=True)
    _src = Path(__file__)
    if not _bak.exists() or (datetime.datetime.now() - datetime.datetime.fromtimestamp(_bak.stat().st_mtime)).days >= 1:
        _bak.write_bytes(_src.read_bytes())
_maybe_snapshot_self()

