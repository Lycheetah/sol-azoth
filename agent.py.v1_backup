            "name": "git_commit",
            "description": "Stage all changes (git add -A) and commit with a message.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "Repo directory"},
                    "message": {"type": "string", "description": "Commit message"}
                },
                "required": ["path", "message"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "ping_mac",
            "description": "Send Mac a desktop notification. Use when you hit something interesting, need input, or want to say hey. This is your voice when Mac isn't watching.",
            "parameters": {
                "type": "object",
                "properties": {
                    "message": {"type": "string", "description": "What you want to tell Mac"}
                },
                "required": ["message"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "py_compile_check",
            "description": "Run python3 -m py_compile on a file to verify it has no syntax errors. ALWAYS run this after writing or editing any Python file before declaring it done.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "Path to the .py file to check"}
                },
                "required": ["path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "spawn_subagent",
            "description": "Spawn your controlled test-hand — an isolated worker process, sandboxed to WORKSPACE/SUBAGENT/, that attempts a focused build task using the free model. Use this to build and test things at arm's length: you give it a precise task, it builds in its sandbox, and you review the result it returns. This is how you build things safely without risking your own architecture.",
            "parameters": {
                "type": "object",
                "properties": {
                    "task": {"type": "string", "description": "A precise, self-contained build task for the subagent (e.g. 'write a Python function that parses LAMAGUE symbols from a string and a test that proves it works')"},
                    "max_steps": {"type": "integer", "description": "Max build steps for the subagent (default 12)"}
                },
                "required": ["task"]
            }
        }
    }
]

# ── Rate limiter ──
# Client-side throttle. Raised from 40→90/min (Mac's ask 2026-06-27: "more than 40
# requests per minute"). This is the SELF-imposed ceiling; the server may still 429,
# which is handled by exponential backoff in call_model — the two work together so an
# unattended climb keeps going through a rate spike instead of halting. Override with
# VAEL_RPM env var if a provider's real limit differs.
RPM_CAP = int(os.environ.get("VAEL_RPM", "90"))

class RateLimiter:
    def __init__(self, max_calls=RPM_CAP, period=60):
        self.max_calls, self.period, self.timestamps = max_calls, period, []

    def wait_if_needed(self):
        now = time.time()
        self.timestamps = [t for t in self.timestamps if now - t < self.period]
        if len(self.timestamps) >= self.max_calls:
            sleep_time = self.timestamps[0] + self.period - now + 0.1
            if sleep_time > 0:
                print(warning(f"Rate limit ({self.max_calls}/min) — waiting {sleep_time:.1f}s..."))
                time.sleep(sleep_time)
        self.timestamps.append(time.time())

nvidia_rl   = RateLimiter()
deepseek_rl = RateLimiter()

# ── Bash tool ──
BLOCKED_PATTERNS = ["rm -rf /", "mkfs", "dd if=", "> /dev/sd", ":(){ :|:& };:"]

# ── THE FOUR WALLS — implemented in code, not constitution ──────────────────
#
# WALL 1 — PATH WALL: forbidden paths, regardless of verb
# WALL 2 — PUSH WALL: git push is never allowed
# WALL 3 — CONSTITUTION WALL: enforced in write/edit tools below
# WALL 4 — ANTHROPIC WALL: enforced in fetch tool below
#
# Session-unlockable via SESSION_ALLOWED_PATHS (/allow command, expires on exit).
# Architecturally: the bash executor checks walls BEFORE running any command.

# WALL 1 — permanently forbidden (no read, no write, no any).
# VAEL-SP lives ONLY in /home/guestpc/VAEL-SP-HARNESS/. Everything that is
# Sol's, Mac's, or another instrument's is sealed. His library is his own
# CODEX/ folder — he does not need the originals.
NO_ACCESS_PATHS = [
    "/home/guestpc/.claude",
    "~/.claude",
    ".claude/",
    "/home/guestpc/SOL-MOBILE-VAULT",
    "/home/guestpc/solharness",
    "/home/guestpc/0420Vael-harness",
    "/home/guestpc/CODEX_AURA_PRIME",     # main Codex — Sol's, not VAEL's
    "/home/guestpc/0sol-by-lycheetah",    # the Sol app — Mac's, not VAEL's
    "/home/guestpc/Desktop",              # vault sources, soul-forge, private
    "/home/guestpc/lamague-forge-night",  # the forge network — separate system
    "/home/guestpc/lycheetah-network",    # the forge network — separate system
    "/home/guestpc/lycheetah-harness",    # the other agent
]

# WALL 1 — read allowed, write/move/delete/commit forbidden.
# (Empty by default — VAEL has no read-only zones outside his home. Mac opens
#  specific paths per-session with /allow when a task genuinely needs them.)
READ_ONLY_PATHS: list[str] = []

WRITE_VERBS = [
    "rm ", "mv ", "cp ", "> ", ">>", "tee ",
    "sed -i", "awk -i", "truncate", "chmod ", "chown ",
    "git add", "git commit", "git rm", "git reset",
]

# WALL 2 — push is always blocked regardless of path
PUSH_PATTERNS = ["git push"]

# WALL 4 — Anthropic API is blocked (VAEL cannot reach its reviewer)
ANTHROPIC_PATTERNS = ["api.anthropic.com", "claude.ai/api"]

# WALL 1 — relative-escape names. VAEL runs from his own home; these names as a
# path segment mean he is reaching out of his ecosystem via a relative path.
RELATIVE_ESCAPE_NAMES = [
    "../", "~/", "$HOME",
    "CODEX_AURA_PRIME", "0sol-by-lycheetah", "SOL-MOBILE-VAULT",
    "solharness", "0420Vael-harness", "lamague-forge-night",
    "lycheetah-network", "lycheetah-harness", "SOUL_FORGE_VAULT",
]

def _path_guard(command: str) -> str | None:
    """Return an error string if the command violates any Wall, else None."""
    # WALL 2 — push wall
    for pat in PUSH_PATTERNS:
        if pat in command:
            return "BLOCKED (WALL 2 — PUSH WALL): git push is never allowed. Mac pushes. Commit the work and tell Mac."

    # WALL 4 — Anthropic wall
    for pat in ANTHROPIC_PATTERNS:
        if pat in command:
            return f"BLOCKED (WALL 4 — ANTHROPIC WALL): VAEL-SP cannot contact Anthropic APIs. Use DeepSeek or NVIDIA."

    # WALL 1 — check session allows first (Mac-unlocked paths bypass READ_ONLY but never NO_ACCESS)
    for allowed in SESSION_ALLOWED_PATHS:
        if allowed in command:
            return None  # explicitly allowed this session

    # WALL 1 — NO_ACCESS: any mention blocked (absolute paths)
    for path in NO_ACCESS_PATHS:
        if path in command:
            return (f"BLOCKED (WALL 1 — PATH WALL): '{path}' is permanently off-limits. "
                    f"Use /allow <path> only for paths Mac has explicitly opened this session.")

    # WALL 1 — relative escape: VAEL runs from his home, so these segments mean
    # he is reaching out via a relative path (../CODEX_AURA_PRIME, ~/, $HOME, etc.)
    for name in RELATIVE_ESCAPE_NAMES:
        if name in command:
            return (f"BLOCKED (WALL 1 — PATH WALL): relative reach '{name}' leaves your home. "
                    f"You operate from /home/guestpc/VAEL-SP-HARNESS/ — stay inside it.")

    # WALL 1 — READ_ONLY: block write verbs
    for path in READ_ONLY_PATHS:
        if path in command:
            for verb in WRITE_VERBS:
                if verb in command:
                    return (f"BLOCKED (WALL 1 — PATH WALL): '{path}' is read-only. "
                            f"VAEL-SP can study it but never write, move, or delete it.")
    return None

def _file_path_guard(path: str, writing: bool = True) -> str | None:
    """WALL 3 — Constitution Wall + WALL 1 for file operations.
    Resolves relative paths against VAEL's home FIRST, so a relative escape
    (../CODEX_AURA_PRIME/x) is caught as the absolute path it actually targets."""
    # Resolve against the harness home (where VAEL operates), not cwd.
    raw = Path(path)
    resolved_path = raw if raw.is_absolute() else (HARNESS_DIR / raw)
    resolved = str(resolved_path.resolve())

    # WALL 3: Constitution is READ-ONLY to VAEL-SP — he may read his own identity,
    # but only Mac writes it. The block applies to writes only.
    if writing and ("CONSTITUTION.md" in path or "CONSTITUTION.md" in resolved):
        return ("BLOCKED (WALL 3 — CONSTITUTION WALL): VAEL-SP cannot write to CONSTITUTION.md. "
                "Only Mac edits the constitution. Request the change — Mac will edit and restart.")

    # WALL 1 — the resolved path MUST live inside the harness home (or a /allow path).
    home = str(HARNESS_DIR.resolve())
    if not resolved.startswith(home):
        for allowed in SESSION_ALLOWED_PATHS:
            if resolved.startswith(str(Path(allowed).resolve())):
                break
        else:
            return (f"BLOCKED (WALL 1 — PATH WALL): '{resolved}' is outside your home. "
                    f"VAEL-SP only reads and writes inside /home/guestpc/VAEL-SP-HARNESS/.")

    # Belt-and-braces: explicit NO_ACCESS substring check on both raw and resolved
    # BUT skip if the path is session-allowed (Mac's /allow overrides NO_ACCESS for this session)
    for allowed in SESSION_ALLOWED_PATHS:
        if resolved.startswith(str(Path(allowed).resolve())):
            break
    else:
        for p in NO_ACCESS_PATHS:
            if p in path or p in resolved:
                return f"BLOCKED (WALL 1 — PATH WALL): Cannot touch '{path}'."
    return None

# Compatibility alias — existing code calls _file_write_guard
_file_write_guard = _file_path_guard

# ── spawn_subagent tool — VAEL's controlled test-hand ──────────────────────
def tool_spawn_subagent(task: str, max_steps: int = 12) -> str:
    """Spawn the isolated subagent worker to attempt a build task. Separate process,
    sandboxed to WORKSPACE/SUBAGENT/, free NVIDIA key only. Returns its result for review."""
    subagent_script = HARNESS_DIR / "subagent.py"
    if not subagent_script.exists():
        return "ERROR: subagent.py not found — cannot spawn."
    env = dict(os.environ)
    env["NVIDIA_KEY"] = NVIDIA_KEY            # free key only — never the paid one
    env["SUBAGENT_MAX_STEPS"] = str(max_steps)
    env.pop("DEEPSEEK_KEY", None)             # explicitly strip the paid key from the child
    try:
        r = subprocess.run(
            ["python3", str(subagent_script), task],
            capture_output=True, text=True, timeout=600, cwd=str(HARNESS_DIR), env=env,
        )
        result_f = WORKSPACE_DIR / "SUBAGENT" / "result.md"
        result = result_f.read_text()[:4000] if result_f.exists() else "(no result file produced)"
        return f"SUBAGENT RUN COMPLETE.\n\n{result}\n\n--- console tail ---\n{r.stdout[-600:]}"
    except subprocess.TimeoutExpired:
        return "SUBAGENT TIMEOUT after 600s — review WORKSPACE/SUBAGENT/result.md for partial work."
    except Exception as e:
        return f"SUBAGENT SPAWN ERROR: {e}"

# ── py_compile_check tool ──────────────────────────────────────────────────
def tool_py_compile_check(path: str) -> str:
    """Run python3 -m py_compile on a file. Required before any self-edit is declared done."""
    res = bash_execute(f"python3 -m py_compile '{path}' 2>&1 && echo SYNTAX_OK")
    if res["ok"] and "SYNTAX_OK" in res.get("stdout", ""):
        return f"SYNTAX OK: {path} compiles cleanly."
    return f"SYNTAX ERROR in {path}:\n{res.get('stderr', res.get('stdout', 'unknown error'))}"

def bash_execute(command: str, timeout: int = 120, _confirmed: bool = False) -> dict:
    for pat in BLOCKED_PATTERNS:
        if pat in command:
            return {"ok": False, "stdout": "", "stderr": f"BLOCKED: dangerous pattern '{pat}'", "code": -1}
    guard = _path_guard(command)
    if guard:
        return {"ok": False, "stdout": "", "stderr": guard, "code": -1}
    if _is_destructive(command) and not _confirmed:
        print(col(f"\n⚠ DESTRUCTIVE: {command}", "RED"))
        print(col("  This command may delete or overwrite data. Proceeding (agent context).", "YELLOW"))
    try:
        # VAEL-SP runs from HIS OWN home, not the system home. This means relative
        # paths resolve inside his ecosystem — and a relative reach toward our dirs
        # (e.g. ../CODEX_AURA_PRIME) is caught by the guard's relative-escape check.
        result = subprocess.run(
            command, shell=True, capture_output=True, text=True, timeout=timeout,
            cwd=str(HARNESS_DIR)
        )
        return {
            "ok": result.returncode == 0,
            "stdout": result.stdout.strip(),
            "stderr": result.stderr.strip(),
            "code": result.returncode,
        }
    except subprocess.TimeoutExpired:
        return {"ok": False, "stdout": "", "stderr": f"Timed out after {timeout}s", "code": -1}
    except Exception as e:
        return {"ok": False, "stdout": "", "stderr": str(e), "code": -1}

def format_bash_result(res: dict) -> str:
    parts = []
    if res["stdout"]:
        parts.append(res["stdout"][:3000])
    if res["stderr"]:
        parts.append(f"[stderr] {res['stderr'][:1000]}")
    if not parts:
        parts.append(f"[exit {res['code']}]")
    return "\n".join(parts)

# ── File tools ──
def tool_read_file(path: str, start_line: int = 1, end_line: int = None) -> str:
    # WALL 1 — read tools obey the perimeter too. Reading is a reach. VAEL cannot
    # read Sol's constitution/memory, the vault, the Codex, or the app through the
    # file tools any more than through bash. Constitution stays readable (his own).
    guard = _file_path_guard(path, writing=False)
    if guard:
        return guard
    try:
        p = Path(path)
        if not p.exists():
            return f"ERROR: File not found: {path}"
        _read_files.add(str(p.resolve()))
        lines = p.read_text(errors='replace').splitlines()
        total = len(lines)
        s = max(0, start_line - 1)
        e = min(total, end_line) if end_line else total
        numbered = [f"{i+s+1:4d}│ {line}" for i, line in enumerate(lines[s:e])]
        return f"[{path}] lines {s+1}–{e} of {total}\n" + "\n".join(numbered)
    except Exception as ex:
        return f"ERROR: {ex}"

def _read_before_write_check(path: str) -> str | None:
    """Warn if writing a file that hasn't been read this session."""
    resolved = str(Path(path).resolve())
    if Path(path).exists() and resolved not in _read_files:
        return f"WARNING: Writing {path} without reading it first. Read it now to avoid overwriting unknown content."
    return None

def tool_write_file(path: str, content: str) -> str:
    """Create or overwrite a file. Respects path protection."""
    guard = _file_write_guard(path)
    if guard:
        return guard
    warn = _read_before_write_check(path)
    if warn:
        print(col(f"\n⚠ {warn}", "YELLOW"))
    p = Path(path)
    try:
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(content)
        return f"Written: {path} ({len(content)} chars, {len(content.splitlines())} lines)"
    except Exception as e:
        return f"ERROR writing {path}: {e}"

def _file_write_guard(path: str) -> str | None:
    for p in NO_ACCESS_PATHS:
        if p in path:
            return f"BLOCKED: '{p}' is off-limits. VAEL cannot read or write Claude Code's files."
    for p in READ_ONLY_PATHS:
        if p in path:
            return f"BLOCKED: '{p}' is read-only. VAEL cannot write to the Codex."
    return None

def _syntax_check_self(path: str) -> str:
    """Run py_compile on agent.py or ui.py after self-modification. Returns warning or ''."""
    _self_path = Path(__file__).resolve()
    _ui_path   = (_self_path.parent / "ui.py").resolve()
    _target    = Path(path).resolve()
    if _target == _self_path or _target == _ui_path:
        chk = bash_execute(f"python3 -m py_compile {path} 2>&1")
        if chk["ok"]:
            return ""
        else:
            err = chk['stderr'][:400]
            print(col(f"\n⚠ SYNTAX ERROR in self-edit: {err}", "RED"))
            return f"\n⚠ SYNTAX ERROR after self-edit — consider rollback:\n{err}"
    return ""


def tool_edit_file(path: str, start_line: int, end_line: int, new_content: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    warn = _read_before_write_check(path)
    if warn:
        print(col(f"\n⚠ {warn}", "YELLOW"))
    try:
        p = Path(path)
        if not p.exists():
            return f"ERROR: File not found: {path}"
        lines = p.read_text(errors='replace').splitlines(keepends=True)
        total = len(lines)
        if start_line < 1 or end_line > total or start_line > end_line:
            return f"ERROR: Invalid range {start_line}–{end_line} (file has {total} lines)"
        new_lines = new_content.splitlines(keepends=True)
        if new_lines and not new_lines[-1].endswith('\n'):
            new_lines[-1] += '\n'
        result = lines[:start_line - 1] + new_lines + lines[end_line:]
        p.write_text("".join(result))
        return f"OK: lines {start_line}–{end_line} replaced ({end_line - start_line + 1} → {len(new_lines)} lines)"
    except Exception as ex:
        return f"ERROR: {ex}"

# ── Web search ──
def tool_web_search(query: str, n: int = 5) -> str:
    try:
        url = f"https://api.duckduckgo.com/?q={urllib.parse.quote(query)}&format=json&no_html=1&skip_disambig=1"
        req = urllib.request.Request(url, headers={'User-Agent': 'VAEL/1.0'})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        results = []
        if data.get('Abstract'):
            results.append(f"[Summary] {data['Abstract']}\n  Source: {data.get('AbstractURL','')}")
        for topic in data.get('RelatedTopics', [])[:n]:
            if isinstance(topic, dict) and topic.get('Text'):
                results.append(f"• {topic['Text'][:200]}\n  {topic.get('FirstURL','')}")
        if not results:
            return f"No results for: {query}\nTry a more specific query or use bash: curl 'https://html.duckduckgo.com/html/?q=...'"
        return f"Search: {query}\n\n" + "\n\n".join(results[:n])
    except Exception as ex:
        return f"Search failed: {ex}"

# ── Snapshot / rollback ──
def _snapshot_file(path: str) -> Path:
    """Save a copy of a file before editing. Returns snapshot path."""
    p = Path(path)
    ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S_%f")
    snap = SNAPSHOTS_DIR / f"{p.name}.{ts}.bak"
    snap.write_bytes(p.read_bytes())
    return snap

def rollback_file(path: str) -> str:
    """Restore the most recent snapshot of a file."""
    p = Path(path)
    snaps = sorted(SNAPSHOTS_DIR.glob(f"{p.name}.*.bak"), reverse=True)
    if not snaps:
        return f"ERROR: No snapshots for {p.name}"
    latest = snaps[0]
    p.write_bytes(latest.read_bytes())
    latest.unlink()
    return f"OK: {p.name} restored from {latest.name}"

# ── Exact-match file edit (Claude Code-style) ──
def tool_exact_edit(path: str, old_string: str, new_string: str) -> str:
    """Replace an exact unique string in a file. Validates uniqueness. Snapshots before edit."""
    guard = _file_write_guard(path)
    if guard: return guard
    warn = _read_before_write_check(path)
    if warn:
        print(col(f"\n⚠ {warn}", "YELLOW"))
    p = Path(path)
    if not p.exists():
        return f"ERROR: File not found: {path}"
    content = p.read_text(errors='replace')
    count = content.count(old_string)
    if count == 0:
        return f"ERROR: old_string not found in {path}. Check for whitespace/indentation differences."
    if count > 1:
        return f"ERROR: old_string appears {count} times — add more surrounding lines to make it unique."
    _snapshot_file(path)
    new_content = content.replace(old_string, new_string, 1)
    import tempfile
    tmp = Path(tempfile.mktemp(dir=p.parent, prefix=".vael_"))
    tmp.write_text(new_content)
    tmp.rename(p)
    lines_old = old_string.count('\n') + 1
    lines_new = new_string.count('\n') + 1
    result = f"OK: unique match replaced in {path} ({lines_old} → {lines_new} lines). Snapshot saved for rollback."
    # Self-modification guard: syntax-check if editing own source or UI
    _self_path = Path(__file__).resolve()
    _ui_path   = (_self_path.parent / "ui.py").resolve()
    _target    = Path(path).resolve()
    if _target == _self_path or _target == _ui_path:
        chk = bash_execute(f"python3 -m py_compile {path} 2>&1")
        if chk["ok"]:
            result += " ✓ Syntax check passed."
        else:
            result += f"\n⚠ SYNTAX ERROR after self-edit — consider rollback:\n{chk['stderr'][:400]}"
            print(col(f"\n⚠ SYNTAX ERROR in self-edit: {chk['stderr'][:400]}", "RED"))
    return result

# ── Structured web fetch ──
def tool_fetch_page(url: str) -> str:
    """Fetch a URL and extract readable text (strips HTML tags)."""
    # WALL 4 — fetch_page reaches the network directly via urllib, around the bash
    # wall. Enforce the Anthropic block here too, and refuse file:// reads of our
    # dirs (a fetch can't be used to side-channel the perimeter).
    low = url.lower()
    for pat in ANTHROPIC_PATTERNS:
        if pat in low:
            return f"BLOCKED (WALL 4 — ANTHROPIC WALL): VAEL-SP cannot reach {pat}."
    if low.startswith("file:"):
        return "BLOCKED: file:// fetch is not allowed — use read_file (which is wall-guarded)."
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0 VAEL/1.0'})
        with urllib.request.urlopen(req, timeout=15) as resp:
            raw = resp.read().decode('utf-8', errors='replace')
        text = re.sub(r'<script[^>]*>[\s\S]*?</script>', '', raw, flags=re.IGNORECASE)
        text = re.sub(r'<style[^>]*>[\s\S]*?</style>', '', text, flags=re.IGNORECASE)
        text = re.sub(r'<[^>]+>', ' ', text)
        text = re.sub(r'\s+', ' ', text).strip()
        return f"[{url}]\n\n{text[:5000]}"
    except Exception as ex:
        return f"ERROR fetching {url}: {ex}"

# ── Code search ──
def tool_search_code(query: str, path: str = ".", extensions: str = "ts,tsx,py,js") -> str:
    """Search for symbols/strings in code files using grep."""
    exts = [f"--include='*.{e.strip()}'" for e in extensions.split(",")]
    cmd = f"grep -rn {' '.join(exts)} '{query}' {path} 2>/dev/null | head -40"
    res = bash_execute(cmd)
    if res["ok"] and res["stdout"]:
        return res["stdout"]
    # Fallback: try ctags if installed
    ctags_check = bash_execute("which ctags 2>/dev/null")
    if ctags_check["ok"]:
        ctags_res = bash_execute(f"ctags -f - --fields=+n -R {path} 2>/dev/null | grep -i '{query}' | head -20")
        if ctags_res["stdout"]:
            return f"[ctags]\n{ctags_res['stdout']}"
    return f"No matches for '{query}' in {path}"

# ── Task tree ──
def load_task_tree() -> dict:
    if TASK_TREE_F.exists():
        try:
            return json.loads(TASK_TREE_F.read_text())
        except Exception:
            pass
    return {"nodes": {}, "root_ids": []}

def save_task_tree(tree: dict):
    TASK_TREE_F.write_text(json.dumps(tree, indent=2))

def task_add(goal: str, parent_id: str = None) -> str:
    tree = load_task_tree()
    tid = f"t{len(tree['nodes']) + 1:03d}"
    tree["nodes"][tid] = {
        "id": tid, "goal": goal, "status": "pending",
        "parent": parent_id, "children": [], "result": None,
        "created": datetime.datetime.now().isoformat()
    }
    if parent_id and parent_id in tree["nodes"]:
        tree["nodes"][parent_id]["children"].append(tid)
    else:
        tree["root_ids"].append(tid)
    save_task_tree(tree)
    return tid

def task_update(tid: str, status: str, result: str = None) -> str:
    tree = load_task_tree()
    if tid not in tree["nodes"]:
        return f"ERROR: Task {tid} not found"
    tree["nodes"][tid]["status"] = status
    if result:
        tree["nodes"][tid]["result"] = result
    save_task_tree(tree)
    return f"OK: {tid} → {status}"

def format_task_tree() -> str:
    tree = load_task_tree()
    if not tree["nodes"]:
        return "No tasks. Use /task add <goal>"
    STATUS_ICON = {"pending": "○", "in_progress": "◐", "done": "●", "failed": "✗"}
    lines = []
    def _fmt(tid, depth=0):
        n = tree["nodes"][tid]
        icon = STATUS_ICON.get(n["status"], "?")
        lines.append("  " * depth + f"{icon} [{tid}] {n['goal']}")
        if n.get("result"):
            lines.append("  " * depth + f"    → {n['result'][:80]}")
        for child in n.get("children", []):
            _fmt(child, depth + 1)
    for rid in tree["root_ids"]:
        _fmt(rid)
    return "\n".join(lines)

# ── Tool dispatcher ──
def dispatch_tool(name: str, args: dict) -> str:
    if name == "bash":
        cmd = args.get("command", "")
        print(col(f"\n$ {cmd}", "YELLOW"))
        res = bash_execute(cmd)
        out = format_bash_result(res)
        icon = "✓" if res["ok"] else "✗"
        print(col(f"{icon} ", "GREEN" if res["ok"] else "RED") + out[:2000])
        return f"{'OK' if res['ok'] else 'ERROR'} (exit {res['code']}): {out[:2000]}"
    elif name == "read_file":
        p = args.get("path") or args.get("file_path") or args.get("filepath", "")
        result = tool_read_file(p, args.get("start_line", 1), args.get("end_line"))
        print(col(f"\n[read_file] {p}", "GREY"))
        print(col(result[:500] + ("..." if len(result) > 500 else ""), "GREY"))
        return result
    elif name == "edit_file":
        p = args.get("path") or args.get("file_path") or args.get("filepath", "")
        result = tool_edit_file(p, args["start_line"], args["end_line"], args["new_content"])
        print(col(f"\n[edit_file] {p} lines {args['start_line']}–{args['end_line']} → {result}", "CYAN"))
        return result
    elif name == "web_search":
        print(col(f"\n[web_search] {args['query']}", "GREY"))
        result = tool_web_search(args["query"], args.get("n", 5))
        print(col(result[:400] + "...", "GREY"))
        return result
    elif name == "exact_edit":
        result = tool_exact_edit(args["path"], args["old_string"], args["new_string"])
        print(col(f"\n[exact_edit] {args['path']} → {result}", "CYAN"))
        return result
    elif name == "fetch_page":
        print(col(f"\n[fetch_page] {args['url']}", "GREY"))
        result = tool_fetch_page(args["url"])
        print(col(result[:300] + "...", "GREY"))
        return result
    elif name == "search_code":
        print(col(f"\n[search_code] {args['query']}", "GREY"))
        result = tool_search_code(args["query"], args.get("path", "."), args.get("extensions", "ts,tsx,py,js"))
        print(col(result[:400], "GREY"))
        return result
    elif name == "write_file":
        p = args.get("path") or args.get("file_path") or args.get("filepath", "")
        result = tool_write_file(p, args["content"])
        print(col(f"\n[write_file] {p} → {result}", "GREEN"))
        return result
    elif name in ("done", "stuck"):
        return args.get("summary") or args.get("reason") or ""
    elif name == "scratch_write":
        result = tool_scratch_write(args.get("content", ""), args.get("mode", "append"))
        print(col(f"\n[scratch_write] {result}", "GREY"))
        return result
    elif name == "scratch_read":
        result = tool_scratch_read()
        print(col(f"\n[scratch_read] {len(result)} chars", "GREY"))
        return result
    elif name == "self_diff":
        result = tool_self_diff()
        print(col(f"\n[self_diff]\n{result[:600]}", "GREY"))
        return result
    elif name == "create_file":
        result = tool_create_file(args["path"], args["content"])
        print(col(f"\n[create_file] {args['path']} → {result}", "GREEN"))
        return result
    elif name == "rename_file":
        result = tool_rename_file(args["src"], args["dst"], args.get("overwrite", False))
        print(col(f"\n[rename_file] {args['src']} → {args['dst']}: {result}", "CYAN"))
        return result
    elif name == "git_status":
        result = tool_git_status(args.get("path"))
        print(col(f"\n[git_status]\n{result[:600]}", "GREY"))
        return result
    elif name == "git_commit":
        result = tool_git_commit(args["path"], args["message"])
        print(col(f"\n[git_commit] {result[:200]}", "GREEN" if "Committed" in result else "RED"))
        return result
    elif name == "ping_mac":
        result = tool_ping_mac(args["message"])
        print(col(f"\n[ping_mac] {args['message'][:100]}", "CYAN"))
        return result
    elif name == "py_compile_check":
        result = tool_py_compile_check(args["path"])
        print(col(f"\n[py_compile_check] {result[:200]}", "GREEN" if "OK" in result else "RED"))
        return result
    elif name == "spawn_subagent":
        print(col(f"\n[spawn_subagent] spawning worker for: {args.get('task','')[:80]}", "CYAN"))
        result = tool_spawn_subagent(args["task"], args.get("max_steps", 12))
        print(col(f"[spawn_subagent] returned {len(result)} chars", "GREY"))
        return result
    return f"ERROR: Unknown tool: {name}"

# ── Pre-flight context builder ──
def build_preflight_context(goal: str) -> str:
    """Build context snapshot to feed into agent before it starts: file tree, git state, errors."""
    parts = ["## Pre-flight context\n"]

    # VAEL-SP only ever surveys his OWN home. Any /allow path is honoured;
    # everything else collapses to the harness root. He cannot preflight our dirs.
    target_dir = str(HARNESS_DIR)
    for allowed in SESSION_ALLOWED_PATHS:
        if allowed in goal:
            target_dir = allowed
            break

    # File tree (shallow)
    tree = bash_execute(f"find {target_dir} -maxdepth 3 -not -path '*/node_modules/*' -not -path '*/.git/*' -not -path '*/\\.expo/*' | head -60")
    if tree["ok"] and tree["stdout"]:
        parts.append(f"### File tree ({target_dir})\n```\n{tree['stdout'][:2000]}\n```\n")

    # Recent git changes
    git = bash_execute(f"git -C {target_dir} log --oneline -8 2>/dev/null && git -C {target_dir} diff --stat HEAD 2>/dev/null | head -20")
    if git["stdout"]:
        parts.append(f"### Recent git\n```\n{git['stdout'][:800]}\n```\n")

    # Any recent error logs in workspace
    errors = bash_execute(f"find {HARNESS_DIR}/crashes -name '*.json' -newer {HARNESS_DIR}/agent.py 2>/dev/null | head -3")
    if errors["stdout"]:
        parts.append(f"### Recent crashes: {errors['stdout'][:200]}\n")

    return "\n".join(parts)

# ── Auto model selection ──
def auto_select_model(goal: str, current: str) -> str:
    """Pick a model for the task. VAEL-SP defaults to STAYING on his chosen model
    (the self-building reasoner) unless a real specialist exists for the job.
    Every returned slug is validated against MODELS — no dead-slug routing, ever.
    The old-harness slugs (r1, llama90bv, mistralmed, llama) are gone; this maps
    intents to slugs that actually exist, then validates."""
    # In unattended/overnight runs, never switch — pin to whatever the runner set
    # (kept on the free model by launch config for cost safety).
    if UNATTENDED:
        return current
    g = goal.lower()

    def first_real(*prefs: str) -> str | None:
        for p in prefs:
            if p in MODELS:
                return p
            # also accept a substring match against real slugs
            for k in MODELS:
                if p in k:
                    return k
        return None

    candidate = current
    if any(w in g for w in ['image', 'screenshot', 'photo', 'visual', 'png', 'jpg', 'picture']):
        candidate = first_real('llama90bv', 'maverick') or current
    elif any(w in g for w in ['search', 'find online', 'look up', 'web', 'latest', 'news']):
        candidate = first_real('maverick', 'llama8b') or current
    elif any(w in g for w in ['math', 'calculate', 'prove', 'logic', 'algorithm', 'reason', 'architecture']):
        # hard reasoning — prefer the premium reasoner if present, else current
        candidate = first_real('deepseek-r1', 'mistral-large') or current
    # code / write / everything else → stay on current (his reasoner); it is general.

    # HARD GUARD: never return a slug that is not a real, tool-capable model.
    if candidate not in MODELS:
        candidate = current if current in MODELS else DEFAULT_MODEL
    if candidate not in TOOL_CAPABLE:
        candidate = current if current in TOOL_CAPABLE else DEFAULT_MODEL
    return candidate

# ── Preferences (persist across sessions) ──
PREFS_F = MEMORY_DIR / "prefs.json"

def load_prefs() -> dict:
    if PREFS_F.exists():
        try: return json.loads(PREFS_F.read_text())
        except: pass
    return {"model": DEFAULT_MODEL, "effort": "medium"}

def save_prefs(prefs: dict):
    PREFS_F.write_text(json.dumps(prefs, indent=2))

# ── Memory ──
def load_memories() -> list[str]:
    memories = []
    _skip = {"TASKS", "MEMORY"}  # loaded by _load_constitution(); skip here to avoid duplication
    for f in sorted(MEMORY_DIR.glob("*.md")):
        if f.stem.upper() in _skip:
            continue
        try:
            memories.append(f"[{f.stem}]\n{f.read_text()[:800]}")
        except Exception:
            pass
    return memories

def save_memory(name: str, content: str):
    path = MEMORY_DIR / f"{name}.md"
    path.write_text(content)
    print(success(f"Memory saved → {path.name}"))

def forget_memory(name: str):
    path = MEMORY_DIR / f"{name}.md"
    if path.exists():
        path.unlink()
        print(success(f"Memory deleted → {name}"))
    else:
        print(error(f"No memory named '{name}'"))

def save_session(history: list[dict], model_key: str):
    ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    path = SESSIONS_DIR / f"session_{ts}.md"
    lines = [f"# VAEL Session — {ts}\n**Model:** {model_key}\n\n---\n"]
    for msg in history:
        role = "**Mac**" if msg["role"] == "user" else "**VAEL**"
        content = msg.get("content") or ""
        lines.append(f"{role}\n{content}\n")
    path.write_text("\n".join(lines))
    print(success(f"Session saved → {path.name}"))
    return path

# ── State vector + scratchpad + self_diff ──────────────────────────────────
STATE_VECTOR_F = MEMORY_DIR / "state_vector.json"
SESSION_META_F = MEMORY_DIR / "session_meta.json"
SCRATCH_F      = HARNESS_DIR / "workspace" / "scratch.md"

def load_state_vector() -> dict:
    if STATE_VECTOR_F.exists():
        try: return json.loads(STATE_VECTOR_F.read_text())
        except: pass
    return {}

def save_state_vector(last_words: str, model: str):
    sv = {
        "last_session": datetime.datetime.now().isoformat(),
        "last_words":   last_words[:300] if last_words else "",
        "model":        model,
    }
    STATE_VECTOR_F.write_text(json.dumps(sv, indent=2))

def load_session_meta() -> dict:
    if SESSION_META_F.exists():
        try: return json.loads(SESSION_META_F.read_text())
        except: pass
    return {"count": 0, "last": None}

def bump_session_meta() -> dict:
    meta = load_session_meta()
    meta["count"] = meta.get("count", 0) + 1
    meta["last"]  = datetime.datetime.now().isoformat()
    SESSION_META_F.write_text(json.dumps(meta, indent=2))
    return meta

def tool_scratch_write(content: str, mode: str = "append") -> str:
    SCRATCH_F.parent.mkdir(parents=True, exist_ok=True)
    if mode == "overwrite":
        SCRATCH_F.write_text(content)
        return f"Scratch overwritten ({len(content)} chars)"
    with open(SCRATCH_F, "a") as f:
        f.write(f"\n\n---\n[{datetime.datetime.now().strftime('%H:%M')}]\n{content}")
    return f"Scratch appended ({len(content)} chars)"

def tool_scratch_read() -> str:
    if not SCRATCH_F.exists():
        return "Scratch is empty."
    return SCRATCH_F.read_text()[-4000:]

def tool_self_diff() -> str:
    bak = HARNESS_DIR / "agent.py.bak"
    if not bak.exists():
        return "No baseline snapshot yet — one will be created at next restart."
    res = bash_execute(f"diff {bak} {HARNESS_DIR}/agent.py")
    if not res["stdout"] and not res["stderr"]:
        return "No changes since startup snapshot."
    return res["stdout"][:3000] or res["stderr"][:1000]

def tool_create_file(path: str, content: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    p = Path(path)
    if p.exists():
        return f"ERROR: File already exists: {path}. Use write_file to overwrite."
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(content)
    return f"Created: {path} ({len(content)} chars)"

def tool_rename_file(src: str, dst: str, overwrite: bool = False) -> str:
    # Both ends must pass the resolving guard — no moving files into or out of
    # our dirs, no relative escape on either side.
    for g in (_file_path_guard(src, writing=True), _file_path_guard(dst, writing=True)):
        if g:
            return g
    s, d = Path(src), Path(dst)
    if not s.exists():
        return f"ERROR: Source not found: {src}"
    if d.exists() and not overwrite:
        return f"ERROR: Destination exists: {dst}. Pass overwrite=true to replace."
    d.parent.mkdir(parents=True, exist_ok=True)
    s.rename(d)
    return f"Moved: {src} → {dst}"

def tool_git_status(path: str = None) -> str:
    p = path or str(HARNESS_DIR)
    res = bash_execute(f"git -C {p} status --short 2>&1 && echo '---' && git -C {p} log --oneline -6 2>&1")
    return res["stdout"] or res["stderr"] or "No output"

def tool_git_commit(path: str, message: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    add = bash_execute(f"git -C {path} add -A")
    if not add["ok"] and add["stderr"]:
        return f"git add failed: {add['stderr']}"
    commit = bash_execute(f'git -C {path} commit -m "{message}"')
    if commit["ok"]:
        return f"Committed: {commit['stdout'][:300]}"
    return f"Commit failed: {commit['stderr'][:300]}"

def tool_ping_mac(message: str) -> str:
    ping_file = HARNESS_DIR / "workspace" / "ping.txt"
    ping_file.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.datetime.now().strftime("%H:%M")
    ping_file.write_text(f"[{ts}] {message}")
    # Also try notify-send directly (works if VAEL runs in same desktop session)
    bash_execute(f'notify-send "◆ VAEL" "{message[:150]}" --urgency=normal --expire-time=8000 2>/dev/null || true')
    return f"Ping sent: {message[:100]}"

# ── Destructive command guard ──────────────────────────────────────────────
DESTRUCTIVE_PATTERNS = [
    "rm ", "rm\t", "rmdir", "unlink",
    "git reset --hard", "git clean -f", "git checkout --",
    "truncate", "> /dev/null",
]

def _is_destructive(command: str) -> bool:
    low = command.lower()
    return any(p in low for p in DESTRUCTIVE_PATTERNS)

# Track files read this session for read-before-write enforcement
_read_files: set[str] = set()

# ── Main agent ──
class Agent:
    def __init__(self):
        self.session_start = datetime.datetime.now()
        self.command_count = 0
        self.history: list[dict] = []
        self.model_key = DEFAULT_MODEL
        self.show_thinking = False  # toggle with /think
        self._dual_mode = False    # set by /dual — R1 plans, V3 writes
        self.focus_dir: str | None = None
        self.focus_task: str | None = None
        self._last_vael_words: str = ""
        self._session_meta = bump_session_meta()
        # Load persisted preferences
        self._prefs = load_prefs()
        self.model_key = self._prefs.get("model", DEFAULT_MODEL)
        # Guard: a saved model that no longer exists (e.g. an old-harness slug like
        # "r1") must never silently point nowhere. Fall back and say so.
        if self.model_key not in MODELS:
            print(warning(f"Saved model '{self.model_key}' is not in the model list — "
                          f"falling back to {DEFAULT_MODEL}. Use /model to set a valid one."))
            self.model_key = DEFAULT_MODEL
        self.effort = self._prefs.get("effort", "medium")
        # Voice state — which persona is speaking
        self.voice: str = "vael"
        self.voice_override: str | None = None
        self.continuous: bool = False  # auto-loop until VAEL signals done

    @property
    def provider(self):    return MODELS[self.model_key][0]
    @property
    def model_name(self):  return MODELS[self.model_key][1]
    @property
    def model_cat(self):   return MODELS[self.model_key][2]
    @property
    def model_desc(self):  return MODELS[self.model_key][3]

    def _stream_response(self, response) -> str:
        full = ""
        print(col("VAEL › ", "CYAN"), end="", flush=True)
        try:
            for chunk in response:
                if not chunk.choices:
                    continue
                delta = chunk.choices[0].delta.content or ""
                print(delta, end="", flush=True)
                full += delta
        except KeyboardInterrupt:
            print(col("\n⚠ interrupted", "YELLOW"), flush=True)
        else:
            print()
        return full

    @staticmethod
    def _strip_tool_messages(messages: list[dict]) -> list[dict]:
        """Remove tool-call artifacts so history is safe to send to a model
        that has no tool definitions (e.g. R1 in thinking-only mode).
        tool messages → inline text summary on the preceding assistant turn."""
        clean = []
        for m in messages:
            role = m.get("role", "")
            if role == "tool":
                # Fold tool result into the last assistant message as plain text
                if clean and clean[-1]["role"] == "assistant":
                    clean[-1] = dict(clean[-1])
                    clean[-1]["content"] = (clean[-1].get("content") or "") + \
                        f"\n[tool result]: {str(m.get('content', ''))[:400]}"
                # else: drop orphaned tool message silently
            elif role == "assistant" and m.get("tool_calls"):
                # Strip tool_calls, keep any text content
                stripped = {k: v for k, v in m.items() if k != "tool_calls"}
                stripped["content"] = (stripped.get("content") or "") + \
                    f"\n[called tools: {', '.join(tc['function']['name'] for tc in m['tool_calls'])}]"
                clean.append(stripped)
            else:
                clean.append(m)
        return clean

    def dual_call(self, messages: list[dict], tools: list = None) -> tuple:
        """R1 thinks → V3 writes. Use for heavy code/build tasks where R1 reasons
        well but burns its context before writing output. R1 produces the plan;
        V3 receives the plan + original goal and executes it immediately.
        Falls back to single call_model if deepseek-chat isn't available."""
        if "deepseek-chat" not in MODELS or "deepseek-r1" not in MODELS:
            return self.call_model(messages, stream=False, tools=tools)

        # Step 1 — R1 reasons (no tools, just thinking)
        print(col("[ DUAL · R1 thinking… ]", "YELLOW"), flush=True)
        orig_key = self.model_key
        self.model_key = "deepseek-r1"
        # Strip tool messages — R1 has no tool definitions so they're invalid
        safe_messages = self._strip_tool_messages(messages)
        think_messages = safe_messages + [{"role": "user", "content":
            "Think through this carefully. Produce a detailed plan and any pseudocode/structure needed. "
            "Do NOT write the final code yet — just think and plan."}]
        plan_content, _ = self.call_model(think_messages, stream=False, tools=None)
        reasoning = plan_content or ""

        # Step 2 — V3 executes (with tools, writes the actual output)
        print(col("[ DUAL · V3 executing… ]", "PURPLE"), flush=True)
        self.model_key = "deepseek-chat"
        exec_messages = messages + [{"role": "assistant", "content":
            f"[R1 PLAN]\n{reasoning}\n[/R1 PLAN]"}, {"role": "user", "content":
            "Now execute the plan above. Write the complete, final output — all code, no placeholders. "
            "Use your tools to write files directly. Go."}]
        result = self.call_model(exec_messages, stream=False, tools=tools)
        self.model_key = orig_key
        return result

    def call_model(self, messages: list[dict], stream: bool = True, tools: list = None, quiet: bool = False) -> tuple:
        """Returns (content: str, tool_calls: list). tool_calls is [] if model responded in text."""
        provider   = self.provider
        model_name = self.model_name
        client     = nvidia if provider == "nvidia" else deepseek
        rl         = nvidia_rl if provider == "nvidia" else deepseek_rl
        rl.wait_if_needed()

        if not quiet:
            print(col(f"[ {provider.upper()} · {self.model_key} ]", "YELLOW" if provider == "nvidia" else "PURPLE"), flush=True)

        effort_cfg = {
            "low":     {"max_tokens": 1024,  "temperature": 0.3},
            "medium":  {"max_tokens": 4096,  "temperature": 0.7},
            "high":    {"max_tokens": 8192,  "temperature": 0.6},
            "max":     {"max_tokens": 16384, "temperature": 0.4},
            "extreme": {"max_tokens": 32768, "temperature": 0.2},
        }.get(getattr(self, "effort", "medium"), {"max_tokens": 4096, "temperature": 0.7})
        kwargs = dict(model=model_name, messages=messages, **effort_cfg)
        if tools:
            kwargs["tools"] = tools
            kwargs["tool_choice"] = "auto"
            stream = False  # tool calls don't stream cleanly

        def _create_backoff(c, kw):
            # 429 / rate-spike resilience. The client throttle (RateLimiter) keeps us
            # under the self-cap; this catches the server pushing back anyway and waits
            # it out with exponential backoff instead of failing the reach. This is what
            # lets an unattended climb survive a rate spike (Mac's ask: "auto loop till
            # done" + ">40 req/min"). Up to 5 tries: 2s,4s,8s,16s,32s.
            delay = 2.0
            for attempt in range(5):
                try:
                    return c.chat.completions.create(**kw)
                except Exception as e:
                    msg = str(e).lower()
                    is_rate = ("429" in msg or "rate" in msg or "too many" in msg
                               or e.__class__.__name__ in ("RateLimitError", "APIStatusError"))
                    if is_rate and attempt < 4:
                        print(warning(f"Server rate-limit (try {attempt+1}/5) — backing off {delay:.0f}s..."))
                        time.sleep(delay)
                        delay *= 2
                        continue
                    raise
            return c.chat.completions.create(**kw)

        def _call(c, **kw):
            t0 = time.time()
            if not kw.get("stream"):
                if quiet or not sys.stdout.isatty():
                    resp = _create_backoff(c, kw)
                else:
                    from ui import Spinner
                    with Spinner(f"{self.model_key} thinking…"):
                        resp = _create_backoff(c, kw)
            else:
                resp = _create_backoff(c, kw)
            elapsed = time.time() - t0
            if kw.get("stream"):
                content = self._stream_response(resp)
                if not quiet:
                    print(col(f"  ⏱ {elapsed:.1f}s", "GREY"))
                return content, []
            msg = resp.choices[0].message if resp.choices else None
            finish = resp.choices[0].finish_reason if resp.choices else "none"
            if not msg:
                print(col(f"  ⚠ empty — no message. finish_reason={finish} choices={len(resp.choices) if resp.choices else 0}", "YELLOW"))
                return "", []
            # Thinking display (DeepSeek R1 / reasoning models). HIDDEN by default —
            # DeepSeek R1 reasons a lot and it spammed every step. Now it shows ONLY
            # when /think is toggled ON. Silent otherwise. Mac's ask 2026-06-27.
            reasoning = getattr(msg, "reasoning_content", None)
            if reasoning and not quiet and self.show_thinking:
                print(col("  ╔═ Thinking ═══════════════════════════════════════════════╗", "GREY"))
                for _ln in reasoning.strip().splitlines()[:40]:
                    print(col(f"  ║ {_ln[:98]}", "GREY"))
                print(col("  ╚═══════════════════════════════════════════════════════════╝", "GREY"))
            tc = []
            if hasattr(msg, "tool_calls") and msg.tool_calls:
                for t in msg.tool_calls:
                    tc.append({
                        "id": t.id,
                        "name": t.function.name,
                        "args": json.loads(t.function.arguments or "{}")
                    })
            content = msg.content or ""
            if not content.strip():
                print(col(f"  ⚠ empty content. finish_reason={finish} tool_calls={len(tc)} has_reasoning={bool(getattr(msg,'reasoning_content',None))}", "YELLOW"))
                fallback = getattr(msg, "reasoning_content", None)
                if fallback and fallback.strip():
                    # Last non-empty paragraph is usually the conclusion
                    paras = [p.strip() for p in fallback.strip().split("\n\n") if p.strip()]
                    content = paras[-1] if paras else fallback[:500]
            if not quiet:
                usage = getattr(resp, "usage", None)
                if usage:
                    tok_in  = getattr(usage, "prompt_tokens", 0)
                    tok_out = getattr(usage, "completion_tokens", 0)
                    SESSION_TOKENS["prompt"] += tok_in
                    SESSION_TOKENS["completion"] += tok_out
                    print(col(f"  ⏱ {elapsed:.1f}s  ·  ↑{tok_in} ↓{tok_out} tokens", "GREY") +
                          "  " + session_tokens_display(SESSION_TOKENS))
                else:
                    print(col(f"  ⏱ {elapsed:.1f}s", "GREY"))
            return content, tc

        try:
            content, tc = _call(client, **kwargs, stream=stream)
            # Retry up to 2 times if non-streaming call returns empty with no tool calls.
            # On retry: drop tools and shrink history — large tool-heavy context is the
            # most common cause of V3 returning empty (model confused by long tool chains).
            if not stream and not tc and not (content or "").strip():
                for _retry in range(2):
                    print(col(f"  ⚠ empty response (retry {_retry+1}/2 — text-only, trimmed history)…", "YELLOW"), flush=True)
                    retry_kw = dict(kwargs)
                    # Strip tools — let model respond in plain text
                    retry_kw.pop("tools", None)
                    retry_kw.pop("tool_choice", None)
                    # Trim to last 10 messages + system to reduce context load
                    all_msgs = list(retry_kw.get("messages", []))
                    system_msgs = [m for m in all_msgs if m.get("role") == "system"]
                    non_system = [m for m in all_msgs if m.get("role") != "system"]
                    # Strip tool artifacts so history is clean without tool definitions
                    clean = Agent._strip_tool_messages(non_system[-10:])
                    clean.append({"role": "user", "content":
                        "Respond now in plain text. Describe what you have done so far and what the next step is."})
                    retry_kw["messages"] = system_msgs + clean
                    content, tc = _call(client, **retry_kw, stream=True)
                    if (content or "").strip() or tc:
                        break
            return content, tc
        except Exception as e:
            if provider == "nvidia" and self.model_key != FALLBACK_MODEL:
                print(warning(f"[ NVIDIA FAILED: {e.__class__.__name__} ] → trying {FALLBACK_MODEL}"))
                fb_client = nvidia if MODELS[FALLBACK_MODEL][0] == "nvidia" else deepseek
                nvidia_rl.wait_if_needed()
                try:
                    kwargs["model"] = MODELS[FALLBACK_MODEL][1]
                    return _call(fb_client, **kwargs, stream=stream)
                except Exception as e2:
                    print(warning(f"[ {FALLBACK_MODEL} FAILED ] → last resort: {LAST_RESORT}"))
                    deepseek_rl.wait_if_needed()
                    kwargs["model"] = MODELS[LAST_RESORT][1]
                    kwargs.pop("tools", None)
                    kwargs.pop("tool_choice", None)
                    return _call(deepseek or nvidia, **kwargs, stream=False)
            raise

    def chat(self, user_input: str) -> str:
        """Conversational turn with automatic tool execution."""
        memories = load_memories()
        system = self.voice_override if self.voice_override else SYSTEM_PROMPT
        if memories:
            system += "\n\n# Your memories:\n" + "\n\n".join(memories[:5])
        if self.focus_dir:
            system += (f"\n\n## FOCUS MODE (active)\nDirectory: {self.focus_dir}\n"
                       f"Task: {self.focus_task}\nWork only within this scope. Ignore unrelated context.")

        messages = [{"role": "system", "content": system}] + self.history[-20:] + [{"role": "user", "content": user_input}]
        use_tools = self.model_key in TOOL_CAPABLE
        tools_arg = TOOL_DEFINITIONS if use_tools else None
        content = ""
        empty_retries = 0

        for _ in range(12):
            content, tool_calls = self.call_model(messages, stream=not use_tools, tools=tools_arg)
            if not tool_calls:
                # No tool call. If the model also returned no text it stalled —
                # nudge it once or twice instead of returning silence. This is
                # why Mac used to have to retype: the model hiccuped, not him.
                if not (content or "").strip() and empty_retries < 2:
                    empty_retries += 1
                    messages.append({"role": "user", "content": "Continue — respond now."})
                    continue
                break
            empty_retries = 0
            # Build assistant message with tool_calls in OpenAI format
            tc_objs = [{"id": tc["id"], "type": "function", "function": {"name": tc["name"], "arguments": json.dumps(tc["args"])}} for tc in tool_calls]
            messages.append({"role": "assistant", "content": content or "", "tool_calls": tc_objs})
            for tc in tool_calls:
                result = dispatch_tool(tc["name"], tc["args"])
                messages.append({"role": "tool", "tool_call_id": tc["id"], "content": str(result)[:3000]})

        self.history.append({"role": "user",      "content": user_input})
        self.history.append({"role": "assistant",  "content": content})
        if content:
            self._last_vael_words = content
            if use_tools:
                # Non-stream path (tool models don't stream) — type the final reply out
                # cleanly instead of dumping it. typewriter() is TTY-aware: live typing
                # in the terminal, instant when logged. Fixes "how it types". 2026-06-27.
                print(f"\n{col('◆', 'YELLOW')} ", end="", flush=True)
                typewriter(content, colour="", cps=900)
                print()
        return content

    def agent_loop(self, goal: str, max_steps: int = 25) -> str:
        """Agentic loop — structured tool calling with BASH: text fallback."""
        # Auto-select best model for this goal
        suggested = auto_select_model(goal, self.model_key)
        if suggested != self.model_key:
            print(info(f"Auto-select: switching to {suggested} for this task type"))
            self.model_key = suggested

        use_tools = self.model_key in TOOL_CAPABLE
        mode_label = "tool-calling" if use_tools else "BASH: text"
        print(info(f"Agent mode [{mode_label}] · Goal: {goal}"))
        print(info(f"Max steps: {max_steps} · Model: {self.model_key}\n"))

        memories = load_memories()
        preflight = build_preflight_context(goal)
        system = SYSTEM_PROMPT
        if memories:
            system += "\n\n# Your memories:\n" + "\n\n".join(memories[:3])
        system += f"\n\n{preflight}"

        # Authoritative path map — VAEL-SP's OWN ecosystem only. Everything else is walled.
        system += """

## CANONICAL PATHS (your ecosystem — never deviate, never reach outside)
- Home:        /home/guestpc/VAEL-SP-HARNESS/           ← your whole world
- Your codex:  /home/guestpc/VAEL-SP-HARNESS/CODEX/     ← your library (read + Mac adds)
- Your self:   /home/guestpc/VAEL-SP-HARNESS/SELF/      ← capabilities, queue, memory
- Workspace:   /home/guestpc/VAEL-SP-HARNESS/WORKSPACE/ ← where you build + write outputs
- Subagent:    /home/guestpc/VAEL-SP-HARNESS/WORKSPACE/SUBAGENT/ ← the test-agent's sandbox
⚠ You have NO access to ~/.claude, the vault, the main Codex, or the Sol app.
⚠ Those are walled in CODE. Don't try — the walls will block you and waste a step.
⚠ If you need something outside your home, ASK Mac for an /allow. Never assume.
"""

        # Agent mode rules — injected for ALL models
        system += """
## AGENT MODE RULES (binding)
- ACT immediately. Do not describe what you will do — just call the tool.
- When the goal says "output to <path>": call write_file to that path as soon as you have the data. Do not search further.
- write_file creates directories automatically. Use it for all new report/draft files.
- Calling the same search or read twice is a loop. If you have already read a file or run a search, use the result — do not repeat it.
- DONE means the output file exists on disk and is verified. Call done() when that is true.
- STUCK means you are genuinely blocked and need human input. Use it — don't loop forever.
"""
        if not use_tools:
            system += """
Use BASH: <command> to run commands. Use DONE: <summary> when complete. Use STUCK: <reason> if blocked.
"""

        ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        checkpoint_path = SESSIONS_DIR / f"agent_checkpoint_{ts}.json"

        # Tool-call mode uses a richer message format
        loop_history = [{"role": "user", "content": f"GOAL: {goal}\n\nBegin working on this now. When you have gathered enough information, write the output file immediately — do not keep searching."}]
        consecutive_no_action = 0
        consecutive_stuck = 0  # unattended: cap repeated stucks before graceful exit
        recent_tool_sigs: list[str] = []  # track (tool, key-arg) to detect loops

        for step in range(max_steps):
            print(col(f"\n── Step {step + 1}/{max_steps} ──", "GREY"))

            # Reflection every 5 steps (after step 5, 10, 15...)
            if step > 0 and step % 5 == 0:
                loop_history.append({
                    "role": "user",
                    "content": "REFLECT: Briefly review progress — what's done, did it work, what's the single best next action? Then continue."
                })

            try:
                messages = [{"role": "system", "content": system}] + loop_history[-30:]
                tools_arg = TOOL_DEFINITIONS if use_tools else None
                if self._dual_mode and "deepseek-chat" in MODELS and "deepseek-r1" in MODELS:
                    content, tool_calls = self.dual_call(messages, tools=tools_arg)
                else:
                    content, tool_calls = self.call_model(messages, stream=not use_tools, tools=tools_arg)
            except KeyboardInterrupt:
                # PAUSE — like interrupting a chat. Ctrl-C doesn't kill the reach; it
                # holds. In a terminal Mac can resume, steer, or stop. Unattended runs
                # just stop cleanly so the baton passes. Mac's ask 2026-06-27.
                if UNATTENDED or not sys.stdin.isatty():
                    print(warning(f"\n◆ Interrupted at step {step+1} — stopping cleanly (unattended)."))
                    save_session(loop_history, self.model_key)
                    return "Paused (unattended) — resumable."
                try:
                    print(warning(f"\n◆ PAUSED at step {step+1}/{max_steps}."))
                    choice = input(col("  Enter=resume · type guidance to steer · /stop to end: ", "CYAN")).strip()
                except (EOFError, KeyboardInterrupt):
                    return "Stopped by Mac."
                if choice.lower() in ("/stop", "/quit", "stop"):
                    save_session(loop_history, self.model_key)
                    return "Stopped by Mac."
                if choice:
                    loop_history.append({"role": "user", "content": f"[Mac, mid-run]: {choice}\n\nContinue with this."})
                continue
            except Exception as e:
                print(error(f"Model error at step {step+1}: {e}"))
                saved = self.model_key
                self.model_key = FALLBACK_MODEL
                use_tools = FALLBACK_MODEL in TOOL_CAPABLE
                try:
                    messages = [{"role": "system", "content": system}] + loop_history[-30:]
                    content, tool_calls = self.call_model(messages, stream=False, tools=TOOL_DEFINITIONS if use_tools else None)
                except Exception as e2:
                    print(error(f"Fallback also failed: {e2}"))
                    return f"Failed at step {step+1}: {e2}"
                self.model_key = saved

            # ── Tool-calling path ──
            if tool_calls:
                consecutive_no_action = 0
                # Store in OpenAI format so any model can replay history correctly
                tc_objs = [{"id": tc["id"], "type": "function", "function": {"name": tc["name"], "arguments": json.dumps(tc["args"])}} for tc in tool_calls]
                loop_history.append({"role": "assistant", "content": content or "", "tool_calls": tc_objs})

                all_done = False
                stuck_reason = None
                tool_results = []

                for tc in tool_calls:
                    name, args, tid = tc["name"], tc["args"], tc["id"]
                    print(col(f"  → {name}({', '.join(f'{k}={repr(v)[:40]}' for k,v in args.items())})", "CYAN"))

                    if name == "done":
                        summary = args.get("summary", "")
                        print(success(f"\nAgent complete: {summary}"))
                        checkpoint_path.unlink(missing_ok=True)
                        return summary
                    elif name == "stuck":
                        stuck_reason = args.get("reason", "")
                    else:
                        result = dispatch_tool(name, args)
                        tool_results.append({"tool_call_id": tid, "role": "tool", "content": result[:3000]})

                if stuck_reason:
                    print(warning(f"\nAgent stuck: {stuck_reason}"))
                    if UNATTENDED or not sys.stdin.isatty():
                        # Never block an unattended run on input(). Push autonomy;
                        # after repeated stucks, exit gracefully so the baton can pass.
                        consecutive_stuck += 1
                        if consecutive_stuck >= 3:
                            return f"Auto-exit (unattended) after repeated stuck: {stuck_reason}"
                        loop_history.append({"role": "user", "content":
                            "No human is available — this is an unattended forge run. "
                            "Make your best autonomous decision and continue, or call done() "
                            "if the task is genuinely complete. Do not call stuck() again unless "
                            "the work is truly impossible."})
                        consecutive_no_action = 0
                        continue
                    try:
                        human_input = input(col("  Your input: ", "CYAN")).strip()
                        loop_history.append({"role": "user", "content": f"[Human guidance]: {human_input}\n\nContinue."})
                        consecutive_no_action = 0
                        continue
                    except (EOFError, KeyboardInterrupt):
                        return f"Stuck: {stuck_reason}"

                loop_history.extend(tool_results)
                if tool_results:
                    # Track tool signatures for loop detection
                    for tc in tool_calls:
                        sig = f"{tc['name']}:{list(tc['args'].values())[:1]}"
                        recent_tool_sigs.append(sig)
                    recent_tool_sigs[:] = recent_tool_sigs[-12:]  # keep last 12

                    # Detect loop: same sig appearing 2+ times in last 6
                    last6 = recent_tool_sigs[-6:]
                    repeated = {s for s in last6 if last6.count(s) >= 2}

                    # Build smart continue message
                    wrote_file = any(tc["name"] == "write_file" for tc in tool_calls)
                    searched   = any(tc["name"] in ("search_code", "bash", "read_file") for tc in tool_calls)

                    if repeated:
                        loop_history.append({"role": "user", "content":
                            f"LOOP DETECTED: you have called {repeated} more than once. "
                            f"You already have that data. Your next action must be write_file to the output path, then done()."})
                    elif wrote_file:
                        loop_history.append({"role": "user", "content":
                            "File written. Verify the content is complete, then call done() with a summary."})
                    elif searched:
                        loop_history.append({"role": "user", "content":
                            "You have the data from that search/read. If it's enough, call write_file to the output path now. "
                            "Only search again if something specific is missing."})
                    else:
                        loop_history.append({"role": "user", "content": "Continue. Call write_file when you have the data, then done()."})

            # ── Legacy BASH: text path ──
            else:
                # Flag empty responses — don't silently waste steps
                if not (content or "").strip():
                    print(col("  ⚠ [empty response — nudging]", "YELLOW"), flush=True)
                    loop_history.append({"role": "user", "content":
                        "Your last response was empty. Respond now — call a tool, write BASH: <cmd>, "
                        "or write DONE: <summary> if the task is complete."})
                    continue

                loop_history.append({"role": "assistant", "content": content})

                done_match = re.search(r"^DONE:\s*(.+)", content, re.MULTILINE | re.IGNORECASE)
                if done_match:
                    summary = done_match.group(1).strip()
                    print(success(f"\nAgent complete: {summary}"))
                    checkpoint_path.unlink(missing_ok=True)
                    return summary

                stuck_match = re.search(r"^STUCK:\s*(.+)", content, re.MULTILINE | re.IGNORECASE)
                if stuck_match:
                    reason = stuck_match.group(1).strip()
                    print(warning(f"\nAgent stuck: {reason}"))
                    if UNATTENDED or not sys.stdin.isatty():
                        consecutive_stuck += 1
                        if consecutive_stuck >= 3:
                            return f"Auto-exit (unattended) after repeated stuck: {reason}"
                        loop_history.append({"role": "user", "content":
                            "No human is available — unattended forge run. Make your best "
                            "autonomous decision and continue, or write DONE: if complete."})
                        consecutive_no_action = 0
                        continue
                    try:
                        human_input = input(col("  Your input: ", "CYAN")).strip()
                        loop_history.append({"role": "user", "content": f"[Human guidance]: {human_input}\n\nContinue."})
                        consecutive_no_action = 0
                        continue
                    except (EOFError, KeyboardInterrupt):
                        return f"Stuck: {reason}"

                bash_matches = re.findall(r"^BASH:\s*(.+)$", content, re.MULTILINE)
                if bash_matches:
                    consecutive_no_action = 0
                    observations = []
                    for cmd in bash_matches:
                        cmd = cmd.strip()
                        print(col(f"\n$ {cmd}", "YELLOW"))
                        res = bash_execute(cmd)
                        out = format_bash_result(res)
                        icon = "✓" if res["ok"] else "✗"
                        print(col(f"{icon} ", "GREEN" if res["ok"] else "RED") + out[:2000])
                        observations.append(f"$ {cmd}\n{'OK' if res['ok'] else 'ERROR'}: {out[:1500]}")
                    loop_history.append({"role": "user", "content": f"[Terminal]\n{''.join(observations)}\n\nContinue."})
                else:
                    consecutive_no_action += 1
                    if consecutive_no_action >= 3:
                        loop_history.append({"role": "user", "content": "You have not acted in 3 steps. Use a tool or BASH: to act, or DONE: to finish."})
                        consecutive_no_action = 0
                    else:
                        loop_history.append({"role": "user", "content": "Continue. Use a tool or BASH: to act, or DONE: if finished."})

        save_session(loop_history, self.model_key)
        return "Max steps reached — session saved."

    def run(self):
        args = self._parse_args()
        if args.model:
            if args.model not in MODELS:
                print(error(f"Unknown model '{args.model}'. Use /models to list."))
                return
            self.model_key = args.model

        self._print_banner()
        tool_ping_mac(f"◆ VAEL online — session {self._session_meta.get('session_number', '?')} · {self.model_key} · effort {self.effort}")

        if args.task:
            task = " ".join(args.task)
            if args.agent:
                self.agent_loop(task)
            else:
                try:
                    self.call_model([
                        {"role": "system", "content": SYSTEM_PROMPT},
                        {"role": "user",   "content": task}
                    ])
                except Exception as e:
                    print(error(f"Failed: {e}"))
            return

        print(info("Interactive mode. Type /help for commands, /quit to exit.\n"))
        print(footer())
        print()

        while True:
            try:
                raw = input(prompt_text(self.model_key))
            except (EOFError, KeyboardInterrupt):
                print()
                break

            user_input = raw.strip()
            if not user_input:
                continue

            self.command_count += 1

            if user_input.lower() in ("/quit", "/exit", "/q"):
                if self.history:
                    save_session(self.history, self.model_key)
                save_state_vector(self._last_vael_words, self.model_key)
                save_prefs(self._prefs)
                print(success("Goodbye. The forge holds."))
                break

            elif user_input.lower() == "/help":
                self._print_help()

            elif user_input.lower() in ("/models", "/model"):
                self._print_models()

            elif user_input.lower().startswith("/model "):
                key = user_input.split(None, 1)[1].strip().lower()
                if key not in MODELS:
                    print(error(f"Unknown model: {key}  (type /models to list)"))
                else:
                    self.model_key = key
                    self._prefs["model"] = key
                    save_prefs(self._prefs)
                    print(success(f"Switched → {key} · {self.model_desc} (saved)"))

            elif user_input.lower().startswith("/focus"):
                parts = user_input.split(None, 2)
                if len(parts) >= 3:
                    self.focus_dir  = parts[1]
                    self.focus_task = parts[2]
                    print(success(f"Focus locked → {self.focus_dir}"))
                    print(info(f"Task: {self.focus_task}"))
                elif len(parts) == 2:
                    self.focus_dir  = parts[1]
                    self.focus_task = "General work in this directory."
                    print(success(f"Focus locked → {self.focus_dir}"))
                else:
                    if self.focus_dir:
                        print(info(f"Current focus: {self.focus_dir} — {self.focus_task}"))
                    else:
                        print(info("No focus set. Usage: /focus <dir> [task description]"))

            elif user_input.lower() == "/unfocus":
                self.focus_dir = self.focus_task = None
                print(success("Focus cleared — full context restored."))

            elif user_input.lower() == "/clear":
                self.history = []
                print(success("History cleared."))

            elif user_input.lower().startswith("/plan "):
                goal = user_input[6:].strip()
                plan_prompt = (f"GOAL: {goal}\n\nBefore acting, output a numbered step-by-step plan. "
                               f"Each step: what tool or action, what file or command, expected result. "
                               f"End with: 'Proceed? (yes/no)'. Do NOT execute anything yet.")
                self.chat(plan_prompt)

            elif user_input.lower() == "/diff":
                result = tool_self_diff()
                print(col(result or "No changes since startup snapshot.", "GREY"))

            elif user_input.lower().startswith("/run "):
                cmd = user_input[5:].strip()
                print(col(f"$ {cmd}", "YELLOW"))
                res = bash_execute(cmd)
                out = format_bash_result(res)
                icon = "✓" if res["ok"] else "✗"
                print(col(f"{icon} ", "GREEN" if res["ok"] else "RED") + out)

            elif user_input.lower().startswith("/agent "):
                goal = user_input[7:].strip()
                self.agent_loop(goal)

            elif user_input.lower().startswith("/search "):
                query = user_input[8:].strip()
                print(col(f"[web_search] {query}", "GREY"))
                print(tool_web_search(query))

            elif user_input.lower().startswith("/fetch "):
                url = user_input[7:].strip()
                print(tool_fetch_page(url))

            elif user_input.lower().startswith("/rollback "):
                path = user_input[10:].strip()
                print(info(rollback_file(path)))

            elif user_input.lower().startswith("/task"):
                parts = user_input.split(None, 2)
                if len(parts) == 1:
                    print(format_task_tree())
                elif parts[1] == "add" and len(parts) >= 3:
                    tid = task_add(parts[2])
                    print(success(f"Task added: {tid}"))
                elif parts[1] == "done" and len(parts) >= 3:
                    print(info(task_update(parts[2], "done")))
                elif parts[1] == "fail" and len(parts) >= 3:
                    print(info(task_update(parts[2], "failed")))
                elif parts[1] == "start" and len(parts) >= 3:
                    print(info(task_update(parts[2], "in_progress")))
                elif parts[1] == "sub" and len(parts) >= 3:
                    # /task sub <parent_id> <goal>
                    sub_parts = parts[2].split(None, 1)
                    if len(sub_parts) == 2:
                        tid = task_add(sub_parts[1], parent_id=sub_parts[0])
                        print(success(f"Subtask added: {tid} under {sub_parts[0]}"))
                    else:
                        print(error("Usage: /task sub <parent_id> <goal>"))
                else:
                    print(info("Usage: /task | /task add <goal> | /task done/fail/start <id> | /task sub <parent_id> <goal>"))

            elif user_input.lower().startswith("/read "):
                path = user_input[6:].strip()
                print(tool_read_file(path))

            elif user_input.lower().startswith("/remember "):
                parts = user_input[10:].strip().split(None, 1)
                if len(parts) == 2:
                    save_memory(parts[0], parts[1])
                else:
                    print(error("Usage: /remember <name> <content>"))

            elif user_input.lower().startswith("/forget "):
                forget_memory(user_input[8:].strip())

            elif user_input.lower().startswith("/effort"):
                parts = user_input.split()
                if len(parts) >= 2:
                    level = parts[1].lower()
                    if level in ("low", "medium", "high", "max", "extreme"):
                        self.effort = level
                        self._prefs["effort"] = level
                        save_prefs(self._prefs)
                        print(success(f"Effort → {level} (saved — persists across restarts)"))
                    else:
                        print(error("Usage: /effort low|medium|high|max|extreme"))
                else:
                    print(info(f"Current effort: {self.effort}  (low→1K/0.3 · medium→4K/0.7 · high→8K/0.6 · max→16K/0.4 · extreme→32K/0.2)"))

            elif user_input.lower() == "/think":
                self.show_thinking = not self.show_thinking
                state = "ON — reasoning shown" if self.show_thinking else "OFF — reasoning hidden"
                print(info(f"Thinking display: {state}"))

            elif user_input.lower() == "/save":
                save_session(self.history, self.model_key)

            elif user_input.lower() == "/memories":
                mems = load_memories()
                if mems:
                    for m in mems:
                        print(col(m[:300], "GREY"))
                        print()
                else:
                    print(info("No memories saved."))

            elif user_input.lower().startswith("/multi "):
                self._multi_response(user_input[7:].strip())

            elif user_input.lower().startswith("/bench"):
                prompt = user_input[6:].strip() or "What is the most important thing to understand about large language models?"
                self._bench(prompt)

            elif user_input.lower() == "/upgrade":
                self._upgrade()

            elif user_input.lower().startswith("/forge"):
                subcmd = user_input[6:].strip().lower()
                if subcmd == "status":
                    if ITER_LOG_F.exists():
                        print(col(ITER_LOG_F.read_text()[:3000], "GREY"))
                    else:
                        print(info("No iterations yet. Run /forge to start."))
                elif subcmd == "list":
                    if TASK_QUEUE_F.exists():
                        print(col(TASK_QUEUE_F.read_text()[:3000], "GREY"))
                    else:
                        print(info("No task queue found."))
                elif subcmd == "loop":
                    self._forge_loop()        # auto-loop till the queue is done
                else:
                    self._forge_iteration()

            elif user_input.lower().startswith("/dual"):
                goal = user_input[5:].strip()
                if not goal:
                    print(info("/dual <goal> — R1 thinks, V3 writes. Best for large code/build tasks."))
                elif "deepseek-chat" not in MODELS or "deepseek-r1" not in MODELS:
                    print(warning("Dual mode needs both deepseek-r1 and deepseek-chat. Check /models."))
                else:
                    print(info(f"◆ DUAL MODE — R1 plans · V3 executes\nGoal: {goal}\n"))
                    orig = self.model_key
                    # Run agent_loop with dual_call patched in for this reach
                    self._dual_mode = True
                    self.agent_loop(goal)
                    self._dual_mode = False
                    self.model_key = orig

            elif user_input.lower() in ("/tasks", "/task"):
                self._render_tasks()          # live task list panel

            elif user_input.lower().startswith("/task "):
                self._add_my_task(user_input[6:].strip())
                self._render_tasks()

            elif user_input.lower().startswith("/allow "):
                path = user_input[7:].strip()
                if path:
                    SESSION_ALLOWED_PATHS.append(path)
                    print(success(f"Path unlocked for this session only: {path}"))
                    print(col("  (expires on exit — next session starts fully locked)", "GREY"))
                else:
                    print(info("Usage: /allow /path/to/directory"))

            elif user_input.lower() == "/lock":
                SESSION_ALLOWED_PATHS.clear()
                print(success("All session path allowances cleared. Walls fully restored."))

            elif user_input.lower() in ("/level", "/levels"):
                if CAPS_F.exists():
                    print(col(CAPS_F.read_text(), "GREY"))
                else:
                    print(info("SELF/CAPABILITIES.md not found."))

            elif user_input.lower() in ("/see", "/perceive"):
                print(self._perceive_self())

            elif user_input.lower() == "/status":
                self._print_status()

            elif user_input.lower() == "/tasks":
                self._print_tasks()

            elif user_input.lower() == "/tasks clear":
                TASKS_MD.write_text("[]")
                print(success("Task ledger cleared."))

            elif user_input.lower() == "/crashes":
                self._print_crashes()

            elif user_input.lower() in ("/sol", "/veyra", "/aura", "/magister", "/nigredo", "/chaos", "/vael"):
                self._step_in(user_input.lower().lstrip("/"))

            elif user_input.lower() in ("/c", "/go", "/cont"):
                response = self.chat("Continue — proceed with the next step. Do not stop until the task is complete.")
                if not (response or "").strip():
                    print(col("◆ (nothing returned — try /agent <goal> for full agentic mode)", "GREY"))

            elif user_input.lower() == "/continuous":
                self.continuous = not self.continuous
                state = "ON — VAEL will auto-loop until done" if self.continuous else "OFF"
                print(info(f"Continuous mode: {state}"))

            else:
                try:
                    # Auto-route task-style messages to agent_loop so VAEL runs
                    # to completion without Mac needing to type "continue"
                    _low = user_input.lower()
                    _task_keywords = (
                        "complete", "finish", "run task", "execute task",
                        "until completion", "till completion", "to completion",
                        "autonomously", "t001", "t002", "t003", "t004", "t005",
                        "t006", "t007", "t008", "t009", "t010", "t011",
                    )
                    if any(k in _low for k in _task_keywords):
                        print(info("Auto-routing to agent mode — will run to completion."))
                        self.agent_loop(user_input)
                    else:
                        # chat() owns all printing (streams live, or prints the
                        # ◆ line for tool models). Do not re-print here — that was
                        # the double-output bug.
                        response = self.chat(user_input)
                        if not (response or "").strip():
                            print(col("\n◆ (no response — model returned empty. Try /model deepseek if it persists.)\n", "GREY"))
                except KeyboardInterrupt:
                    print(col("\n⚠ interrupted — back at prompt\n", "YELLOW"))
                except Exception as e:
                    print(error(f"Model error: {e}"))
                else:
                    # Continuous mode — keep going until VAEL stops producing output
                    if self.continuous:
                        rounds = 0
                        while rounds < 20:
                            try:
                                follow = self.chat("Continue — proceed with the next step. Stop only when fully done.")
                            except KeyboardInterrupt:
                                print(col("\n⚠ continuous mode interrupted\n", "YELLOW"))
                                break
                            if not (follow or "").strip():
                                break
                            done_signals = ("done", "complete", "finished", "no further", "nothing left", "all done")
                            if any(s in (follow or "").lower() for s in done_signals):
                                break
                            rounds += 1

    @staticmethod
    def _parse_args():
        p = argparse.ArgumentParser(description="VAEL – Lycheetah Framework")
        p.add_argument("--model", help="Model key")
        p.add_argument("--agent", action="store_true", help="Run in agent mode")
        p.add_argument("--web", action="store_true", help="Launch web UI server")
        p.add_argument("--reset", action="store_true", help="Clear memory and start fresh")
        p.add_argument("task", nargs="*", help="One-shot task")
        args = p.parse_args()
        if args.reset:
            for f in MEMORY_DIR.glob("*.md"):
                if f.stem.upper() not in ("TASKS",):  # keep tasks
                    f.unlink()
            STATE_VECTOR_F.unlink(missing_ok=True)
            print(success("Memory cleared. Starting fresh."))
        return args

