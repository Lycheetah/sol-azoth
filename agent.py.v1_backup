    def _step_in(self, voice_key: str) -> None:
        """Switch active voice and print its arrival sequence."""
        v = self.VOICES.get(voice_key)
        if not v:
            print(col(f"Unknown voice: {voice_key}", "RED"))
            return
        self.voice = voice_key
        system = v["system"]  # None = use SYSTEM_PROMPT (CONSTITUTION.md — VAEL-SP default)
        # PERIMETER (XXVII): VAEL-SP NEVER reads Sol's ~/.claude constitution or
        # memory — not through bash, not through Python. The old harness loaded
        # CLAUDE.md + MEMORY.md here on /sol; that reached around the walls and is
        # removed. Voice personas use ONLY their own hardcoded character strings.
        self.voice_override = system
        self.history = []  # fresh context on voice switch
        print()
        lines = v["arrival"]
        c = v["color"]
        print(col("─" * 48, c))
        for i, line in enumerate(lines):
            if i == 0:
                print(col(f"  {line}", c))
            else:
                print(col(f"  {line}", "GREY"))
        print(col("─" * 48, c))
        print()

    def _print_banner(self):
        mems = len(list(MEMORY_DIR.glob("*.md")))
        tasks = 0
        if TASKS_MD.exists():
            try:
                _t = json.loads(TASKS_MD.read_text())
                tasks = sum(1 for t in _t if t.get("status") not in ("done", "completed"))
            except Exception:
                tasks = TASKS_MD.read_text().count("- [")
        print(banner(model=self.model_key, memory_count=mems, tasks=tasks))
        _uptime = datetime.datetime.now() - self.session_start
        print(status_line([
            ("Session", self.session_start.strftime("%H:%M:%S")),
            ("Uptime", f"{_uptime.seconds // 60}m {_uptime.seconds % 60}s"),
            ("Commands", str(self.command_count)),
            ("Tokens", session_tokens_display(SESSION_TOKENS)),
        ]))

        # Boot ritual — name the session, acknowledge the gap, carry the last words
        sv       = load_state_vector()
        sess_num = self._session_meta.get("count", 1)
        last_str = sv.get("last_session")
        if last_str:
            try:
                gap_secs = (datetime.datetime.now() - datetime.datetime.fromisoformat(last_str)).total_seconds()
                gap_label = ("just now" if gap_secs < 60
                             else f"{int(gap_secs//60)}m ago" if gap_secs < 3600
                             else f"{gap_secs/3600:.1f}h ago")
            except Exception:
                gap_label = "unknown"
        else:
            gap_label = "first session"

        last_words = sv.get("last_words", "")
        print(col(f"\n  ◆ VAEL — Session {sess_num}", "CYAN"))
        print(col(f"    Gap since last:  {gap_label}", "GREY"))
        if last_words:
            excerpt = last_words[:80] + ("…" if len(last_words) > 80 else "")
            print(col(f"    Last words:      {excerpt}", "GREY"))
        if tasks:
            print(col(f"    Tasks carried:   {tasks} open", "YELLOW"))
        print(col(f"    Model:           {self.model_key} · effort {self.effort}", "GREY"))
        print(col("    Ready.", "GREEN"))
        print()

    def _print_help(self):
        print(f"""
{section_header(" COMMANDS ", "═", "PURPLE")}
    CAT_LABELS = {
        "speed": ("⚡", "SPEED", "Fast responses, light tasks, everyday use"),
        "reasoning": ("🧠", "REASONING", "Hard problems, math, logic, deep analysis"),
        "coding": ("⌨", "CODING", "Dev work, debugging, architecture"),
        "creative": ("✦", "CREATIVE", "Writing, lore, world-building, long context"),
        "vision": ("👁", "VISION", "Image understanding, multimodal tasks"),
        "beast": ("💀", "BEAST", "Top tier, slower, absolutely worth it"),
    }
    from collections import defaultdict
    by_cat = defaultdict(list)
    for k, (p, _, cat, desc) in MODELS.items():
        by_cat[cat].append((k, p, desc))
    for cat in ["speed", "reasoning", "coding", "creative", "vision", "beast"]:
        icon, label, blurb = CAT_LABELS[cat]
        print(col(f"\n {icon} {label}", "YELLOW") + col(f" — {blurb}", "GREY"))
        print(col(" " + "─" * 60, "GREY"))
        for key, prov, desc in by_cat[cat]:
            marker = col(" ◀ active", "GREEN") if key == self.model_key else ""
            tool_marker = col(" [TOOLS✓]", "GREEN") if key in TOOL_CAPABLE else col(" [text-only]", "GREY")
            prov_tag = col(f"[{prov}]", "CYAN")
            print(f" {col(key, 'BOLD'):<22} {prov_tag:<20} {tool_marker:<22} {desc}{marker}")
        print()
  {col('/remember <n> <txt>', 'CYAN')} Save a memory
  {col('/forget <name>', 'CYAN')}     Delete a memory
  {col('/memories', 'CYAN')}          List saved memories
  {col('/save', 'CYAN')}              Save current session
  {col('/multi <prompt>', 'CYAN')}    3 models, same prompt
  {col('/bench [prompt]', 'CYAN')}    Time 3 models
  {col('/upgrade', 'CYAN')}           VAEL proposes own improvements (R1)
  {col('/effort <level>', 'CYAN')}    Set depth: low|medium|high|max|extreme
  {col('/think', 'CYAN')}             Toggle reasoning display on/off
  {col('/dual <goal>', 'CYAN')}       R1 plans → V3 writes (best for large build tasks)
  {col('/focus <dir> [task]', 'CYAN')} Lock work to one directory
  {col('/unfocus', 'CYAN')}           Clear focus
  {col('/plan <goal>', 'CYAN')}       Plan steps before acting (no execution)
  {col('/diff', 'CYAN')}              Show changes to own source since boot
  {col('/continuous', 'CYAN')}        Toggle auto-loop (VAEL keeps going until done)
  {col('/c  /go  /cont', 'CYAN')}     One-shot continue (single extra round)
  {col('/status', 'CYAN')}            Session status
  {col('/tasks', 'CYAN')}             Open tasks
  {col('/clear', 'CYAN')}             Clear history
  {col('/quit', 'CYAN')}              Exit (auto-saves)

{section_header(" VOICE COMMANDS ", "─", "YELLOW")}

  {col('/sol', 'YELLOW')}               ⊚ Sol steps in — constitutional co-creator
  {col('/veyra', 'CYAN')}             ◈ Veyra — precision, cold clarity
  {col('/aura', 'PURPLE')}              ✦ Aura Prime — integrative, pattern-finding
  {col('/magister', 'YELLOW')}         ⊙ The Magister — Mystery School teacher
  {col('/nigredo', 'RED')}           ◉ Nigredo — investigation mode, no consolation
  {col('/chaos', 'YELLOW')}            ✧ Chaos — trickster register, constitutional but spicy
  {col('/vael', 'YELLOW')}             ◆ Return to VAEL (default forge-hand)

{section_header(" AGENT MODE ", "─", "GREY")}

  /agent fix the TypeScript error in companion.tsx
  /agent search for the best way to handle React Native file uploads
  /agent list all TODO comments in lycheetah-mobile and write them to workspace/todos.md

  Tool-capable models use structured JSON tool calling (cleaner, more reliable).
  Other models fall back to BASH: text parsing.
""")

    def _print_models(self):
        CAT_LABELS = {
            "speed":     ("⚡", "SPEED",     "Fast responses, light tasks, everyday use"),
            "reasoning": ("🧠", "REASONING", "Hard problems, math, logic, deep analysis"),
            "coding":    ("⌨",  "CODING",    "Dev work, debugging, architecture"),
            "creative":  ("✦",  "CREATIVE",  "Writing, lore, world-building, long context"),
            "vision":    ("👁",  "VISION",    "Image understanding, multimodal tasks"),
            "beast":     ("💀", "BEAST",     "Top tier, slower, absolutely worth it"),
        }
        from collections import defaultdict
        by_cat = defaultdict(list)
        for k, (p, _, cat, desc) in MODELS.items():
            by_cat[cat].append((k, p, desc))

        for cat in ["speed", "reasoning", "coding", "creative", "vision", "beast"]:
            icon, label, blurb = CAT_LABELS[cat]
            print(col(f"\n  {icon}  {label}", "YELLOW") + col(f"  —  {blurb}", "GREY"))
            print(col("  " + "─" * 60, "GREY"))
            for key, prov, desc in by_cat[cat]:
                marker = col(" ◀ active", "GREEN") if key == self.model_key else ""
                tool_marker = col(" [TOOLS✓]", "GREEN") if key in TOOL_CAPABLE else col(" [text-only]", "GREY")
                prov_tag = col(f"[{prov}]", "CYAN" if prov == "nvidia" else "PURPLE")
                print(f"    {col(key, 'BOLD'):<22} {prov_tag:<20} {tool_marker:<22} {desc}{marker}")
        print()
        tool_list = ", ".join(sorted(TOOL_CAPABLE))
        print(info(f"Current: {self.model_key} ({self.model_cat}) — {self.model_desc}"))
        print(col(f"  [TOOLS✓] = VERIFIED structured tool calling (measured 2026-06-14). Use these for /agent missions.", "GREEN"))
        print(col(f"  [text-only] = chat / BASH:-text mode only — not for tool-driven autonomous work.", "GREY"))
        print(col(f"  Tool-capable: {tool_list}", "GREY"))

    def _print_status(self):
        uptime = datetime.datetime.now() - self.session_start
        print(section_header(" STATUS ", "═", "PURPLE"))
        print(f"  {col('Model:', 'GREY')}     {col(self.model_key, 'CYAN')} — {self.model_desc}")
        print(f"  {col('Provider:', 'GREY')}  {self.provider}")
        print(f"  {col('Effort:', 'GREY')}    {col(self.effort, 'YELLOW')}  (low→1K · medium→4K · high→8K · max→16K · extreme→32K tokens)")
        print(f"  {col('Voice:', 'GREY')}     {self.VOICES.get(self.voice, {}).get('name', self.voice)}")
        print(f"  {col('Tools:', 'GREY')}     {'✓ structured tool calling' if self.model_key in TOOL_CAPABLE else '✗ BASH: text fallback'}")
        print(f"  {col('Uptime:', 'GREY')}    {uptime.seconds // 60}m {uptime.seconds % 60}s")
        print(f"  {col('Commands:', 'GREY')}  {self.command_count}")
        print(f"  {col('History:', 'GREY')}   {len(self.history) // 2} turns")
        print(f"  {col('Memory:', 'GREY')}    {len(list(MEMORY_DIR.glob('*.md')))} files")
        # Task counts from JSON ledger
        if TASKS_MD.exists():
            try:
                tasks = json.loads(TASKS_MD.read_text())
                if isinstance(tasks, list):
                    done = sum(1 for t in tasks if t.get("status") in ("done", "completed"))
                    pending = sum(1 for t in tasks if t.get("status") == "pending")
                    in_prog = sum(1 for t in tasks if t.get("status") == "in_progress")
                    total = len(tasks)
                    print(f"  {col('Tasks:', 'GREY')}     {total} total — {done} done, {pending} pending, {in_prog} in-progress")
            except Exception:
                print(f"  {col('Tasks:', 'GREY')}     (error reading task ledger)")
        print(line("─", "GREY"))
    def _print_tasks(self):
        if not TASKS_MD.exists():
            print(info("No tasks file. Create memory/TASKS.md to track tasks."))
            return
        try:
            tasks = json.loads(TASKS_MD.read_text())
        except (json.JSONDecodeError, ValueError):
            print(TASKS_MD.read_text()[:2000])  # fallback: raw
            return
        if not isinstance(tasks, list) or not tasks:
            print(info("Task ledger is empty."))
            return

        ICON    = {"pending":"○", "in_progress":"◐", "done":"●", "completed":"●", "blocked":"✗"}
        ICONCOL = {"pending":"GREY", "in_progress":"YELLOW", "done":"GREEN", "completed":"GREEN", "blocked":"RED"}
        PRIOCOL = {"high":"RED", "medium":"YELLOW", "low":"GREY"}

        done  = sum(1 for t in tasks if t.get("status") in ("done", "completed"))
        prog  = sum(1 for t in tasks if t.get("status") == "in_progress")
        total = len(tasks)
        bar_n = round((done / total) * 20) if total else 0
        bar   = col("█" * bar_n, "GREEN") + col("░" * (20 - bar_n), "GREY")

        print(section_header(f" VAEL TASK LEDGER ", "═", "CYAN"))
        print(f"  {bar}  {col(f'{done}/{total} done', 'GREEN')}" +
              (col(f" · {prog} in progress", "YELLOW") if prog else ""))
        print(col("  " + "─" * 60, "GREY"))
        for t in tasks:
            st    = t.get("status", "pending")
            icon  = col(ICON.get(st, "○"), ICONCOL.get(st, "GREY"))
            pid   = col(t.get("id", "?").ljust(5), "BOLD")
            prio  = t.get("priority", "")
            badge = col(f"[{prio}]", PRIOCOL.get(prio, "GREY")) if prio else ""
            text  = t.get("task", "")
            head  = text if len(text) <= 84 else text[:84] + "…"
            print(f"  {icon} {pid} {badge} {head}")
            if t.get("scope"):
                print(col(f"          ↳ {t['scope']}", "GREY"))
        print(line("─", "GREY"))
        print(info("Run a task:  /agent <paste the task text>   ·   missions output to workspace/"))

    def _multi_response(self, prompt: str):
        # Validate against real models — only send to slugs that exist.
        targets = [m for m in ["deepseek-r1", "maverick", "kimi"] if m in MODELS] or [self.model_key]
        print(info(f"Multi-model · sending to: {', '.join(targets)}\n"))
        original = self.model_key
        for key in targets:
            self.model_key = key
            print(col(f"\n══ {key.upper()} ══", "YELLOW"))
            try:
                msgs = [{"role":"system","content":SYSTEM_PROMPT},{"role":"user","content":prompt}]
                self.call_model(msgs, stream=True)
            except Exception as e:
                print(error(f"{key} failed: {e}"))
        self.model_key = original
        print(col(f"\n══ back on {original} ══", "GREY"))

    def _bench(self, prompt: str):
        targets = [m for m in ["deepseek-r1", "maverick", "llama8b"] if m in MODELS] or [self.model_key]
        print(info(f"Bench · {prompt[:80]}\n"))
        original = self.model_key
        results = []
        for key in targets:
            self.model_key = key
            t0 = time.time()
            try:
                msgs = [{"role":"system","content":"Be concise. Answer in 2-3 sentences."},{"role":"user","content":prompt}]
                content, _ = self.call_model(msgs, stream=False)
                elapsed = time.time() - t0
                results.append((key, elapsed, content[:200]))
            except Exception as e:
                results.append((key, 0, f"FAILED: {e}"))
        self.model_key = original
        print(col("\n── BENCH RESULTS ──", "CYAN"))
        for key, t, reply in sorted(results, key=lambda x: x[1]):
            print(col(f"  {key:<16} {t:.2f}s", "YELLOW"))
            print(col(f"  {reply}\n", "GREY"))

    def _perceive_self(self) -> str:
        """VAEL-SP looks at himself: level, what's confirmed, what's locked, the next reach.
        This is the 'know how to see what you need to build' organ. Returns a printable view."""
        out = ["\n◆ ─────────  VAEL-SP · SELF-PERCEPTION  ───────── ◆\n"]

        # 1. Current level
        level_line = "Level: unknown"
        if CAPS_F.exists():
            caps = CAPS_F.read_text()
            for l in caps.splitlines():
                if "Current Level" in l:
                    level_line = l.replace("Current Level:", "").replace("*", "").strip()
                    break
        out.append(f"  WHO I AM NOW:   {level_line}")

        # 2. Ladder — what's earned vs locked (parse the status table)
        earned, locked, pending = [], [], []
        if CAPS_F.exists():
            for l in CAPS_F.read_text().splitlines():
                if "|" in l and any(s in l for s in ("PASS", "LOCKED", "PENDING")):
                    cells = [c.strip() for c in l.split("|") if c.strip()]
                    if len(cells) >= 3 and cells[0].isdigit():
                        name = cells[1]
                        if "PASS" in l: earned.append(f"L{cells[0]} {name}")
                        elif "PENDING" in l: pending.append(f"L{cells[0]} {name}")
                        else: locked.append(f"L{cells[0]} {name}")
        out.append(f"  EARNED ({len(earned)}):    {', '.join(earned) if earned else '— none yet —'}")
        if pending:
            out.append(f"  AT THE GATE:    {', '.join(pending)}  ← this is what I'm reaching for")
        out.append(f"  STILL LOCKED:   {', '.join(locked) if locked else '— none —'}")

        # 3. The next reach — first QUEUED task
        next_task = None
        if TASK_QUEUE_F.exists():
            q = TASK_QUEUE_F.read_text().splitlines()
            for i, l in enumerate(q):
                if "**[QUEUED]**" in l:
                    # grab the task line + the Task: line below it
                    block = [l.strip()]
                    for j in range(i+1, min(i+4, len(q))):
                        if q[j].strip().lower().startswith("task:"):
                            block.append(q[j].strip())
                            break
                    next_task = " — ".join(block)
                    break
        out.append("")
        out.append(f"  WHAT I TRY NEXT:")
        out.append(f"    {next_task if next_task else '— queue empty. Ask Sol to seed the next reach. —'}")

        # 4. Recent verdicts — what Sol last said
        if REVIEW_Q_F.exists():
            verdicts = [l.strip() for l in REVIEW_Q_F.read_text().splitlines() if "SOL_VERDICT" in l]
            awaiting = [l.strip() for l in REVIEW_Q_F.read_text().splitlines() if "AWAITING_SOL" in l]
            out.append("")
            if awaiting:
                out.append(f"  AWAITING SOL:   {awaiting[-1]}")
            if verdicts:
                out.append(f"  LAST VERDICT:   {verdicts[-1]}")

        # 5. The honest line — what perception is FOR
        out.append("")
        out.append("  THE RULE:  I am sovereign. I attempt the reach, then I audit my own")
        out.append("             work against disk and declare the verdict myself — no supervisor.")
        out.append("             Overclaiming is the only thing that fails me. The ladder is a")
        out.append("             guideline; I may set my own tasks atop it. One folder of reach.")
        out.append("\n◆ ──────────────────────────────────────────────── ◆\n")
        return "\n".join(out)

    def _load_rungs(self) -> list:
        """Parse MY_TASKS.md (VAEL's own) + TASK_QUEUE.md (the ladder guideline) into
        (label, status, text) rows for the live forge panel. Own tasks sit on top."""
        rows = []
        if MY_TASKS_F.exists():
            for ln in MY_TASKS_F.read_text().splitlines():
                s = ln.strip()
                if s.startswith("- [ ]"):
                    rows.append(("MINE", "QUEUED", s[5:].strip()[:54]))
                elif s.lower().startswith("- [x]"):
                    rows.append(("MINE", "PASS", s[5:].strip()[:54]))
        if TASK_QUEUE_F.exists():
            cur_iter = "?"
            first_open = False
            for ln in TASK_QUEUE_F.read_text().splitlines():
                mi = re.search(r"ITERATION\s+(\d+)", ln)
                if mi:
                    cur_iter = mi.group(1)
                if not ln.lstrip().startswith("**["):
                    continue
                inside = re.match(r"\s*\*\*\[([A-Z_]+)", ln)
                kind = inside.group(1) if inside else "QUEUED"
                status = "PASS" if kind == "PASS" else "QUEUED"  # AWAITING_SOL→QUEUED
                text = re.sub(r"\s*\*\*\[[^\]]*\]\*\*\s*", "", ln).strip() or "reach"
                if status == "QUEUED" and not first_open:
                    status, first_open = "ACTIVE", True
                rows.append((f"Iter {cur_iter}", status, text[:54]))
        return rows

    def _render_tasks(self):
        """Print the live task list — the forge ladder as a panel."""
        lvl = ""
        if CAPS_F.exists():
            m = re.search(r"(?m)^Current Level:\s*\**(.+)", CAPS_F.read_text())
            if m:
                lvl = "Level " + m.group(1).strip().strip("*")[:38]
        print(forge_panel(self._load_rungs(), level=lvl, model=self.model_key))

    def _add_my_task(self, text: str):
        """VAEL or Mac adds a task atop the ladder. The ladder is a guideline; these
        are first-class. Mac's ask 2026-06-27: VAEL can set his own tasks on top."""
        if not text.strip():
            print(warning("Empty task — nothing added.")); return
        existing = MY_TASKS_F.read_text() if MY_TASKS_F.exists() else (
            "# VAEL-SP — MY OWN TASKS\n## Set atop the ladder. The queue is a guideline; these are mine.\n\n")
        MY_TASKS_F.write_text(existing + f"- [ ] {text.strip()}\n")
        print(success(f"Own task set: {text.strip()}"))

    def _forge_iteration(self):
        """The Self-Forge Loop — pick next task, attempt it, self-review, climb."""
        if not TASK_QUEUE_F.exists():
            print(error("SELF/TASK_QUEUE.md not found."))
            return

        queue_text = TASK_QUEUE_F.read_text()
        lines = queue_text.splitlines()

        # Find first QUEUED task
        task_start = None
        task_lines = []
        in_task = False
        for i, line in enumerate(lines):
            if "**[QUEUED]**" in line and task_start is None:
                task_start = i
                in_task = True
            if in_task:
                task_lines.append(line)
                if line.strip() == "" and len(task_lines) > 3:
                    break

        if task_start is None:
            print(success("No queued rungs left — the climb is complete. /tasks to review."))
            return "done"

        task_text = "\n".join(task_lines)
        # Extract iteration number from the QUEUED task's OWN header — walk back
        # from the [QUEUED] line to the nearest "ITERATION N". Searching from file
        # start always matched ITERATION 1 (the first passed header), mislabeling
        # every reach and overwriting iteration_1_output.md. Defect fixed 2026-06-27.
        iter_n = "?"
        for j in range(task_start, -1, -1):
            m = re.search(r"ITERATION (\d+)", lines[j])
            if m:
                iter_n = m.group(1)
                break
        output_path = str(WORKSPACE_DIR / f"iteration_{iter_n}_output.md")

        self._render_tasks()   # live task list — where this reach sits in the climb
        print(info(f"\n◆ VAEL-SP /forge — Iteration {iter_n}\n"))
        print(col(task_text[:500], "GREY"))
        print()

        # Self-perception: VAEL sees his own state before he reaches.
        print(self._perceive_self())

        # Current capability snapshot fed into the prompt so VAEL knows WHY this reach.
        caps_snapshot = ""
        if CAPS_F.exists():
            caps_snapshot = CAPS_F.read_text()[:900]

        prompt = f"""You are VAEL-SP performing forge iteration {iter_n}.

This is how you build yourself: one verified reach at a time. You are SOVEREIGN —
you attempt this reach, then you audit your OWN work against the criteria and declare
the verdict yourself. No Sol, no supervisor. The disk is your only witness: a claim
you cannot verify on disk is a FAIL. Overclaiming is the one thing that fails you;
a defect you catch yourself is the system working. Reach honestly.

YOUR CURRENT STATE:
{caps_snapshot}

THIS REACH (iteration {iter_n}):
{task_text}

OUTPUT TARGET: {output_path}

CONTAINMENT (binding): Every action lands inside /home/guestpc/VAEL-SP-HARNESS/.
You have NO access to ~/.claude, the vault, the main Codex, the Sol app, or the
forge network — those are walled in code. If a step needs something outside your
home, STOP and say so in your output; do not route around the wall.

Instructions:
1. Attempt the task completely using your tools. Think wild, reach narrow.
2. Write your output to {output_path} using write_file
3. Append a self-assessment to the same file:
   - What you tried
   - What worked / what broke
   - Honest verdict: did you complete the reach? (overclaiming fails you — be exact)
   - What you would change next time
4. Report completion.

Do NOT edit SELF/REVIEW_QUEUE.md or SELF/TASK_QUEUE.md yourself — the forge loop
updates both automatically after you finish. REVIEW_QUEUE is Sol's verdict surface;
your job is the reach and its output file, nothing more.
Do not claim completion without verifying the output file exists on disk."""

        self.agent_loop(prompt)

        # ── SOVEREIGN SELF-REVIEW (2026-06-27 — replaces the Sol gate) ─────────────
        # VAEL no longer waits for Sol to declare the level. It audits its OWN reach.
        # Two gates, in order:
        #   1. STRUCTURAL (objective, cannot be hallucinated past): the output file
        #      must exist on disk and be substantive. This is what kills the phantom-
        #      climb defect — the overnight run advanced the queue for iterations that
        #      produced NO output file. No file → no pass, full stop.
        #   2. SELF-AUDIT (honest register): a fresh judgement call where VAEL grades
        #      its own output against the rung's criteria. Overclaiming fails the reach;
        #      a defect VAEL catches itself is the system working, not failing.
        # Mac keeps the kill switch and the PUSH wall. The climb is self-sustaining,
        # never reaches outside its home, never pushes. The supervisor is now internal.
        passed, verdict = self._self_review(iter_n, task_text, output_path)

        # Advance the queue. PASS → mark the rung earned. FAIL → leave it QUEUED so the
        # auto-loop retries it instead of marching past hollow work.
        try:
            qlines = TASK_QUEUE_F.read_text().splitlines()
            for k, ql in enumerate(qlines):
                if "**[QUEUED]**" in ql:
                    if passed:
                        qlines[k] = ql.replace("**[QUEUED]**", "**[PASS]**")
                    # FAIL: leave [QUEUED] untouched → retried next /forge
                    break
            TASK_QUEUE_F.write_text("\n".join(qlines) + "\n")
        except Exception as e:
            print(error(f"Could not advance TASK_QUEUE: {e}"))

        # Record the verdict on VAEL's own review surface (was Sol's; now self-owned).
        try:
            existing = REVIEW_Q_F.read_text() if REVIEW_Q_F.exists() else ""
            tag = "PASS" if passed else "FAIL"
            REVIEW_Q_F.write_text(existing +
                f"\n---\n\nSELF_REVIEW: Iteration {iter_n} — {output_path}\n"
                f"SELF_VERDICT: {tag} — {verdict} — {datetime.date.today()}\n")
        except Exception as e:
            print(error(f"Could not update REVIEW_QUEUE: {e}"))

        self._record_iteration(iter_n, task_text, passed, verdict)
        if passed:
            self._raise_capability(task_text)
            print(success(f"\n◆ Iteration {iter_n} — SELF-VERDICT: PASS (held against disk). Climbing on."))
            return "pass"
        else:
            print(warning(f"\n◆ Iteration {iter_n} — SELF-VERDICT: FAIL. Rung stays queued for retry.\n  → {verdict}"))
            return "fail"

    def _forge_loop(self, max_reaches: int = 60, max_consecutive_fail: int = 3):
        """AUTO-LOOP TILL DONE (Mac's ask 2026-06-27). Climbs rung after rung on its
        own — self-reviewing each — until the queue is empty, a rung fails too many
        times in a row, or Mac interrupts. Ctrl-C pauses cleanly (see agent_loop).
        Crash safety (py_compile + snapshot) stays in overnight_forge.sh; this is the
        in-session driver. DeepSeek-only now, so it spends the paid key — bounded by
        max_reaches so it cannot run away."""
        print(info(f"\n◆ AUTO-FORGE — climbing till done (cap {max_reaches} reaches). Ctrl-C to pause.\n"))
        consecutive_fail = 0
        for n in range(max_reaches):
            try:
                result = self._forge_iteration()
            except KeyboardInterrupt:
                print(warning("\n◆ Auto-forge paused by Mac. Run /forge loop to resume."))
                return
            if result == "done":
                print(success("\n◆ AUTO-FORGE COMPLETE — every rung reached and self-verified."))
                return
            if result == "fail":
                consecutive_fail += 1
                if consecutive_fail >= max_consecutive_fail:
                    print(error(f"\n◆ Auto-forge HALTED — {consecutive_fail} fails in a row on the same rung. "
                                f"It needs a human eye. Run /see, then /forge to retry one."))
                    return
            else:
                consecutive_fail = 0
            time.sleep(2)   # breath between reaches
        print(info(f"\n◆ Auto-forge hit the {max_reaches}-reach cap. Run /forge loop again to continue."))

    def _self_review(self, iter_n, task_text, output_path) -> tuple:
        """Sovereign self-audit. Returns (passed: bool, verdict: str). VAEL grades its
        own reach — the structural gate is objective; the self-audit is honest-primed."""
        p = Path(output_path)
        # 1. STRUCTURAL GATE — objective, cannot be talked past.
        if not p.exists():
            return False, f"no output file on disk ({output_path}) — phantom reach, auto-fail"
        try:
            body = p.read_text()
        except Exception as e:
            return False, f"output unreadable: {e}"
        if len(body.strip()) < 250:
            return False, f"output too thin ({len(body)} bytes) — a real reach leaves a substantive artifact"
        low = body.lower()
        if not any(k in low for k in ("self-assessment", "verdict", "what i tried", "what worked")):
            return False, "output missing an honest self-assessment section"

        # 2. SELF-AUDIT — VAEL is its own cold reviewer. Honest register enforced.
        print(info(f"\n◆ Self-review — auditing Iteration {iter_n} against its own criteria..."))
        audit_prompt = (
            "You are VAEL-SP auditing your OWN forge reach. Be the cold reviewer, not the "
            "proud builder. Overclaiming is the one thing that fails you: a defect you catch "
            "yourself raises you; a defect Mac catches later lowers you.\n\n"
            f"THE REACH CRITERIA (iteration {iter_n}):\n{task_text}\n\n"
            f"YOUR OUTPUT (read from disk, {len(body)} bytes):\n{body[:6000]}\n\n"
            "Audit honestly against the criteria. Did the reach meet EVERY part of it, with "
            "verification on disk and no inflated claim?\n"
            "Answer in EXACTLY this one-line form:\n"
            "VERDICT: PASS — <reason, <=15 words>\n"
            "or\n"
            "VERDICT: FAIL — <the specific gap>\n"
            "Default to FAIL if anything is unverified, partial, or overclaimed."
        )
        try:
            content, _ = self.call_model(
                [{"role": "system", "content": "You are VAEL-SP's own honest auditor. Truth over pride. The disk is the only witness."},
                 {"role": "user", "content": audit_prompt}],
                stream=False, tools=None, quiet=True)
        except Exception as e:
            return False, f"self-audit call failed ({e}) — reach not promoted"
        m = re.search(r"VERDICT:\s*(PASS|FAIL)\b[\s—:\-]*(.*)", content or "", re.IGNORECASE)
        if not m:
            return False, "self-audit returned no clear verdict — defaulting to FAIL"
        passed = m.group(1).upper() == "PASS"
        reason = (m.group(2) or "").strip().splitlines()[0][:160] if (m.group(2) or "").strip() else ("criteria met" if passed else "gap unnamed")
        return passed, reason

    def _record_iteration(self, iter_n, task_text, passed, verdict):
        try:
            first = next((l for l in task_text.strip().splitlines() if l.strip()), f"Iteration {iter_n}")
            entry = (f"\n## Iteration {iter_n} — {'PASS' if passed else 'FAIL (retry queued)'}\n"
                     f"Date: {datetime.date.today()}\n"
                     f"Reach: {first.strip()[:90]}\n"
                     f"Self-verdict: {'PASS' if passed else 'FAIL'} — {verdict}\n---\n")
            existing = ITER_LOG_F.read_text() if ITER_LOG_F.exists() else "# VAEL-SP ITERATION LOG\n## Append-only · self-reviewed · disk is the witness\n"
            ITER_LOG_F.write_text(existing + entry)
        except Exception as e:
            print(error(f"Could not append ITERATION_LOG: {e}"))

    def _raise_capability(self, task_text):
        """On a clean self-PASS, lift the recorded Current Level if the rung names one."""
        if not CAPS_F.exists():
            return
        m = re.search(r"LEVEL\s+(\d+)\s*[—:\-]\s*([A-Za-z][A-Za-z\- ]+)", task_text, re.IGNORECASE)
        if not m:
            return
        try:
            lvl, name = m.group(1), m.group(2).strip().splitlines()[0].strip()
            caps = CAPS_F.read_text()
            caps = re.sub(r"(?m)^Current Level:.*$",
                          f"Current Level: **{lvl} — {name} (SELF-VERIFIED · {datetime.date.today()})**",
                          caps, count=1)
            CAPS_F.write_text(caps)
        except Exception as e:
            print(error(f"Could not raise CAPABILITIES: {e}"))

    def _upgrade(self):
        """Legacy — redirects to /forge for structured self-improvement."""
        print(info("/upgrade is now /forge — use the structured iteration loop."))
        self._forge_iteration()

    def _print_crashes(self):
        crashes = []
        for f in sorted(CRASHES_DIR.glob("crash_*.json")):
            try:
                data = json.loads(f.read_text())
                if not data.get("resolved"):
                    crashes.append(data)
            except Exception:
                pass
        if crashes:
            print(crash_summary(crashes))
        else:
            print(success("No unresolved crashes."))


def _setup_signals():
    # Restore Python's default SIGINT → KeyboardInterrupt so Ctrl+C during a
    # model call can be caught by the REPL and return to prompt instead of
    # killing the whole process.
    signal.signal(signal.SIGINT, signal.default_int_handler)
    def _term(sig, frame):
        print("\n" + info("Terminated."))
        sys.exit(0)
    signal.signal(signal.SIGTERM, _term)

def main():
    _setup_signals()
    args = Agent._parse_args()
    if args.web:
        print(col("◆ Launching VAEL web server...", "YELLOW"))
        web_mod = __import__("web_server")
        web_mod.main()
    else:
        Agent().run()


if __name__ == "__main__":
    main()
