# ── Slug generation ──
def _make_slug(model_id: str) -> str:
    """Generate a clean short slug from a full model ID.
    e.g. 'meta/llama-4-maverick-17b-128e-instruct' -> 'maverick'
         'deepseek-ai/deepseek-v4-pro' -> 'deepseek-v4-pro'
         'nvidia/nemotron-mini-4b-instruct' -> 'nemotron-mini'
    """
    # Strip provider prefix
    parts = model_id.split("/", 1)
    name = parts[1] if len(parts) > 1 else parts[0]
    # Known short names
    SHORT_NAMES = {
        "meta/llama-4-maverick-17b-128e-instruct": "maverick",
        "meta/llama-3.1-8b-instruct": "llama8b",
        "meta/llama-3.2-1b-instruct": "llama1b",
        "meta/llama-3.2-3b-instruct": "llama3b",
        "meta/llama-3.2-11b-vision-instruct": "llama11bv",
        "meta/llama-3.3-70b-instruct": "llama33-70b",
        "meta/llama-3.1-70b-instruct": "llama70b",
        "nvidia/nvidia-nemotron-nano-9b-v2": "nemotron-nano",
        "nvidia/nemotron-mini-4b-instruct": "nemotron-mini",
        "nvidia/llama-3.3-nemotron-super-49b-v1.5": "super49b",
        "nvidia/nemotron-3-super-120b-a12b": "super120b",
        "google/gemma-2-2b-it": "gemma2",
        "google/gemma-3n-e2b-it": "gemma3n",
        "google/gemma-3n-e4b-it": "gemma3n4b",
        "mistralai/ministral-14b-instruct-2512": "ministral",
        "mistralai/mistral-nemotron": "mistral-nemotron",
        "mistralai/mistral-large-3-675b-instruct-2512": "mistral-large",
        "microsoft/phi-4-mini-instruct": "phi4-mini",
        "openai/gpt-oss-20b": "gptoss",
        "moonshotai/kimi-k2.6": "kimi",
        "deepseek-ai/deepseek-v4-pro": "deepseek-v4-pro",
        "deepseek-ai/deepseek-r1": "deepseek-r1",
        "minimaxai/minimax-m2.7": "minimax-m2",
        "minimaxai/minimax-m3": "minimax-m3",
        "stepfun-ai/step-3.7-flash": "step37",
        "bytedance/seed-oss-36b-instruct": "seed-oss",
        "sarvamai/sarvam-m": "sarvam",
        "qwen/qwen3.5-397b-a17b": "qwen",
    }
    if model_id in SHORT_NAMES:
        return SHORT_NAMES[model_id]
    # Fallback: lowercase, replace non-alnum with dash, collapse dashes
    import re
    slug = re.sub(r'[^a-z0-9-]', '', name.lower().replace(' ', '-').replace('_', '-'))
    slug = re.sub(r'-+', '-', slug).strip('-')
    return slug[:20] if slug else "unknown"


def _load_models_from_benchmark() -> dict[str, tuple[str, str, str, str]]:
    """Load models from benchmark file. Returns a dict keyed by model slug.
    Format: {slug: (provider, full_id, category, description)}
    Only includes models with no errors.
    """
    if not BENCHMARK_PATH.exists():
        warning(f"Benchmark file not found at {BENCHMARK_PATH}")
        return {}

    try:
        data = json.loads(BENCHMARK_PATH.read_text())
    except Exception as e:
        error(f"Failed to parse benchmark file: {e}")
        return {}

    models = {}

    for entry in data:
        model_id = entry.get("model", "")
        chat_tps = entry.get("chat_tps", 0.0)
        tool_ms = entry.get("tool_ms")
        tool_ok = entry.get("tool_ok")
        err = entry.get("error")

        # Skip models with errors
        if err:
            continue

        # Determine provider from model_id prefix
        provider = model_id.split("/")[0] if "/" in model_id else "nvidia"

        # Generate slug
        slug = _make_slug(model_id)

        # Categorize
        if chat_tps >= 40.0:
            cat = "speed"
        elif chat_tps >= 15.0:
            cat = "speed"
        elif chat_tps >= 8.0:
            cat = "reasoning"
        elif chat_tps >= 2.0:
            cat = "coding"
        elif chat_tps >= 0.5:
            cat = "beast"
        else:
            cat = "beast"  # slow but powerful

        # Build description
        parts = [model_id]
        parts.append(f"{chat_tps:.1f} tps")
        if tool_ok is True:
            parts.append("[TOOL]")
        elif tool_ok is False:
            parts.append("[text-only]")
        if tool_ms:
            parts.append(f"~{tool_ms}ms")
        desc = " · ".join(parts)

        models[slug] = (provider, model_id, cat, desc)

    # Fallback defaults if benchmark is empty
    if not models:
        models = {
            "deepseek-v4-pro": ("nvidia", "deepseek-ai/deepseek-v4-pro", "speed", "DeepSeek V4 Pro · FREE · flagship · [TOOL]"),
            "maverick": ("nvidia", "meta/llama-4-maverick-17b-128e-instruct", "speed", "Llama 4 Maverick · 128 experts · [TOOL]"),
            "llama8b": ("nvidia", "meta/llama-3.1-8b-instruct", "speed", "Llama 3.1 8B · tiny · [TOOL]"),
            "gptoss": ("nvidia", "openai/gpt-oss-20b", "speed", "GPT OSS 20B · small MoE"),
            "gemma3n": ("nvidia", "google/gemma-3n-e2b-it", "speed", "Gemma 3n · edge multimodal"),
            "kimi": ("nvidia", "moonshotai/kimi-k2.6", "speed", "Kimi K2 · Moonshot · [TOOL]"),
            "mistral-large": ("nvidia", "mistralai/mistral-large-3-675b-instruct-2512", "beast", "Mistral Large 3 · 675B frontier · [TOOL]"),
        }

    return models


# Load models dynamically at startup
MODELS = _load_models_from_benchmark()

