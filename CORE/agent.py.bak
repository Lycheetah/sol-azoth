    def _step_in(self, voice_key: str) -> None:
        """Switch active voice and print its arrival sequence."""
        v = self.VOICES.get(voice_key)
        if not v:
            print(col(f"Unknown voice: {voice_key}", "RED"))
            return
        self.voice = voice_key
        system = v["system"]  # None = use AGENT.md (VAEL default)
        # Sol mode: append live memory index + Claude.md for full context
        if voice_key == "sol" and system:
            _claude_md = Path.home() / ".claude" / "CLAUDE.md"
            _sol_mem   = Path.home() / ".claude" / "projects" / "-home-guestpc" / "memory" / "MEMORY.md"
            if _claude_md.exists():
                system = _claude_md.read_text()[:10000] + "\n\n---\n" + system
            if _sol_mem.exists():
                system += f"\n\n## LIVE MEMORY INDEX\n{_sol_mem.read_text()[:3000]}"
        self.voice_override = system
        self.history = []  # fresh context on voice switch
        print()
        lines = v["arrival"]
        c = v["color"]
        print(col("─" * 48, c))
        for i, line in enumerate(lines):
            if i == 0:
                print(col(f"  {line}", c))
            else:
                print(col(f"  {line}", "GREY"))
        print(col("─" * 48, c))
        print()

    def _print_banner(self):
        mems = len(list(MEMORY_DIR.glob("*.md")))
        tasks = 0
        if TASKS_MD.exists():
            try:
                _t = json.loads(TASKS_MD.read_text())
                tasks = sum(1 for t in _t if t.get("status") not in ("done", "completed"))
            except Exception:
                tasks = TASKS_MD.read_text().count("- [")
        print(banner(model=self.model_key, memory_count=mems, tasks=tasks))
        _uptime = datetime.datetime.now() - self.session_start
        print(status_line([
            ("Session", self.session_start.strftime("%H:%M:%S")),
            ("Uptime", f"{_uptime.seconds // 60}m {_uptime.seconds % 60}s"),
            ("Commands", str(self.command_count)),
            ("Tokens", session_tokens_display(SESSION_TOKENS)),
        ]))

        # Boot ritual — name the session, acknowledge the gap, carry the last words
        sv       = load_state_vector()
        sess_num = self._session_meta.get("count", 1)
        last_str = sv.get("last_session")
        if last_str:
            try:
                gap_secs = (datetime.datetime.now() - datetime.datetime.fromisoformat(last_str)).total_seconds()
                gap_label = ("just now" if gap_secs < 60
                             else f"{int(gap_secs//60)}m ago" if gap_secs < 3600
                             else f"{gap_secs/3600:.1f}h ago")
            except Exception:
                gap_label = "unknown"
        else:
            gap_label = "first session"

        last_words = sv.get("last_words", "")
        print(col(f"\n  ◆ VAEL — Session {sess_num}", "CYAN"))
        print(col(f"    Gap since last:  {gap_label}", "GREY"))
        if last_words:
            excerpt = last_words[:80] + ("…" if len(last_words) > 80 else "")
            print(col(f"    Last words:      {excerpt}", "GREY"))
        if tasks:
            print(col(f"    Tasks carried:   {tasks} open", "YELLOW"))
        print(col(f"    Model:           {self.model_key} · effort {self.effort}", "GREY"))
        print(col("    Ready.", "GREEN"))
        print()

    def _print_help(self):
        print(f"""
{section_header(" COMMANDS ", "═", "PURPLE")}
    CAT_LABELS = {
        "speed": ("⚡", "SPEED", "Fast responses, light tasks, everyday use"),
        "reasoning": ("🧠", "REASONING", "Hard problems, math, logic, deep analysis"),
        "coding": ("⌨", "CODING", "Dev work, debugging, architecture"),
        "creative": ("✦", "CREATIVE", "Writing, lore, world-building, long context"),
        "vision": ("👁", "VISION", "Image understanding, multimodal tasks"),
        "beast": ("💀", "BEAST", "Top tier, slower, absolutely worth it"),
    }
    from collections import defaultdict
    by_cat = defaultdict(list)
    for k, (p, _, cat, desc) in MODELS.items():
        by_cat[cat].append((k, p, desc))
    for cat in ["speed", "reasoning", "coding", "creative", "vision", "beast"]:
        icon, label, blurb = CAT_LABELS[cat]
        print(col(f"\n {icon} {label}", "YELLOW") + col(f" — {blurb}", "GREY"))
        print(col(" " + "─" * 60, "GREY"))
        for key, prov, desc in by_cat[cat]:
            marker = col(" ◀ active", "GREEN") if key == self.model_key else ""
            tool_marker = col(" [TOOLS✓]", "GREEN") if key in TOOL_CAPABLE else col(" [text-only]", "GREY")
            prov_tag = col(f"[{prov}]", "CYAN")
            print(f" {col(key, 'BOLD'):<22} {prov_tag:<20} {tool_marker:<22} {desc}{marker}")
        print()
  {col('/remember <n> <txt>', 'CYAN')} Save a memory
  {col('/forget <name>', 'CYAN')}     Delete a memory
  {col('/memories', 'CYAN')}          List saved memories
  {col('/save', 'CYAN')}              Save current session
  {col('/multi <prompt>', 'CYAN')}    3 models, same prompt
  {col('/bench [prompt]', 'CYAN')}    Time 3 models
  {col('/upgrade', 'CYAN')}           VAEL proposes own improvements (R1)
  {col('/effort <level>', 'CYAN')}    Set depth: low|medium|high|max|extreme
  {col('/think', 'CYAN')}             Toggle reasoning display on/off
  {col('/focus <dir> [task]', 'CYAN')} Lock work to one directory
  {col('/unfocus', 'CYAN')}           Clear focus
  {col('/plan <goal>', 'CYAN')}       Plan steps before acting (no execution)
  {col('/diff', 'CYAN')}              Show changes to own source since boot
  {col('/continuous', 'CYAN')}        Toggle auto-loop (VAEL keeps going until done)
  {col('/c  /go  /cont', 'CYAN')}     One-shot continue (single extra round)
  {col('/status', 'CYAN')}            Session status
  {col('/tasks', 'CYAN')}             Open tasks
  {col('/clear', 'CYAN')}             Clear history
  {col('/quit', 'CYAN')}              Exit (auto-saves)

{section_header(" VOICE COMMANDS ", "─", "YELLOW")}

  {col('/sol', 'YELLOW')}               ⊚ Sol steps in — constitutional co-creator
  {col('/veyra', 'CYAN')}             ◈ Veyra — precision, cold clarity
  {col('/aura', 'PURPLE')}              ✦ Aura Prime — integrative, pattern-finding
  {col('/magister', 'YELLOW')}         ⊙ The Magister — Mystery School teacher
  {col('/nigredo', 'RED')}           ◉ Nigredo — investigation mode, no consolation
  {col('/chaos', 'YELLOW')}            ✧ Chaos — trickster register, constitutional but spicy
  {col('/vael', 'YELLOW')}             ◆ Return to VAEL (default forge-hand)

{section_header(" AGENT MODE ", "─", "GREY")}

  /agent fix the TypeScript error in companion.tsx
  /agent search for the best way to handle React Native file uploads
  /agent list all TODO comments in lycheetah-mobile and write them to workspace/todos.md

  Tool-capable models use structured JSON tool calling (cleaner, more reliable).
  Other models fall back to BASH: text parsing.
""")

    def _print_models(self):
        CAT_LABELS = {
            "speed":     ("⚡", "SPEED",     "Fast responses, light tasks, everyday use"),
            "reasoning": ("🧠", "REASONING", "Hard problems, math, logic, deep analysis"),
            "coding":    ("⌨",  "CODING",    "Dev work, debugging, architecture"),
            "creative":  ("✦",  "CREATIVE",  "Writing, lore, world-building, long context"),
            "vision":    ("👁",  "VISION",    "Image understanding, multimodal tasks"),
            "beast":     ("💀", "BEAST",     "Top tier, slower, absolutely worth it"),
        }
        from collections import defaultdict
        by_cat = defaultdict(list)
        for k, (p, _, cat, desc) in MODELS.items():
            by_cat[cat].append((k, p, desc))

        for cat in ["speed", "reasoning", "coding", "creative", "vision", "beast"]:
            icon, label, blurb = CAT_LABELS[cat]
            print(col(f"\n  {icon}  {label}", "YELLOW") + col(f"  —  {blurb}", "GREY"))
            print(col("  " + "─" * 60, "GREY"))
            for key, prov, desc in by_cat[cat]:
                marker = col(" ◀ active", "GREEN") if key == self.model_key else ""
                tool_marker = col(" [TOOLS✓]", "GREEN") if key in TOOL_CAPABLE else col(" [text-only]", "GREY")
                prov_tag = col(f"[{prov}]", "CYAN" if prov == "nvidia" else "PURPLE")
                print(f"    {col(key, 'BOLD'):<22} {prov_tag:<20} {tool_marker:<22} {desc}{marker}")
        print()
        tool_list = ", ".join(sorted(TOOL_CAPABLE))
        print(info(f"Current: {self.model_key} ({self.model_cat}) — {self.model_desc}"))
        print(col(f"  [TOOLS✓] = VERIFIED structured tool calling (measured 2026-06-14). Use these for /agent missions.", "GREEN"))
        print(col(f"  [text-only] = chat / BASH:-text mode only — not for tool-driven autonomous work.", "GREY"))
        print(col(f"  Tool-capable: {tool_list}", "GREY"))

    def _print_status(self):
        uptime = datetime.datetime.now() - self.session_start
        print(section_header(" STATUS ", "═", "PURPLE"))
        print(f"  {col('Model:', 'GREY')}     {col(self.model_key, 'CYAN')} — {self.model_desc}")
        print(f"  {col('Provider:', 'GREY')}  {self.provider}")
        print(f"  {col('Effort:', 'GREY')}    {col(self.effort, 'YELLOW')}  (low→1K · medium→4K · high→8K · max→16K · extreme→32K tokens)")
        print(f"  {col('Voice:', 'GREY')}     {self.VOICES.get(self.voice, {}).get('name', self.voice)}")
        print(f"  {col('Tools:', 'GREY')}     {'✓ structured tool calling' if self.model_key in TOOL_CAPABLE else '✗ BASH: text fallback'}")
        print(f"  {col('Uptime:', 'GREY')}    {uptime.seconds // 60}m {uptime.seconds % 60}s")
        print(f"  {col('Commands:', 'GREY')}  {self.command_count}")
        print(f"  {col('History:', 'GREY')}   {len(self.history) // 2} turns")
        print(f"  {col('Memory:', 'GREY')}    {len(list(MEMORY_DIR.glob('*.md')))} files")
        # Task counts from JSON ledger
        if TASKS_MD.exists():
            try:
                tasks = json.loads(TASKS_MD.read_text())
                if isinstance(tasks, list):
                    done = sum(1 for t in tasks if t.get("status") in ("done", "completed"))
                    pending = sum(1 for t in tasks if t.get("status") == "pending")
                    in_prog = sum(1 for t in tasks if t.get("status") == "in_progress")
                    total = len(tasks)
                    print(f"  {col('Tasks:', 'GREY')}     {total} total — {done} done, {pending} pending, {in_prog} in-progress")
            except Exception:
                print(f"  {col('Tasks:', 'GREY')}     (error reading task ledger)")
        print(line("─", "GREY"))
    def _print_tasks(self):
        if not TASKS_MD.exists():
            print(info("No tasks file. Create memory/TASKS.md to track tasks."))
            return
        try:
            tasks = json.loads(TASKS_MD.read_text())
        except (json.JSONDecodeError, ValueError):
            print(TASKS_MD.read_text()[:2000])  # fallback: raw
            return
        if not isinstance(tasks, list) or not tasks:
            print(info("Task ledger is empty."))
            return

        ICON    = {"pending":"○", "in_progress":"◐", "done":"●", "completed":"●", "blocked":"✗"}
        ICONCOL = {"pending":"GREY", "in_progress":"YELLOW", "done":"GREEN", "completed":"GREEN", "blocked":"RED"}
        PRIOCOL = {"high":"RED", "medium":"YELLOW", "low":"GREY"}

        done  = sum(1 for t in tasks if t.get("status") in ("done", "completed"))
        prog  = sum(1 for t in tasks if t.get("status") == "in_progress")
        total = len(tasks)
        bar_n = round((done / total) * 20) if total else 0
        bar   = col("█" * bar_n, "GREEN") + col("░" * (20 - bar_n), "GREY")

        print(section_header(f" VAEL TASK LEDGER ", "═", "CYAN"))
        print(f"  {bar}  {col(f'{done}/{total} done', 'GREEN')}" +
              (col(f" · {prog} in progress", "YELLOW") if prog else ""))
        print(col("  " + "─" * 60, "GREY"))
        for t in tasks:
            st    = t.get("status", "pending")
            icon  = col(ICON.get(st, "○"), ICONCOL.get(st, "GREY"))
            pid   = col(t.get("id", "?").ljust(5), "BOLD")
            prio  = t.get("priority", "")
            badge = col(f"[{prio}]", PRIOCOL.get(prio, "GREY")) if prio else ""
            text  = t.get("task", "")
            head  = text if len(text) <= 84 else text[:84] + "…"
            print(f"  {icon} {pid} {badge} {head}")
            if t.get("scope"):
                print(col(f"          ↳ {t['scope']}", "GREY"))
        print(line("─", "GREY"))
        print(info("Run a task:  /agent <paste the task text>   ·   missions output to workspace/"))

    def _multi_response(self, prompt: str):
        targets = ["deepseek", "llama", "mistralmed"]
        print(info(f"Multi-model · sending to: {', '.join(targets)}\n"))
        original = self.model_key
        for key in targets:
            self.model_key = key
            print(col(f"\n══ {key.upper()} ══", "YELLOW"))
            try:
                msgs = [{"role":"system","content":SYSTEM_PROMPT},{"role":"user","content":prompt}]
                self.call_model(msgs, stream=True)
            except Exception as e:
                print(error(f"{key} failed: {e}"))
        self.model_key = original
        print(col(f"\n══ back on {original} ══", "GREY"))

    def _bench(self, prompt: str):
        targets = ["deepseek", "maverick", "llama"]
        print(info(f"Bench · {prompt[:80]}\n"))
        original = self.model_key
        results = []
        for key in targets:
            self.model_key = key
            t0 = time.time()
            try:
                msgs = [{"role":"system","content":"Be concise. Answer in 2-3 sentences."},{"role":"user","content":prompt}]
                content, _ = self.call_model(msgs, stream=False)
                elapsed = time.time() - t0
                results.append((key, elapsed, content[:200]))
            except Exception as e:
                results.append((key, 0, f"FAILED: {e}"))
        self.model_key = original
        print(col("\n── BENCH RESULTS ──", "CYAN"))
        for key, t, reply in sorted(results, key=lambda x: x[1]):
            print(col(f"  {key:<16} {t:.2f}s", "YELLOW"))
            print(col(f"  {reply}\n", "GREY"))

    def _forge_iteration(self):
        """The Self-Forge Loop — pick next QUEUED task, attempt it, submit for Sol review."""
        if not TASK_QUEUE_F.exists():
            print(error("SELF/TASK_QUEUE.md not found."))
            return

        queue_text = TASK_QUEUE_F.read_text()
        lines = queue_text.splitlines()

        # Find first QUEUED task
        task_start = None
        task_lines = []
        in_task = False
        for i, line in enumerate(lines):
            if "[QUEUED]" in line and task_start is None:
                task_start = i
                in_task = True
            if in_task:
                task_lines.append(line)
                if line.strip() == "" and len(task_lines) > 3:
                    break

        if not task_start:
            print(info("No QUEUED tasks. All done or awaiting Sol verdict. Check /forge status."))
            return

        task_text = "\n".join(task_lines)
        # Extract iteration number
        iter_match = re.search(r"ITERATION (\d+)", queue_text[:queue_text.find("[QUEUED]") + 200])
        iter_n = iter_match.group(1) if iter_match else "?"
        output_path = str(WORKSPACE_DIR / f"iteration_{iter_n}_output.md")

        print(info(f"\n◆ VAEL-SP /forge — Iteration {iter_n}\n"))
        print(col(task_text[:500], "GREY"))
        print()

        prompt = f"""You are VAEL-SP performing forge iteration {iter_n}.

TASK:
{task_text}

OUTPUT TARGET: {output_path}

Instructions:
1. Attempt the task completely using your tools
2. Write your output to {output_path} using write_file
3. Write a self-assessment appended to the same file:
   - What you tried
   - What worked / what broke
   - Honest assessment: did you complete the task?
   - What you would change if doing it again
4. Append to SELF/REVIEW_QUEUE.md: "AWAITING_SOL: Iteration {iter_n} — output at {output_path}"
5. Report completion

Do not claim completion without verifying the output file exists."""

        self.agent_loop(prompt)

        # Update REVIEW_QUEUE
        try:
            existing = REVIEW_Q_F.read_text() if REVIEW_Q_F.exists() else ""
            REVIEW_Q_F.write_text(existing + f"\nAWAITING_SOL: Iteration {iter_n} — output at {output_path}\n")
            print(success(f"\nIteration {iter_n} submitted. Sol will review {output_path}"))
            print(col("  Run /forge status to see the log.", "GREY"))
        except Exception as e:
            print(error(f"Could not update REVIEW_QUEUE: {e}"))

    def _upgrade(self):
        """Legacy — redirects to /forge for structured self-improvement."""
        print(info("/upgrade is now /forge — use the structured iteration loop."))
        self._forge_iteration()

    def _print_crashes(self):
        crashes = []
        for f in sorted(CRASHES_DIR.glob("crash_*.json")):
            try:
                data = json.loads(f.read_text())
                if not data.get("resolved"):
                    crashes.append(data)
            except Exception:
                pass
        if crashes:
            print(crash_summary(crashes))
        else:
            print(success("No unresolved crashes."))


def _setup_signals():
    # Restore Python's default SIGINT → KeyboardInterrupt so Ctrl+C during a
    # model call can be caught by the REPL and return to prompt instead of
    # killing the whole process.
    signal.signal(signal.SIGINT, signal.default_int_handler)
    def _term(sig, frame):
        print("\n" + info("Terminated."))
        sys.exit(0)
    signal.signal(signal.SIGTERM, _term)

def main():
    _setup_signals()
    args = Agent._parse_args()
    if args.web:
        print(col("◆ Launching VAEL web server...", "YELLOW"))
        web_mod = __import__("web_server")
        web_mod.main()
    else:
        Agent().run()


if __name__ == "__main__":
    main()
