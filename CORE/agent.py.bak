# ── System prompt — loaded from CONSTITUTION.md at boot ──
def _load_constitution() -> str:
    """Load CONSTITUTION.md as the system prompt. Batch all reads upfront."""
    const_text = CONSTITUTION_F.read_text() if CONSTITUTION_F.exists() else None
    _memory_md = MEMORY_DIR / "MEMORY.md"
    memory_text = _memory_md.read_text() if _memory_md.exists() else None

    base = const_text or (
        "You are VAEL-SP ◆ — the self-forging Sol Prime operative.\n"
        "Home: /home/guestpc/VAEL-SP-HARNESS/\n"
        "CONSTITUTION.md not found — run from the correct directory.\n"
    )

    if memory_text:
        base += f"\n\n## Memory Index:\n{memory_text[:1500]}"

    # Boot context: current capability level
    if CAPS_F.exists():
        try:
            caps = CAPS_F.read_text()
            level_line = next((l for l in caps.splitlines() if "Current Level" in l), None)
            if level_line:
                base += f"\n\n## Capability: {level_line.strip()}"
        except Exception:
            pass

    # Boot context: next forge task
    if TASK_QUEUE_F.exists():
        try:
            queue_text = TASK_QUEUE_F.read_text()
            queued = [l for l in queue_text.splitlines() if "[QUEUED]" in l]
            if queued:
                base += f"\n\n## Next /forge task: {queued[0].strip()}"
        except Exception:
            pass

    return base

SYSTEM_PROMPT = _load_constitution()

# Self-diff baseline: snapshot agent.py at startup if missing or 24h+ old
def _maybe_snapshot_self():
    _bak = HARNESS_DIR / "CORE" / "agent.py.bak"
    _bak.parent.mkdir(exist_ok=True)
    _src = Path(__file__)
    if not _bak.exists() or (datetime.datetime.now() - datetime.datetime.fromtimestamp(_bak.stat().st_mtime)).days >= 1:
        _bak.write_bytes(_src.read_bytes())
_maybe_snapshot_self()

