    MODELS = {k: v for k, v in MODELS.items() if v[0] != "deepseek"}
if not gemini_client:
    MODELS = {k: v for k, v in MODELS.items() if v[0] != "gemini"}
if not nvidia_client:
    MODELS = {k: v for k, v in MODELS.items() if v[0] != "nvidia"}

def _client_for(slug: str):
    provider = MODELS.get(slug, ("deepseek",))[0]
    return {"deepseek": deepseek_client, "gemini": gemini_client, "nvidia": nvidia_client}.get(provider, deepseek_client)

def _model_id(slug: str) -> str:
    return MODELS.get(slug, (None, slug))[1]

# Default: V4 Flash (tool-capable). Override with AZOTH_DEFAULT_MODEL=pro
_env_default = _resolve_alias(os.environ.get("AZOTH_DEFAULT_MODEL", "flash"))
DEFAULT_MODEL = _env_default if _env_default in MODELS else next(
    (s for s in ["flash", "pro", "deep"] if s in MODELS),
    next(iter(MODELS.keys())) if MODELS else "flash"
)

# ── MODEL TIER LAW (updated July 9 2026 — DeepSeek-only for main agent) ─────
#   All bodies on AZOTH_DEEPSEEK_ONLY=1 → DeepSeek V4 only.
#   SOL/LUNA → flash default, pro on demand (/model pro).
PREMIUM_BODIES = {"SOL", "LUNA"}
ALLOW_DEEPSEEK = os.environ.get("ALLOW_DEEPSEEK", "1") == "1"  # default ON now

def _premium_default() -> str:
    """Best model for main body — DeepSeek V4 Flash (tools) unless pro pinned in env."""
    for slug in [_env_default, "flash", "pro", "deep"]:
        if slug in MODELS:
            return slug
    return DEFAULT_MODEL

def _fallback_chain(for_agent: str = "SOL") -> list[str]:
    """Ordered fallback chain when a call fails. DeepSeek-only: flash ↔ pro."""
    if DEEPSEEK_ONLY or not nvidia_client:
        return [s for s in ["flash", "pro", "deep"] if s in MODELS] or [DEFAULT_MODEL]
    if for_agent == "SOL":
        return [s for s in ["flash", "pro", "deep", "gpt120", "qwen", "llama70", "gpt20"] if s in MODELS] or [DEFAULT_MODEL]
    if for_agent == "LUNA":
        return [s for s in ["flash", "pro", "gpt120", "qwen", "llama70", "gpt20", "lite"] if s in MODELS] or [DEFAULT_MODEL]
    return [s for s in ["flash", "gpt20", "lite"] if s in MODELS] or [DEFAULT_MODEL]

def _luna_default() -> str:
    return _premium_default()

def resolve_model_for(agent_name: str, pinned: str = None) -> str:
    """Tier-aware model resolution. DeepSeek-only: always a V4 slug."""
    pinned = _resolve_alias(pinned) if pinned else None
    if pinned and pinned in MODELS:
        is_deepseek = MODELS[pinned][0] == "deepseek"
        if is_deepseek and agent_name not in PREMIUM_BODIES and not ALLOW_DEEPSEEK:
            pass
        else:
            return pinned
    if agent_name in ("SOL", "LUNA") or DEEPSEEK_ONLY:
        return _premium_default()
    return DEFAULT_MODEL

