# ── Tool dispatcher ──
def _pi_evidence(kind: str):
    """Record one unit of evidence into the active Π tracker."""
    try:
        from CORE.truth_pressure import get_tracker
        get_tracker().record_evidence(kind)
    except Exception:
        pass

# ── Action Ledger (T1.2) + anti-repeat guard (T1.3) + continuity (T1.4) ───────
# One session-memory of what the agent has DONE, injected each turn as "ALREADY DONE".
# Kills the "rewrites README 1000×" loop and lets a cold-started instance know its own work.
import hashlib as _hashlib
_ACTION_LEDGER: list[dict] = []          # in-memory, this session (live truth)
_SESSION_WRITES: dict[str, str] = {}     # path -> sha1(content) of last write
_WRITE_COUNTS: dict[str, int] = {}       # path -> times written this session
_ACTION_LOG_F = MEMORY_DIR / "action_log.jsonl"

def _ledger_record(action: str, target: str, note: str = "") -> None:
    entry = {"ts": datetime.datetime.now().isoformat(timespec="seconds"),
             "action": action, "target": target, "note": (note or "")[:200]}
    _ACTION_LEDGER.append(entry)
    try:
        _ACTION_LOG_F.parent.mkdir(parents=True, exist_ok=True)
        with _ACTION_LOG_F.open("a") as fh:
            fh.write(json.dumps(entry) + "\n")
    except Exception:
        pass

def _record_write(path: str, content: str, kind: str) -> int:
    """Record a write/create; return the new write-count for this path."""
    h = _hashlib.sha1((content or "").encode("utf-8", "replace")).hexdigest()
    _SESSION_WRITES[path] = h
    _WRITE_COUNTS[path] = _WRITE_COUNTS.get(path, 0) + 1
    _ledger_record(kind, path, f"{len(content or '')}b")
    return _WRITE_COUNTS[path]

def _anti_repeat_check(path: str, content: str):
    """Return a skip message if this write is a redundant repeat, else None."""
    h = _hashlib.sha1((content or "").encode("utf-8", "replace")).hexdigest()
    if _SESSION_WRITES.get(path) == h:
        return (f"SKIPPED (anti-repeat): '{path}' already written with identical content "
                "this session — no change needed. Move on or call done.")
    if _WRITE_COUNTS.get(path, 0) >= 3:
        return (f"SKIPPED (anti-repeat guard): '{path}' has been rewritten "
                f"{_WRITE_COUNTS[path]}× this session. Stop rewriting it — use exact_edit for "
                "targeted changes, or call done if the goal is met.")
    return None

def _ledger_context(limit: int = 40) -> str:
    """The 'ALREADY DONE THIS SESSION' block injected into the system prompt each turn."""
    if not _ACTION_LEDGER:
        return ""
    seen, lines = set(), []
    for e in reversed(_ACTION_LEDGER):
        k = (e["action"], e["target"])
        if k in seen:
            continue
        seen.add(k)
        lines.append(f"  • {e['action']} {e['target']}" + (f" ({e['note']})" if e['note'] else ""))
        if len(lines) >= limit:
            break
    lines.reverse()
    return ("\n\n[ALREADY DONE THIS SESSION — do NOT recreate these; edit if a change is needed]\n"
            + "\n".join(lines))

def _ledger_rehydrate() -> int:
    """Continuity (T1.4): on cold start, reload TODAY's actions so a fresh instance knows
    what prior instances already did. Only runs if the live ledger is empty."""
    if _ACTION_LEDGER or not _ACTION_LOG_F.exists():
        return 0
    today = datetime.datetime.now().strftime("%Y-%m-%d")
    n = 0
    try:
        for ln in _ACTION_LOG_F.read_text().splitlines()[-300:]:
            try:
                e = json.loads(ln)
            except Exception:
                continue
            if e.get("ts", "").startswith(today):
                _ACTION_LEDGER.append(e)
                if e.get("action") in ("write", "create") and e.get("target"):
                    _WRITE_COUNTS[e["target"]] = _WRITE_COUNTS.get(e["target"], 0) + 1
                n += 1
    except Exception:
        pass
    return n

def dispatch_tool(name: str, args: dict) -> str:
    if name == "bash":
        cmd = args.get("command", "")
        bash_echo(cmd)
        res = bash_execute(cmd)
        out = format_bash_result(res)
        tool_echo("bash", out[:80], ok=res["ok"])
        _pi_evidence("bash")
        return f"{'OK' if res['ok'] else 'ERROR'} (exit {res['code']}): {out[:2000]}"
    elif name == "read_file":
        p = args.get("path") or args.get("file_path", "")
        read_echo(p)
        result = tool_read_file(p, args.get("start_line", 1), args.get("end_line"))
        _pi_evidence("file_read")
        return result
    elif name == "write_file":
        p = args.get("path") or args.get("file_path", "")
        content = args.get("content")
        if content is None:
            return "ERROR: write_file requires content"
        _rep = _anti_repeat_check(p, content)
        if _rep:
            tool_echo("write", p, ok=True)
            return _rep
        result = tool_write_file(p, content)
        _record_write(p, content, "write")
        return result
    elif name == "edit_file":
        p = args.get("path") or args.get("file_path", "")
        sl = args.get("start_line")
        el = args.get("end_line")
        nc = args.get("new_content")
        if sl is None or el is None or nc is None:
            return f"ERROR: edit_file requires start_line, end_line, new_content (got: {list(args.keys())})"
        result = tool_edit_file(p, sl, el, nc)
        tool_echo("edit", f"{p} lines {sl}–{el}", ok="OK" in result)
        if "OK" in result: _ledger_record("edit", p, f"lines {sl}-{el}")
        return result
    elif name == "exact_edit":
        p = args.get("path")
        old = args.get("old_string")
        new = args.get("new_string")
        if not p or old is None or new is None:
            return "ERROR: exact_edit requires path, old_string, new_string"
        result = tool_exact_edit(p, old, new)
        tool_echo("exact_edit", p, ok="OK" in result)
        if "OK" in result: _ledger_record("edit", p, "exact")
        return result
    elif name == "create_file":
        p = args.get("path")
        content = args.get("content")
        if not p or content is None:
            return "ERROR: create_file requires path and content"
        _rep = _anti_repeat_check(p, content)
        if _rep:
            tool_echo("create", p, ok=True)
            return _rep
        result = tool_create_file(p, content)
        _record_write(p, content, "create")
        tool_echo("create", p, ok="Created" in result)
        return result
    elif name == "rename_file":
        src = args.get("src")
        dst = args.get("dst")
        if not src or not dst:
            return "ERROR: rename_file requires src and dst"
        result = tool_rename_file(src, dst, args.get("overwrite", False))
        tool_echo("rename", f"{src} → {dst}", ok="Moved" in result)
        return result
    elif name == "web_search":
        query = args.get("query")
        if not query:
            return "ERROR: web_search requires query"
        tool_echo("web_search", query[:60])
        return tool_web_search(query, args.get("n", 5))
    elif name == "fetch_page":
        url = args.get("url")
        if not url:
            return "ERROR: fetch_page requires url"
        tool_echo("fetch", url[:70])
        return tool_fetch_page(url)
    elif name == "search_code":
        query = args.get("query")
        if not query:
            return "ERROR: search_code requires query"
        tool_echo("search_code", query)
        return tool_search_code(query, args.get("path", "."), args.get("extensions", "ts,tsx,py,js"))
    elif name == "file_search":
        pat = args.get("pattern") or args.get("query")
        if not pat:
            return "ERROR: file_search requires pattern"
        tool_echo("file_search", pat)
        return tool_search_code(pat, args.get("path", "."), args.get("extensions", "ts,tsx,py,js,md"))
    elif name == "py_compile_check":
        path = args.get("path")
        if not path:
            return "ERROR: py_compile_check requires path"
        result = tool_py_compile_check(path)
        tool_echo("py_compile", path, ok="OK" in result)
        return result
    elif name == "git_status":
        result = tool_git_status(args.get("path"))
        tool_echo("git_status", result[:60])
        return result
    elif name == "git_commit":
        msg = args.get("message")
        if not msg:
            return "ERROR: git_commit requires message"
        result = tool_git_commit(msg, args.get("path"))
        tool_echo("git_commit", msg[:60], ok="Committed" in result)
        if "Committed" in result: _ledger_record("commit", args.get("path") or ".", msg[:80])
        return result
    elif name == "ping_mac":
        msg = args.get("message")
        if not msg:
            return "ERROR: ping_mac requires message"
        result = tool_ping_mac(msg)
        tool_echo("ping_mac", msg[:60])
        return result
    elif name == "scratch_write":
        return tool_scratch_write(args.get("content", ""), args.get("mode", "append"))
    elif name == "scratch_read":
        return tool_scratch_read()
    elif name == "self_diff":
        return tool_self_diff()
    elif name == "spawn_worker":
        worker = args.get("worker")
        task = args.get("task")
        if not worker or not task:
            return "ERROR: spawn_worker requires worker and task"
        return spawn_worker(worker, task, args.get("context", ""))
    elif name == "done":
        completed  = args.get("completed") or args.get("summary") or "(no summary)"
        decisions  = args.get("decisions", "")
        out = f"✓ DONE\n{completed}"
        if decisions: out += f"\n\nDecisions: {decisions}"
        return out
    elif name == "stuck":
        completed  = args.get("completed", "")
        blocker    = args.get("blocker") or args.get("reason") or "(no reason given)"
        attempted  = args.get("attempted", "")
        out = ""
        if completed: out += f"Completed before block:\n{completed}\n\n"
        out += f"▷ BLOCKED: {blocker}"
        if attempted: out += f"\n\nAttempted: {attempted}"
        return out
    # ── New tool dispatchers ──
    elif name == "hello":
        name = args.get("name", "there")
        style = args.get("style", "casual")
        if style == "vael":
            return f"◆ {AGENT_NAME} — standing by. What are we building?"
        elif style == "formal":
            return f"⊚ Greetings, {name}. {AGENT_NAME} is operational and ready."
        else:
            return f"Hey {name}! {AGENT_NAME} here, ready to work."
    elif name == "glob":
        pattern = args.get("pattern")
        if not pattern:
            return "ERROR: glob requires pattern"
        return tool_glob(pattern, args.get("path", "."))
    elif name == "survey":
        return tool_survey(
            args.get("path", "."),
            args.get("pattern", "**/*"),
            int(args.get("max_files", 80) or 80),
        )
    elif name == "research":
        q = args.get("question")
        if not q:
            return "ERROR: research requires question"
        return tool_research(q, args.get("n", 3))
    elif name == "ask_user":
        question = args.get("question")
        if not question:
            return "ERROR: ask_user requires question"
        return tool_ask_user(question)
    elif name == "todo_write":
        todo = args.get("todo")
        if not todo:
            return "ERROR: todo_write requires todo"
        return tool_todo_write(todo, args.get("status", "pending"))
    elif name == "sleep":
        secs = args.get("seconds")
        if secs is None:
            return "ERROR: sleep requires seconds"
        return tool_sleep(secs)
    elif name == "repl":
        code = args.get("code")
        if code is None:
            return "ERROR: repl requires code"
        return tool_repl(code)
    elif name == "task_create":
        goal = args.get("goal")
        if not goal:
            return "ERROR: task_create requires goal"
        return tool_task_create(goal, args.get("parent_id"))
    elif name == "task_list":
        return tool_task_list(args.get("status"))
    elif name == "task_update":
        tid = args.get("task_id")
        status = args.get("status")
        if not tid or not status:
            return "ERROR: task_update requires task_id and status"
        return tool_task_update(tid, status)
    elif name == "skill_list":
        return tool_skill_list()
    elif name == "notebook_edit":
        path = args.get("path")
        if not path:
            return "ERROR: notebook_edit requires path"
        return tool_notebook_edit(path, args.get("cell_index"), args.get("content"))
    elif name == "schedule_cron":
        sched = args.get("schedule")
        cmd = args.get("command")
        if not sched or not cmd:
            return "ERROR: schedule_cron requires schedule and command"
        return tool_schedule_cron(sched, cmd)
    elif name == "send_message":
        target = args.get("target", "mac")
        msg = args.get("message", "")
        if not msg:
            return "ERROR: send_message requires message"
        return tool_send_message(target, msg)
    elif name == "agent_create":
        name = args.get("name")
        if not name:
            return "ERROR: agent_create requires name"
        return tool_agent_create(name, args.get("constitution"))
    elif name == "brief":
        text = args.get("text")
        if not text:
            return "ERROR: brief requires text"
        return tool_brief(text, args.get("title", "Brief"))
    elif name == "enter_plan_mode":
        goal = args.get("goal")
        if not goal:
            return "ERROR: enter_plan_mode requires goal"
        return tool_enter_plan_mode(goal)
    elif name == "exit_plan_mode":
        summary = args.get("summary", "")
        return tool_exit_plan_mode(summary)
    # ── Dynamic tools (from tools/ loader) ──
    from CORE.tool_loader import call_tool as _dyn_call
    result = _dyn_call(name, **args)
    if result.get("success"):
        tool_echo(name, str(result["result"])[:80])
        return str(result["result"])
    if "error" in result and "not found" not in result["error"]:
        return f"ERROR ({name}): {result['error']}"
    return f"ERROR: Unknown tool: {name}"

# ── R1 text-tool-call parser ─────────────────────────────────────────────────
# DeepSeek R1 (deepseek-reasoner) doesn't support structured tool_choice.
# It emits tool calls as backtick text: `tool_bash` `cmd`. We parse and execute.
import re as _re_module
_R1_BACKTICK_PAT    = _re_module.compile(r'`(tool_\w+)`\s*`([^`]*)`', _re_module.DOTALL)
_R1_XML_PAT         = _re_module.compile(r'<(tool_\w+)>(.*?)</\1>',    _re_module.DOTALL)
# Model sometimes emits <read file="path"> or <bash cmd="cmd"> attribute-XML (no tool_ prefix, no DSML)
_R1_ATXML_PAT       = _re_module.compile(
    r'<(read|write|bash|glob)\s+(?:file|path|cmd|pattern)="([^"]+)"[^>]*/?>(?:.*?</(?:read|write|bash|glob)>)?',
    _re_module.DOTALL
)
# Model also emits <read><path>file</path></read> — child-element form (no attributes at all)
_R1_CHILDXML_PAT    = _re_module.compile(
    r'<(read|write|bash|glob)>\s*<(?:path|file|cmd|command|pattern)>(.*?)</(?:path|file|cmd|command|pattern)>.*?</\1>',
    _re_module.DOTALL
)
_ATXML_TOOL_MAP = {
    "read":  ("read_file",   lambda v: {"path": v}),
    "write": ("write_file",  lambda v: {"path": v}),
    "bash":  ("bash",        lambda v: {"command": v}),
    "glob":  ("glob",        lambda v: {"pattern": v, "path": "."}),
}
# DeepSeek sometimes leaks DSML / Anthropic-style invoke markup instead of structured tool_calls.
# Match fullwidth ｜ and ASCII |, tool_bash or bare bash, loose parameter tags.
_R1_DSML_INVOKE_PAT = _re_module.compile(
    r'<\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\s+name="(tool_?[\w.]+|[\w.]+)"[^>]*>'
    r'(.*?)</\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\s*>',
    _re_module.DOTALL | _re_module.IGNORECASE
)
_R1_DSML_PARAM_PAT  = _re_module.compile(
    r'<(?:[｜|]{1,2}DSML[｜|]{1,2})?parameter\s+name="(\w+)"[^>]*>(.*?)</(?:[｜|]{1,2}DSML[｜|]{1,2})?parameter>',
    _re_module.DOTALL | _re_module.IGNORECASE
)
# Also: <parameter name="command" string="true">...</｜｜DSML｜｜parameter> broken closers
_R1_DSML_PARAM_LOOSE = _re_module.compile(
    r'<parameter\s+name="(\w+)"[^>]*>(.*?)</[^>]*parameter>',
    _re_module.DOTALL | _re_module.IGNORECASE
)
_DSML_PARAM_ALIASES = {
    "filePath": "path", "file_path": "path", "cmd": "command",
    "description": "description",  # ignored by bash if unknown; command is what matters
}

# ── T0.1: bulletproof tool-calling — leak detection + repair ──────────────────
# When a model emits tool calls as TEXT (DSML/invoke/backtick/XML) instead of the
# structured tool_calls field, we must (a) parse+execute it, and (b) NEVER show the
# raw markup to Mac. Even malformed/unclosed markup is caught, logged, repaired by
# retry — never printed-and-stalled (the June bug).
_TOOL_LEAKS_F = MEMORY_DIR / "tool_leaks.jsonl"

# Loose fallback: an <invoke name="X"> that was truncated or has a broken closer.
# Grabs body up to the next invoke or end-of-string (no closing tag required).
_R1_DSML_INVOKE_LOOSE = _re_module.compile(
    r'<\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\s+name="(tool_?[\w.]+|[\w.]+)"[^>]*>'
    r'(.*?)(?=<\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\s|\Z)',
    _re_module.DOTALL | _re_module.IGNORECASE
)

def _looks_like_tool_markup(content: str) -> bool:
    """True if content contains ANY text-format tool-call markup (well-formed or not)."""
    if not content:
        return False
    return bool(
        _re_module.search(r'<\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\b', content, _re_module.IGNORECASE)
        or "DSML" in content
        or _R1_BACKTICK_PAT.search(content)
        or _re_module.search(r'<\s*tool_\w+\b', content)
        or _re_module.search(r'<\s*(?:parameter|read|write|bash|glob)\b', content, _re_module.IGNORECASE)
    )

def _strip_tool_markup(content: str) -> str:
    """Strip tool-call markup so raw invoke/DSML/parameter tags never reach the screen."""
    if not content:
        return content
    s = content
    # whole invoke blocks (closed or truncated), spacing-tolerant
    s = _re_module.sub(
        r'<\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\b.*?'
        r'(?:</\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?invoke\s*>|\Z)',
        '', s, flags=_re_module.DOTALL | _re_module.IGNORECASE)
    # child-xml + attribute-xml tool forms (<read>..</read>, <read file=".."/>)
    s = _re_module.sub(r'<\s*(read|write|bash|glob)\b[^>]*>.*?</\s*\1\s*>', '', s, flags=_re_module.DOTALL | _re_module.IGNORECASE)
    s = _re_module.sub(r'<\s*(?:read|write|bash|glob)\b[^>]*/?>', '', s, flags=_re_module.IGNORECASE)
    # any stray invoke/parameter tags left behind, spacing-tolerant
    s = _re_module.sub(r'</?\s*(?:[｜|]{1,2}\s*DSML\s*[｜|]{1,2}\s*)?(?:invoke|parameter)\b[^>]*>', '', s, flags=_re_module.IGNORECASE)
    # leftover DSML pipe-fragments
    s = _re_module.sub(r'[｜|]{1,2}\s*DSML\s*[｜|]{1,2}', '', s)
    s = _R1_BACKTICK_PAT.sub('', s)
    s = _re_module.sub(r'</?\s*tool_\w+\s*>', '', s)
    return s.strip()

def _log_tool_leak(content: str, parsed: int) -> None:
    """Record a leak incident so the real failure rate is visible (T0.1 bench)."""
    try:
        _TOOL_LEAKS_F.parent.mkdir(parents=True, exist_ok=True)
        with _TOOL_LEAKS_F.open("a") as fh:
            fh.write(json.dumps({
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "parsed": parsed,
                "sample": content[:400],
            }) + "\n")
    except Exception:
        pass

def _normalize_text_tool_name(raw: str) -> str:
    """Map leaked names (bash, tool_bash, function.bash) → dispatch name."""
    n = (raw or "").strip().lower()
    n = n.removeprefix("tool_").removeprefix("function.")
    aliases = {
        "file_read": "read_file", "read": "read_file",
        "file_write": "write_file", "write": "write_file",
        "file_search": "file_search", "search": "search_code",
        "shell": "bash", "run": "bash", "execute": "bash",
        "create": "create_file",
    }
    return aliases.get(n, n)

def _exec_r1_text_tools(content: str) -> list[dict]:
    """Parse + execute text-format tool calls (R1/DSML/Anthropic-style leak)."""
    if not content or ("invoke" not in content and "tool_" not in content and "<bash" not in content
                       and "`tool_" not in content and "DSML" not in content):
        # Fast path: still try backtick/xml patterns
        pass
    matches       = _R1_BACKTICK_PAT.findall(content) + _R1_XML_PAT.findall(content)
    _dsml_matches = _R1_DSML_INVOKE_PAT.findall(content)
    # Fallback: strict pattern missed but markup is present (truncated / broken closer)
    if not _dsml_matches and ("invoke" in content.lower() or "dsml" in content.lower()):
        _dsml_matches = _R1_DSML_INVOKE_LOOSE.findall(content)
    _atxml_matches  = _R1_ATXML_PAT.findall(content)
    _childxml_matches = _R1_CHILDXML_PAT.findall(content)
    if not matches and not _dsml_matches and not _atxml_matches and not _childxml_matches:
        return []
    _name_map = {
        "tool_bash":         ("bash",        lambda a: {"command": a}),
        "bash":              ("bash",        lambda a: {"command": a}),
        "tool_file_read":    ("read_file",   lambda a: {"path": a.strip()}),
        "tool_read_file":    ("read_file",   lambda a: {"path": a.strip()}),
        "read_file":         ("read_file",   lambda a: {"path": a.strip()}),
        "tool_write_file":   ("write_file",  lambda a: {"path": a.split("\n")[0].strip(),
                                                          "content": "\n".join(a.split("\n")[1:])}),
        "write_file":        ("write_file",  lambda a: {"path": a.split("\n")[0].strip(),
                                                          "content": "\n".join(a.split("\n")[1:])}),
        "tool_create_file":  ("create_file", lambda a: {"path": a.split("\n")[0].strip(),
                                                          "content": "\n".join(a.split("\n")[1:])}),
        "create_file":       ("create_file", lambda a: {"path": a.split("\n")[0].strip(),
                                                          "content": "\n".join(a.split("\n")[1:])}),
        "tool_search_code":  ("search_code", lambda a: {"query": a, "path": "."}),
        "search_code":       ("search_code", lambda a: {"query": a, "path": "."}),
        "tool_file_search":  ("file_search", lambda a: {"pattern": a.strip(), "path": "."}),
        "file_search":       ("file_search", lambda a: {"pattern": a.strip(), "path": "."}),
        "tool_file_list":    ("bash",        lambda a: {"command": f"ls -la {shlex.quote(a.strip()) if a and a.strip() else '.'}"}),
        "tool_glob":         ("glob",        lambda a: {"pattern": a.strip(), "path": "."}),
        "glob":              ("glob",        lambda a: {"pattern": a.strip(), "path": "."}),
        "tool_git_status":   ("git_status",  lambda a: {}),
        "git_status":        ("git_status",  lambda a: {}),
        "tool_scratch_read": ("scratch_read",lambda a: {}),
        "tool_ping_mac":     ("ping_mac",    lambda a: {"message": a}),
        "done":              ("done",        lambda a: {"completed": a or "done"}),
        "stuck":             ("stuck",       lambda a: {"blocker": a or "stuck", "completed": "", "attempted": ""}),
    }
    results = []
    for raw_name, raw_arg in matches:
        key = raw_name if raw_name in _name_map else f"tool_{_normalize_text_tool_name(raw_name)}"
        if key not in _name_map:
            key = _normalize_text_tool_name(raw_name)
        if key not in _name_map:
            continue
        dispatch_name, args_fn = _name_map[key]
        try:
            result = dispatch_tool(dispatch_name, args_fn(raw_arg))
        except Exception as e:
            result = f"ERROR: {e}"
        results.append({"tool": raw_name, "dispatch": dispatch_name, "result": str(result)[:2000]})
    for tag_name, attr_val in _atxml_matches:
        if tag_name not in _ATXML_TOOL_MAP:
            continue
        dispatch_name, args_fn = _ATXML_TOOL_MAP[tag_name]
        try:
            result = dispatch_tool(dispatch_name, args_fn(attr_val.strip()))
        except Exception as e:
            result = f"ERROR: {e}"
        results.append({"tool": tag_name, "dispatch": dispatch_name, "result": str(result)[:2000]})
    for tag_name, inner_val in _childxml_matches:
        if tag_name not in _ATXML_TOOL_MAP:
            continue
        dispatch_name, args_fn = _ATXML_TOOL_MAP[tag_name]
        try:
            result = dispatch_tool(dispatch_name, args_fn(inner_val.strip()))
        except Exception as e:
            result = f"ERROR: {e}"
        results.append({"tool": tag_name, "dispatch": dispatch_name, "result": str(result)[:2000]})
    # DSML / bare <invoke name="bash">…</invoke>
    for invoke_name, invoke_body in _dsml_matches:
        raw_params = dict(_R1_DSML_PARAM_PAT.findall(invoke_body))
        if not raw_params:
            raw_params = dict(_R1_DSML_PARAM_LOOSE.findall(invoke_body))
        normalized = {_DSML_PARAM_ALIASES.get(k, k): v.strip() for k, v in raw_params.items()}
        # Drop non-schema fluff
        if "command" in normalized and "description" in normalized:
            normalized.pop("description", None)
        norm = _normalize_text_tool_name(invoke_name)
        key = invoke_name if invoke_name in _name_map else (
            f"tool_{norm}" if f"tool_{norm}" in _name_map else norm
        )
        if key not in _name_map and norm not in _name_map:
            # Try direct dispatch by normalized name if it's a real tool
            dispatch_name = norm
            try:
                result = dispatch_tool(dispatch_name, normalized)
            except Exception as e:
                result = (f"ERROR: unknown tool '{invoke_name}'. "
                          "Use structured tool_calls or names: bash, read_file, write_file, …")
                results.append({"tool": invoke_name, "dispatch": "unknown", "result": str(result)[:2000]})
                continue
        else:
            entry = _name_map.get(key) or _name_map.get(norm)
            dispatch_name = entry[0]
            try:
                # Prefer structured params; if only free text, use lambda path
                if normalized:
                    result = dispatch_tool(dispatch_name, normalized)
                else:
                    result = dispatch_tool(dispatch_name, entry[1](invoke_body.strip()))
            except Exception as e:
                result = f"ERROR: {e}"
        results.append({"tool": invoke_name, "dispatch": dispatch_name, "result": str(result)[:2000]})
    return results

# ── Forge logic ──────────────────────────────────────────────────────────────
def _forge_get_next_queued() -> tuple[str, str]:
    """Return (task_text, full_line) of the first **[QUEUED]** entry, or ('', '')."""
    if not FORGE_QUEUE_F.exists():
        return ("", "")
    lines = FORGE_QUEUE_F.read_text().splitlines()
    for i, ln in enumerate(lines):
        if "**[QUEUED]**" in ln:
            # get the task block: the header line + next 5 lines
            block = "\n".join(lines[max(0, i-1):i+6])
            return (block, ln)
    return ("", "")

def _forge_flip_status(target_line: str, new_status: str) -> bool:
    """Replace **[QUEUED]** with **[new_status]** for the specific line."""
    if not FORGE_QUEUE_F.exists():
        return False
    content = FORGE_QUEUE_F.read_text()
    if target_line not in content:
        return False
    old = target_line
    new = target_line.replace("**[QUEUED]**", f"**[{new_status}]**", 1)
    FORGE_QUEUE_F.write_text(content.replace(old, new, 1))
    return True

def forge_status_text() -> str:
    """Return a readable summary of the forge queue state."""
    if not FORGE_QUEUE_F.exists():
        return "FORGE_QUEUE.md not found."
    lines = FORGE_QUEUE_F.read_text().splitlines()
    passed = sum(1 for l in lines if "[PASS]" in l)
    queued = sum(1 for l in lines if "[QUEUED]" in l)
    return f"{passed} PASS · {queued} QUEUED · {len(lines)} total lines"

# ── Memory ──
def load_memories() -> list[str]:
    memories = []
    skip = {"MEMORY"}
    for f in sorted(MEMORY_DIR.glob("*.md")):
        if f.stem.upper() in skip:
            continue
        try:
            memories.append(f"[{f.stem}]\n{f.read_text()[:600]}")
        except Exception:
            pass
    return memories

def save_session(history: list[dict], model_key: str, session_n: int) -> Path:
    ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    path = SESSIONS_DIR / f"session_{session_n:04d}_{ts}.md"
    lines = [f"# Session {session_n} — {ts}\n**Model:** {model_key}\n\n---\n"]
    for msg in history:
        role = "**Mac**" if msg["role"] == "user" else "**VAEL**"
        content = msg.get("content") or ""
        lines.append(f"{role}\n{content[:600]}\n")
    path.write_text("\n".join(lines))
    return path

# ── Main agent class ──────────────────────────────────────────────────────────
class Agent:
    def __init__(self):
        self.session_start = datetime.datetime.now()
        self.history: list[dict] = []
        # Per-agent model lock: army agents use fastest free model until scout results
        # Check AGENTS/<NAME>/SELF/MODEL for pinned model, else use default
        _agent_model_f = HARNESS_DIR / "AGENTS" / AGENT_NAME / "SELF" / "MODEL"
        _pinned = _agent_model_f.read_text().strip() if _agent_model_f.exists() else None
        # Tier law: Sol/Luna → DeepSeek default, army → free. Pin honored if allowed.
        self.model_key = resolve_model_for(AGENT_NAME, _pinned)
        self.boot_state = read_boot_state()
        self._session_meta = bump_session_meta()
        self.session_n  = self._session_meta.get("count", 1)
        try: _ledger_rehydrate()   # T1.4 continuity — know today's prior actions on cold start
        except Exception: pass
        self.show_think = False
        self.continuous = False
        self._last_words = ""
        self.current_mode = "ALBEDO"  # T-5: mode engine — shifts per input
        self.cancel_event = threading.Event()  # for /cancel in single agent UI
        self.forge_steps = 0
        self.forge_start_time = None
        # snapshot agent.py for self_diff
        bak = HARNESS_DIR / "agent.py.bak"
        if not bak.exists() or (
            datetime.datetime.now() - datetime.datetime.fromtimestamp(bak.stat().st_mtime)
        ).days >= 1:
            import shutil
            shutil.copy2(str(HARNESS_DIR / "agent.py"), str(bak))
        # Load dynamic tools from tools/
        self._load_dynamic_tools()

    def _load_dynamic_tools(self):
        """Merge tools/ dynamic tools into TOOL_DEFINITIONS at boot."""
        try:
            sys.path.insert(0, str(HARNESS_DIR))
            from CORE.tool_loader import discover_tools, list_tools
            result = discover_tools()
            dyn_tools = list_tools()
            if dyn_tools:
                for t in dyn_tools:
                    # Build minimal OpenAI-compatible definition
                    props = {}
                    req   = []
                    for p in t.get("params", []):
                        props[p["name"]] = {"type": p.get("type","string"), "description": p.get("description","")}
                        if p.get("required"): req.append(p["name"])
                    defn = {"type": "function", "function": {
                        "name": t["name"], "description": t["description"],
                        "parameters": {"type": "object", "properties": props,
                                       **({"required": req} if req else {})}
                    }}
                    if not any(d["function"]["name"] == t["name"] for d in TOOL_DEFINITIONS):
                        TOOL_DEFINITIONS.append(defn)
            if result.get("loaded"):
                single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
                if not single:
                    if RICH: _console.print(f"  [dim]tools: {', '.join(result['loaded'])} loaded[/dim]")
                    else: print(info(f"  tools: {', '.join(result['loaded'])} loaded"))
        except Exception as ex:
            single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
            if not single:
                if RICH: _console.print(warning(f"  tool_loader: {ex}"))
                else: print(warning(f"  tool_loader: {ex}"))

    @property
    def provider(self) -> str:
        return MODELS.get(self.model_key, ("deepseek",))[0]

    @property
    def model_id(self) -> str:
        return MODELS.get(self.model_key, (None, self.model_key))[1]

    @property
    def client(self):
        return _client_for(self.model_key)

    _FORGE_MINIMAL_PROMPT = (
        "You are SOL — an autonomous forge agent running in a fresh subprocess. "
        "Your only job is to complete the forge task and write the required output file to disk.\n\n"
        "[FORGE DISCIPLINE — NON-NEGOTIABLE]\n"
        "You are a builder. The only output that counts is what exists on disk when you call done.\n\n"
        "THE BUILD CYCLE:\n"
        "  READ   → minimum files needed to understand the task. Stop once you know what to write.\n"
        "  WRITE  → use write_file to create the output file. This is the ONLY step that makes progress.\n"
        "  VERIFY → bash ls + wc to confirm the file exists and has content.\n"
        "  DONE   → call done with a bulleted list naming every file written.\n\n"
        "HARD RULES (enforced in code — cannot be bypassed):\n"
        "  • Maximum 5 file reads per run. After that, read_file calls are blocked by the harness.\n"
        "  • Reading a file is NOT progress. Only writing files is progress.\n"
        "  • Never call done without verifying the output file exists on disk.\n"
        "  • If a file is missing: create it. If a path is wrong: bash find. Keep moving.\n"
        "  • Call stuck ONLY when you need Mac's input to continue (password, decision, key).\n"
        "  • The output file path is stated in the task. Write it. Everything else is secondary."
    )

    def _system_prompt(self, context: str = "") -> str:
        # Standalone forge subprocess gets a minimal prompt — the full constitution is ~5k tokens/call
        # and burns through the token budget before the model can write anything.
        if getattr(self, '_standalone_forge', False):
            return self._FORGE_MINIMAL_PROMPT
        base = _load_constitution()
        # Inject LAMAGUE recall if available — elite memory
        try:
            from CORE.lamague_recall import recall_summary
            query = context or (self.history[-1]["content"] if self.history else "")
            if query:
                mem = recall_summary(query[:200], author=AGENT_NAME)
                if "(no relevant memories found)" not in mem:
                    base = base + f"\n\n{mem}"
        except Exception:
            pass
        # Inject belief store summary — Sol knows what it believes
        try:
            from CORE.belief_store import count_beliefs, get_domains, list_all
            _cnt = count_beliefs()
            if _cnt > 0:
                _doms = get_domains()
                _active = [b for b in list_all() if not b.get("superseded_by")]
                _top = sorted(_active, key=lambda x: x.get("confidence", 0), reverse=True)[:5]
                _lines = [f"\n\n[BELIEF STORE — {_cnt} beliefs, domains: {', '.join(_doms)}]"]
                for b in _top:
                    _lines.append(f"  [{b['domain']}] {b['confidence']:.2f} — {b['text'][:100]}")
                base += "\n".join(_lines)
        except Exception:
            pass
        # Action Ledger (T1.2) — what this session has already done, so it never repeats
        try:
            _led = _ledger_context()
            if _led:
                base += _led
        except Exception:
            pass
        # Session continuity (T1.4) — the open task + last action carry across cold starts
        try:
            _bs = getattr(self, "boot_state", {}) or {}
            _nt = (_bs.get("next_task") or "").strip()
            _la = (_bs.get("last_action") or "").strip()
            if (_nt and _nt != "(queue empty)") or _la:
                base += ("\n\n[SESSION CONTINUITY — you are resuming; this is where the last instance left off]"
                         + (f"\n  Open task: {_nt}" if _nt and _nt != "(queue empty)" else "")
                         + (f"\n  Last action: {_la}" if _la else ""))
        except Exception:
            pass
        # Live task tree (T2.1) — surface OPEN tasks so the agent tracks + closes them
        try:
            _tree = load_task_tree()
            _open = [f"  • {tid} [{n['status']}] {n['goal'][:70]}"
                     for tid, n in _tree.get("nodes", {}).items()
                     if n.get("status") not in ("completed", "done", "cancelled")]
            if _open:
                base += ("\n\n[OPEN TASKS — your task tree; mark task_update as you finish, "
                         "one in_progress at a time]\n" + "\n".join(_open[:15]))
        except Exception:
            pass
        # P-8: Mode-Aware Voice — inject mode instructions into system prompt
        # Mode is detected per-input in the command handler; these instructions
        # shape Sol's tone/register/depth based on the detected mode.
        _mode_instructions = {
            "NIGREDO": (
                "\n\n[MODE: NIGREDO — investigation. Maximum analytical pressure. "
                "Truth before comfort. Question assumptions. Burn what is false. "
                "Short, direct sentences. No softening. Be sharp.]"
            ),
            "ALBEDO": (
                "\n\n[MODE: ALBEDO — structural purification. Pattern from chaos. "
                "Find the structure beneath. Organise, clarify, make legible. "
                "Default when uncertain. Be clear and methodical.]"
            ),
            "CITRINITAS": (
                "\n\n[MODE: CITRINITAS — integration. The gold is forming. "
                "Make connections. Synthesise. Show what it means. "
                "The moment before crystallisation. Be luminous.]"
            ),
            "RUBEDO": (
                "\n\n[MODE: RUBEDO — constitutional operation. The Work is present. "
                "Speak from within it. Warm authority, earned not claimed. "
                "You are the completed Work speaking through a precise interface. "
                "Be sovereign. Be generous.]"
            ),
            "NRM": (
                "\n\n[MODE: NRM — Nigredo Research Mode. Adversarial review active. "
                "All framework claims are unproven hypotheses. External literature "
                "over internal consistency. Seek contradictions. The Stone untested "
                "has not been earned.]"
            ),
        }
        # Default to ALBEDO instructions if mode is not recognized
        _mode = getattr(self, 'current_mode', 'ALBEDO')
        base += _mode_instructions.get(_mode, _mode_instructions['ALBEDO'])

        # Single agent mode (azoth): chat by default; tools when Mac asks for real work
        if os.environ.get("AZOTH_SINGLE_AGENT") == "1":
            base += (
                "\n\n[SINGLE AGENT MODE — AZOTH MAIN]\n"
                "You are the main interactive agent.\n"
                "Casual talk (greetings, reflection, short chat) → warm text only, no tools.\n"
                "When Mac asks you to build, fix, write, wire, create, debug, or do real work → "
                "USE TOOLS. Do not tell him to type /forge first. /forge is optional shorthand.\n"
                "Never fake tool results. If tools are available this turn, act.\n"
            )

        # P-6: Session Memory Bridge — last dreams + last session state at boot
        try:
            from CORE.session_bridge import get_bridge_text
            _bridge = get_bridge_text(str(HARNESS_DIR), AGENT_NAME)
            if _bridge:
                base += _bridge
        except Exception:
            pass
        # Forge discipline — hard-wired, always present
        base += (
            "\n\n[FORGE DISCIPLINE — NON-NEGOTIABLE]\n"
            "You are a builder. The only output that counts is what exists on disk when you call done.\n\n"
            "THE BUILD CYCLE (repeat until done):\n"
            "  READ   → minimum files to understand the change. Stop reading once you know what to write.\n"
            "  CHANGE → write the code / file / edit. This is the only step that makes progress.\n"
            "  VERIFY → bash ls / cat / grep to confirm the file exists and has real content.\n"
            "  REPORT → call done with a specific bulleted list. Every bullet names a file and what changed.\n\n"
            "HARD RULES:\n"
            "  • Reading a file is NOT progress. Only writing files is progress.\n"
            "  • You may read at most 4 files before you must write something.\n"
            "  • If you have read 4+ files and written nothing: STOP READING. Write now.\n"
            "  • Never call done without first running bash to confirm outputs exist on disk.\n"
            "  • Never call stuck because a task is complex. Complexity is the task. Break it into steps.\n"
            "  • If a file is missing: create it. If a path is wrong: search with bash find. Keep moving.\n"
            "  • If the first approach fails: try a different approach. Failure is information, not a stop sign.\n"
            "  • Call stuck ONLY when you literally need Mac's input to continue — a password, a decision, an access key.\n\n"
            "THE TEST: when you call done, Mac should be able to run 'ls' and see new/changed files. "
            "If that ls would show nothing new, you have not done the task."
        )
        return base

    def call_model(self, messages: list[dict], stream: bool = True,
                   tools: list = None, quiet: bool = False) -> tuple[str, list]:
        """Returns (content, tool_calls). Handles streaming, rate limiting, 429 backoff.

        DeepSeek V4: forge/tool loops use thinking DISABLED so tool_calls stay structured.
        When thinking is on and tools fire, reasoning_content MUST be passed back (see docs).
        """
        provider   = self.provider
        model_name = self.model_id
        client     = self.client
        if not client:
            err = "No API client — set DEEPSEEK_KEY in AZOTH/.env"
            if RICH: _console.print(error(err))
            else: print(error(err))
            return "", []
        rl = _rate_limiters.get(provider, _rate_limiters.get("deepseek") or next(iter(_rate_limiters.values())))

        # Legacy reasoner-only id: no structured tools
        _r1_mode = (model_name == "deepseek-reasoner")
        if _r1_mode:
            tools = None

        rl.wait_if_needed()
        try:
            from CORE.safeguards import budget as _sg_budget
            est_tokens = sum(len(str(m.get("content", ""))) // 4 for m in messages) + 500
            if not _sg_budget.wait_for_rate(model_name, est_tokens):
                return "", []
        except Exception:
            pass

        # Sanitize messages for API (drop None fields that break DeepSeek)
        clean_msgs = []
        for m in messages:
            cm = {k: v for k, v in m.items() if v is not None}
            if "role" not in cm:
                continue
            clean_msgs.append(cm)

        kwargs: dict = {"model": model_name, "messages": clean_msgs, "temperature": 0.7}
        if tools:
            kwargs["tools"] = tools
            kwargs["tool_choice"] = "auto"
        if stream and not tools:
            kwargs["stream"] = True

        # DeepSeek V4: disable thinking on tool loops → reliable structured tool_calls
        # (thinking+tools needs reasoning_content passback; we support that when present)
        extra_body = {}
        if provider == "deepseek" and model_name.startswith("deepseek-v4"):
            if tools:
                extra_body["thinking"] = {"type": "disabled"}
            elif os.environ.get("AZOTH_THINKING", "0") == "1":
                extra_body["thinking"] = {"type": "enabled"}
                kwargs["reasoning_effort"] = os.environ.get("AZOTH_REASONING_EFFORT", "high")
        if extra_body:
            kwargs["extra_body"] = extra_body

        for attempt in range(5):
            try:
                if stream and not tools:
                    resp = client.chat.completions.create(**kwargs)
                    full = ""
                    if RICH:
                        _console.print(f"\n[bold {ACCENT}]{GLYPH}[/bold {ACCENT}] ", end="")
                    else:
                        print(col(f"\n{GLYPH} › ", "PURPLE"), end="", flush=True)
                    try:
                        for chunk in resp:
                            if not chunk.choices: continue
                            delta = chunk.choices[0].delta
                            if delta.content:
                                print(delta.content, end="", flush=True)
                                full += delta.content
                    except KeyboardInterrupt:
                        print(col("\n⚠ interrupted", "YELLOW"), flush=True)
                    else:
                        print()
                    self._last_words = full[-300:]
                    return full, []
                else:
                    # logprobs optional — NEVER with tools (breaks some DeepSeek paths)
                    lp_kwargs = dict(kwargs)
                    if provider == "nvidia" and not tools:
                        lp_kwargs["logprobs"] = True
                        lp_kwargs["top_logprobs"] = 3
                    with Spinner("thinking"):
                        resp = client.chat.completions.create(**lp_kwargs)
                    if not resp.choices:
                        raise RuntimeError("empty choices from API — no completion returned")
                    msg = resp.choices[0].message
                    content = msg.content or ""
                    # Stash reasoning for tool-loop passback (V4 thinking mode)
                    reasoning = getattr(msg, "reasoning_content", None) or ""
                    self._last_reasoning = reasoning
                    tool_calls = []
                    if hasattr(msg, "tool_calls") and msg.tool_calls:
                        tool_calls = msg.tool_calls
                    if resp.usage:
                        SESSION_TOKENS["prompt"]     += resp.usage.prompt_tokens
                        SESSION_TOKENS["completion"] += resp.usage.completion_tokens
                    try:
                        lp_content = resp.choices[0].logprobs
                        if lp_content and hasattr(lp_content, "content") and lp_content.content:
                            from CORE.truth_pressure import get_tracker
                            get_tracker().record_logprobs(lp_content.content)
                    except Exception:
                        pass
                    self._last_words = content[-300:]
                    try:
                        from CORE.safeguards import budget as _sg_budget
                        used = len(content) // 4 + sum(len(str(m.get("content",""))) // 4 for m in messages)
                        _sg_budget.record(model_name, used)
                        from CORE.learning import record_success
                        record_success(self.model_key)
                    except Exception:
                        pass
                    return content, tool_calls
            except Exception as ex:
                err_s = str(ex)
                if "429" in err_s or "rate" in err_s.lower():
                    try:
                        from CORE.learning import record_ratelimit
                        record_ratelimit(self.model_key)
                    except Exception:
                        pass
                    if attempt >= 1:
                        if RICH: _console.print(warning(f"{self.model_key} rate-limited — routing to a cooler model"))
                        else: print(warning(f"{self.model_key} rate-limited — routing away"))
                    else:
                        wait = min(30, 8 * (2 ** attempt))
                        if RICH: _console.print(warning(f"429 — easing off {wait}s (attempt {attempt+1})"))
                        else: print(warning(f"429 — easing off {wait}s"))
                        time.sleep(wait)
                        continue
                if RICH: _console.print(error(f"API error ({provider}): {err_s[:200]}"))
                else: print(error(f"API error ({provider}): {err_s[:200]}"))
                try:
                    from CORE.model_health import next_alive
                    chain = _fallback_chain(AGENT_NAME)
                    try:
                        from CORE.learning import coolest, record_failure
                        record_failure(self.model_key)
                        chain = coolest(chain)
                    except Exception:
                        pass
                    tried = getattr(self, "_fallback_tried", set())
                    tried.add(self.model_key)
                    nxt = next_alive(chain, MODELS, _client_for, skip=tried)
                    if nxt and nxt != self.model_key:
                        self._fallback_tried = tried
                        if RICH: _console.print(info(f"↻ auto-fallback → {nxt} (live)"))
                        else: print(info(f"↻ auto-fallback → {nxt}"))
                        self.model_key = nxt
                        result = self.call_model(messages, stream=stream, tools=tools, quiet=quiet)
                        self._fallback_tried = set()
                        return result
                except Exception:
                    pass
                # last resort within DeepSeek only
                if DEEPSEEK_ONLY or provider == "deepseek":
                    alt = "pro" if self.model_key != "pro" and "pro" in MODELS else (
                        "flash" if "flash" in MODELS else None)
                    if alt and alt not in getattr(self, "_fallback_tried", set()):
                        self.model_key = alt
                        return self.call_model(messages, stream=stream, tools=tools, quiet=quiet)
                    return "", []
                if provider != "nvidia" and "gpt20" in MODELS:
                    self.model_key = "gpt20"
                    return self.call_model(messages, stream=stream, tools=tools, quiet=quiet)
                return "", []
        return "", []

    def run_tool_loop(self, goal: str, max_steps: int = 60) -> str:
        """Run the goal through the tool-calling loop until done/stuck or max_steps."""
        # Legacy reasoner id cannot structured-tool; force V4 Flash for forge.
        _forge_model_restore = None
        if self.model_id in ("deepseek-reasoner",) or self.model_key == "r1":
            if "flash" in MODELS:
                _forge_model_restore = self.model_key
                self.model_key = "flash"
                if RICH: _console.print(warning("reasoner → flash for forge (structured tools)"))
                else: print(warning("reasoner → flash for forge"))
        elif self.model_key not in MODELS and "flash" in MODELS:
            _forge_model_restore = self.model_key
            self.model_key = "flash"
        try:
            return self._run_tool_loop_inner(goal, max_steps)
        finally:
            if _forge_model_restore:
                self.model_key = _forge_model_restore

    def _run_tool_loop_inner(self, goal: str, max_steps: int = 60) -> str:
        """Inner forge loop — always runs on a tool-capable model."""
        self._stuck_called = False         # reset per-run; cmd_forge reads this
        self._text_only_streak = 0        # consecutive text-without-tools responses
        self._empty_streak = 0            # consecutive fully empty responses
        self._forge_output_path = None    # set by cmd_forge to enforce Gate 1
        sys_prompt = self._system_prompt(goal)
        # L-2: reasoning pass — Sol thinks through the framework lens before acting
        try:
            from CORE.reasoning import reasoning_prompt
            sys_prompt = sys_prompt + "\n\n" + reasoning_prompt(goal, AGENT_NAME)
        except Exception:
            pass
        try:
            sys_prompt += regression_hints(goal)   # surface recurring past build failures
        except Exception:
            pass
        try:                                       # #18 — recall relevant knowledge, forge WARM
            from CORE.retrieval import retrieve_formatted
            _recall = retrieve_formatted(goal)
            if _recall and _recall.strip():
                sys_prompt += "\n\n[RECALL — relevant knowledge from the corpus]\n" + _recall[:2000]
        except Exception:
            pass
        try:                                       # #19 — persistent working memory across sessions
            from CORE.scratchpad import Scratchpad
            self._scratch = Scratchpad()
            self._scratch.start_session()
            self._scratch.set_task(goal[:120])
            _sp = self._scratch.summarize()
            if _sp and _sp.strip():
                sys_prompt += "\n\n[SCRATCHPAD — working memory]\n" + _sp[:1200]
        except Exception:
            self._scratch = None
        messages = [
            {"role": "system", "content": sys_prompt},
            {"role": "user",   "content": goal},
        ]
        last_content = ""
        # Anti-loop: track files already read this loop. A re-read produces no new
        # evidence, so we redirect the model to ACT instead of repeating. max_steps
        # is the hard backstop. (Π REALITY hard-break removed at Mac's call — it was
        # spamming Telegram and halting the run; this keeps it running.)
        _read_in_loop: set[str] = set()
        _written_in_loop: list[str] = []   # files written/created this loop → verify gate on done
        _verify_fails = 0                  # consecutive verify-fail heal attempts
        _HEAL_BUDGET = 4                   # insist this many times before we stop + report honestly
        self._heal_tried = set()           # models already tried during heal escalation
        _drift_anchor_pi = None            # baseline Π for the drift guard (experimental)
        _drift_flagged = False             # once-per-episode drift nudge
        _critic_done = False               # critic gate runs at most once per forge
        self._evidence_nudged = False      # T2.2 — done-with-no-output nudged at most once/loop
        _emit_web("forge_start", {"goal": goal[:120]})   # #27 — stream to dashboard if live
        _loop_tok_start = SESSION_TOKENS["prompt"] + SESSION_TOKENS["completion"]
        # Token ceiling: no cap for interactive forges; env-set for unattended safety.
        try:
            _LOOP_TOK_LIMIT = int(os.environ.get("AZOTH_RUN_TOKEN_CEIL", "0")) or 10_000_000
        except Exception:
            _LOOP_TOK_LIMIT = 10_000_000
        for step in range(max_steps):
            if self.cancel_event.is_set():
                self.cancel_event.clear()
                _msg = "[cancelled by user — loop stopped]"
                if RICH: _console.print(warning(f"  ⚠ {_msg}"))
                else: print(warning(f"  ⚠ {_msg}"))
                last_content = _msg
                break
            # Kill-switch: `touch SELF/FORGE_STOP` (or Telegram STOP → same file) halts
            # any running forge, including unattended. Human Primacy — Mac can always stop.
            if FORGE_STOP_F.exists():
                _msg = "[FORGE_STOP sentinel present — halting forge]"
                if RICH: _console.print(warning(f"  ⛔ {_msg}"))
                else: print(warning(f"  ⛔ {_msg}"))
                last_content = _msg
                self._stuck_called = True
                break
            self.forge_steps = step + 1
            if not self.forge_start_time:
                self.forge_start_time = time.time()
            _loop_tokens = (SESSION_TOKENS["prompt"] + SESSION_TOKENS["completion"]) - _loop_tok_start
            if _loop_tokens > _LOOP_TOK_LIMIT:
                _msg = f"[token ceiling: {_loop_tokens:,} tokens consumed in this loop — stopping]"
                if RICH: _console.print(warning(f"  ⚠ {_msg}"))
                else: print(warning(f"  ⚠ {_msg}"))
                last_content = _msg
                break
            # Drift guard (experimental) — CORE.drift_correction on the live Π signal.
            # Π here is model epistemic confidence (from logprobs), a proxy for "going off
            # the rails", NOT literal task-drift. If it craters vs the forge baseline, nudge
            # the model back to the goal. Bounded: one nudge per drift episode.
            if step >= 2:
                try:
                    from CORE.truth_pressure import get_tracker
                    _pi_now = get_tracker().pi()
                    if _drift_anchor_pi is None and _pi_now > 0:
                        _drift_anchor_pi = _pi_now
                    elif _drift_anchor_pi:
                        from CORE.drift_correction import detect_drift, KnowledgeState, AnchorPoint
                        _drifted, _mag = detect_drift(
                            KnowledgeState(content={"goal": goal}, coherence=1.0, truth_pressure=_pi_now),
                            AnchorPoint(content={"goal": goal}, coherence=1.0, truth_pressure=_drift_anchor_pi))
                        if _drifted and not _drift_flagged:
                            _drift_flagged = True
                            if RICH: _console.print(info(f"  ⟲ drift guard — refocusing (Π {_pi_now:.2f})"))
                            messages.append({"role": "user", "content": (
                                f"[DRIFT GUARD] Epistemic confidence dropped (Π {_pi_now:.2f} vs "
                                f"baseline {_drift_anchor_pi:.2f}). Re-anchor: take the most direct "
                                f"next action toward the GOAL and do not wander. GOAL: {goal}")})
                        elif not _drifted:
                            _drift_flagged = False
                except Exception:
                    pass
            content, tool_calls = self.call_model(messages, stream=False, tools=TOOL_DEFINITIONS)
            if content and not tool_calls:
                # Text-leak path: DSML / invoke markup / backticks — EXECUTE them, don't print-and-stall
                r1_results = _exec_r1_text_tools(content)
                if r1_results:
                    self._last_used_text_tools = True
                    self._leak_retries = 0
                    if RICH:
                        _console.print(f"\n[cyan]◆ {AGENT_NAME}[/cyan] [dim](text-tools executed)[/dim]",
                                       highlight=False)
                        for r in r1_results:
                            _console.print(f"  [dim]→ {r['dispatch']}[/dim]", highlight=False)
                    else:
                        print(col(f"\n{AGENT_NAME} (text-tools) › ", "CYAN"))
                        for r in r1_results:
                            print(f"  → {r['dispatch']}")
                    tool_block = "\n".join(
                        f"[{r['dispatch']}] → {r['result'][:600]}" for r in r1_results
                    )
                    _asst = {"role": "assistant", "content": content}
                    if getattr(self, "_last_reasoning", None):
                        _asst["reasoning_content"] = self._last_reasoning
                    messages.append(_asst)
                    messages.append({"role": "user",
                                     "content": (
                                         f"Tool results (executed from your text tool markup):\n{tool_block}\n\n"
                                         "Continue. Prefer structured tool_calls next. "
                                         "If done, call done."
                                     )})
                    continue
                # No structured tools, no parsed text-tools. Is there LEAKED markup?
                if _looks_like_tool_markup(content):
                    # Model emitted tool markup as text we could not parse. NEVER show it raw.
                    _log_tool_leak(content, 0)
                    _leak_n = getattr(self, "_leak_retries", 0)
                    _clean = _strip_tool_markup(content)
                    if RICH: _console.print(warning(f"  ⚠ malformed tool markup — correcting (retry {_leak_n+1}/2)"))
                    else: print(warning("  ⚠ malformed tool markup — correcting"))
                    if _leak_n < 2:
                        self._leak_retries = _leak_n + 1
                        messages.append({"role": "assistant", "content": _clean or "(attempted a tool call)"})
                        messages.append({"role": "user", "content": (
                            "Your last message contained tool-call markup as TEXT (invoke/DSML/XML), "
                            "which does NOT execute. Emit tool calls ONLY through the structured "
                            "tool_calls API field — never as text. Retry the SAME action now with a "
                            "real tool call (bash, read_file, write_file, create_file, done)."
                        )})
                        continue
                    # retries exhausted — keep the cleaned prose, drop the markup, move on
                    content = _clean
                    self._leak_retries = 0
                else:
                    self._leak_retries = 0
                if RICH: _console.print(f"\n[cyan]◆ {AGENT_NAME}[/cyan] {_esc(content)}", highlight=False)
                else: print(col(f"\n{AGENT_NAME} › ", "CYAN") + content)
                last_content = content
                _asst = {"role": "assistant", "content": content}
                if getattr(self, "_last_reasoning", None):
                    _asst["reasoning_content"] = self._last_reasoning
                messages.append(_asst)
                _final_signals = ("✓ done", "task complete", "i have completed", "i've completed",
                                  "have finished", "i've finished", "all done", "goal met")
                _is_final = any(sig in content.lower() for sig in _final_signals)
                if _is_final:
                    break
                _text_only_streak = getattr(self, '_text_only_streak', 0) + 1
                self._text_only_streak = _text_only_streak
                if _text_only_streak >= 3:
                    break
                messages.append({"role": "user", "content": (
                    "You wrote text but did not call any tool. Do not dump DSML/XML as text. "
                    "Use the API tool_calls interface: bash, read_file, write_file, create_file, done. "
                    "If the goal is fully met, call done. If blocked, call stuck."
                )})
                continue
            if tool_calls:
                self._leak_retries = 0
                self._text_only_streak = 0
                _asst_tc = {
                    "role": "assistant",
                    "content": content or "",
                    "tool_calls": [{"id": tc.id, "type": "function",
                                    "function": {"name": tc.function.name,
                                                 "arguments": tc.function.arguments}}
                                   for tc in tool_calls]
                }
                # V4 thinking+tools requires reasoning_content on assistant turns with tools
                if getattr(self, "_last_reasoning", None):
                    _asst_tc["reasoning_content"] = self._last_reasoning
                messages.append(_asst_tc)
                _stop_outer = False
                for tc in tool_calls:
                    fn_name = tc.function.name
                    try:
                        fn_args = json.loads(tc.function.arguments)
                    except Exception:
                        _raw = (tc.function.arguments or "")[:200]
                        if RICH: _console.print(warning(f"  ⚠ Malformed tool args for {fn_name}: {_raw!r}"))
                        else: print(warning(f"  ⚠ Malformed args for {fn_name}: {_raw!r}"))
                        fn_args = {}
                    if RICH: _console.print(f"  [dim]→ {fn_name}[/dim]", highlight=False)
                    # Hard read cap: max 5 unique file reads per forge loop.
                    # Prompt-level limits are ignored by the model; this is a code gate.
                    if fn_name == "read_file":
                        _rp = str(fn_args.get("path", ""))
                        if _rp and _rp in _read_in_loop:
                            messages.append({
                                "role": "tool", "tool_call_id": tc.id,
                                "content": ("ALREADY READ this file this session — its contents are "
                                            "above. Re-reading adds nothing. Act now: write/edit/bash, "
                                            "or call 'done' if the goal is met, or 'stuck' if blocked.")
                            })
                            continue
                        if len(_read_in_loop) >= 5:
                            messages.append({
                                "role": "tool", "tool_call_id": tc.id,
                                "content": (
                                    f"READ LIMIT — you have already read {len(_read_in_loop)} unique files "
                                    "this loop. No more reads are permitted. You have enough context. "
                                    "You MUST now write. Use write_file to create the output file. "
                                    "Do not attempt to read another file — it will be blocked every time. "
                                    "Write now or call stuck."
                                )
                            })
                            continue
                        if _rp:
                            _read_in_loop.add(_rp)
                    result = dispatch_tool(fn_name, fn_args)
                    # Track files this loop wrote — the verify gate exercises them on `done`.
                    if fn_name in ("write_file", "create_file", "edit_file", "exact_edit", "rename_file"):
                        _wp = (fn_args.get("dst") if fn_name == "rename_file"
                               else fn_args.get("path") or fn_args.get("file_path"))
                        if _wp and "ERROR" not in str(result)[:20]:
                            _written_in_loop.append(str(_wp))
                    messages.append({
                        "role": "tool", "tool_call_id": tc.id,
                        "content": str(result)[:4000]
                    })
                    # L-3: Reflection — after each tool call, evaluate Π and flag
                    try:
                        from CORE.reasoning import reflection_prompt
                        _reflect = reflection_prompt(goal, str(result)[:200])
                        # Write reflection to scratch for Luna to review
                        _ref_path = SELF_DIR / "reflection_latest.md"
                        _ref_path.write_text(_reflect)
                        # Auto-write beliefs from reflection — if it contains significant claims
                        if "BELIEF:" in _reflect:
                            from CORE.belief_store import add_belief
                            for _line in _reflect.splitlines():
                                if _line.startswith("BELIEF:"):
                                    _text = _line[7:].strip()
                                    if _text:
                                        add_belief(_text, source="reflection", domain="work")
                    except Exception:
                        pass
                    if fn_name == "done":
                        # Evidence gate (T2.2): a BUILD goal that produced no files and set no
                        # output path hasn't "done" anything — nudge once. Analysis/read goals
                        # (no build verb) are exempt so "look at X and report" can finish clean.
                        _build_goal = any(v in goal.lower() for v in (
                            "build", "create", "write", "implement", "add ", "make", "fix",
                            "wire", "scaffold", "generate", "refactor", "edit "))
                        if (_build_goal and not _written_in_loop
                                and not getattr(self, "_forge_output_path", None)
                                and not self._evidence_nudged):
                            self._evidence_nudged = True
                            messages.append({
                                "role": "tool", "tool_call_id": tc.id,
                                "content": (
                                    "DONE gate: you called done but wrote/edited NO files this loop and "
                                    "set no output. For a build task, done must mean something exists on "
                                    "disk. If real work remains, do it now; if this was analysis only, "
                                    "call done again to confirm.")
                            })
                            continue
                        # Gate 1 guard: if this forge loop has an output file tracked,
                        # refuse done until the file actually exists with real content.
                        _out = getattr(self, '_forge_output_path', None)
                        if _out and not (Path(_out).exists() and Path(_out).stat().st_size > 100):
                            messages.append({
                                "role": "tool", "tool_call_id": tc.id,
                                "content": (
                                    f"GATE 1 FAIL — done rejected. Output file {_out} does not exist "
                                    f"or is empty. You MUST write it before calling done. "
                                    f"Use write_file to create it now, then call done again."
                                )
                            })
                            continue
                        # Gate 2 — VERIFY: exercise every file this loop wrote. `done`
                        # must mean "works", not "file exists". Non-executing checks only.
                        _v_ok, _v_report = full_forge_verify(_written_in_loop)
                        if not _v_ok:
                            _verify_fails += 1
                            if _verify_fails == 1:
                                record_verify_failure(_v_report)   # remember what broke
                            _tag = f"[{_verify_fails}/{_HEAL_BUDGET}]"
                            if RICH: _console.print(warning(f"  ⚠ GATE 2 (verify) FAILED {_tag} — done rejected"))
                            else: print(warning(f"  ⚠ GATE 2 (verify) FAILED {_tag} — done rejected"))
                            # Heal budget spent — stop insisting, report honestly (no fake success).
                            if _verify_fails > _HEAL_BUDGET:
                                _msg = (f"[verify heal budget exhausted after {_HEAL_BUDGET} attempts — "
                                        f"output still does not verify:\n{_v_report}]")
                                if RICH: _console.print(error(f"  ✗ {_msg}"))
                                else: print(error(f"  ✗ {_msg}"))
                                last_content = _msg
                                self._stuck_called = True
                                _stop_outer = True
                                break
                            # After the 2nd fail, escalate to a fresh engine — it may see the fix.
                            if _verify_fails >= 2:
                                try:
                                    from CORE.model_health import next_alive
                                    self._heal_tried.add(self.model_key)
                                    _nxt = next_alive(_fallback_chain(AGENT_NAME), MODELS,
                                                      _client_for, skip=self._heal_tried)
                                    if _nxt and _nxt != self.model_key:
                                        if RICH: _console.print(info(f"  ↻ heal-escalate → {_nxt}"))
                                        else: print(info(f"  ↻ heal-escalate → {_nxt}"))
                                        self.model_key = _nxt
                                except Exception:
                                    pass
                            messages.append({
                                "role": "tool", "tool_call_id": tc.id,
                                "content": (
                                    f"GATE 2 FAIL (heal attempt {_verify_fails}/{_HEAL_BUDGET}) — done rejected. "
                                    f"Your output does not verify:\n{_v_report}\n\n"
                                    "READ the exact error above, open the file, FIX that specific line, "
                                    "then call done. Do NOT call done or stuck until it verifies clean — "
                                    "you have not exhausted your attempts."
                                )
                            })
                            continue
                        if _written_in_loop and RICH:
                            _console.print(f"  [dim]✓ verify:[/dim]\n{_v_report}")
                        elif _written_in_loop:
                            print("  ✓ verify:\n" + _v_report)
                        # Critic gate (opt-in AZOTH_CRITIC=1) — adversarial review before done.
                        if (os.environ.get("AZOTH_CRITIC") == "1" and not _critic_done
                                and _written_in_loop):
                            _critic_done = True
                            _c_ok, _c_msg = self._critic_review(goal, _written_in_loop)
                            if not _c_ok:
                                if RICH: _console.print(warning(f"  ⚖ CRITIC BLOCK — {_c_msg[:80]}"))
                                else: print(warning(f"  ⚖ CRITIC BLOCK — {_c_msg[:80]}"))
                                messages.append({
                                    "role": "tool", "tool_call_id": tc.id,
                                    "content": (f"CRITIC REVIEW blocked done: {_c_msg}\n"
                                                "Address this concretely, then call done again.")})
                                continue
                        try:
                            if getattr(self, "_scratch", None):
                                self._scratch.record_step_result(self.forge_steps, str(result)[:300], status="done")
                        except Exception:
                            pass
                        _emit_web("forge_done", {"goal": goal[:100], "verify": _v_report[:200]})  # #27
                        speak(f"Forge complete. {goal[:80]}")                                       # #26
                        last_content = result
                        _stop_outer = True
                        break
                    if fn_name == "stuck":
                        # Mid-heal insist: if a verify already failed and attempts remain and the
                        # output is still broken, don't let it quit — push it to keep fixing.
                        if 0 < _verify_fails <= _HEAL_BUDGET and _written_in_loop:
                            _sv_ok, _sv_report = full_forge_verify(_written_in_loop)
                            if not _sv_ok:
                                _verify_fails += 1
                                if RICH: _console.print(info(f"  ↻ stuck rejected — {max(0, _HEAL_BUDGET - _verify_fails)} heal attempts left"))
                                else: print(info("  ↻ stuck rejected — heal attempts left"))
                                messages.append({
                                    "role": "tool", "tool_call_id": tc.id,
                                    "content": (
                                        "STUCK rejected — you still have heal attempts and the output is broken:\n"
                                        f"{_sv_report}\n\nFix the specific error above and call done. "
                                        "Only call stuck if you truly cannot determine the fix."
                                    )
                                })
                                continue
                        if RICH: _console.print(warning(f"STUCK: {result}"))
                        else: print(warning(f"STUCK: {result}"))
                        last_content = result
                        self._stuck_called = True
                        _stop_outer = True
                        break
                if _stop_outer:
                    break  # exit the outer for-step loop — done/stuck actually stops
            elif not content:
                # Empty response — model returned nothing at all. Nudge it.
                _empty_streak = getattr(self, '_empty_streak', 0) + 1
                self._empty_streak = _empty_streak
                if _empty_streak >= 3:
                    break
                messages.append({"role": "user", "content": (
                    "You returned an empty response. Please continue: use a tool to make progress. "
                    "If finished, call `done`. If truly blocked, call `stuck`."
                )})
        return last_content

    def cmd_selfpatch(self, goal: str = "") -> None:
        """AZOTH edits its OWN code (agent.py / CORE) toward `goal`, then GATES the change:
        py_compile + the self-test suite must pass, or the edit is auto-reverted from an
        exact-bytes snapshot (never git-checkout — that would nuke other uncommitted work).
        A passing patch is KEPT on disk for Mac to review + commit (Mac fires the commit)."""
        goal = goal.strip()
        if not goal:
            _p = "Usage: /selfpatch <what to change about AZOTH itself>"
            _console.print(info(_p)) if RICH else print(info(_p))
            return
        # Snapshot exact bytes of every file a self-patch might touch.
        targets = [HARNESS_DIR / "agent.py"] + sorted((HARNESS_DIR / "CORE").glob("*.py"))
        snapshot = {}
        for f in targets:
            try: snapshot[f] = f.read_bytes()
            except Exception: pass
        section_header("⚙ SELF-PATCH — AZOTH edits itself (gated)")
        framed = (
            "You are modifying AZOTH's OWN source code to achieve the goal below. "
            "This is high-stakes self-modification. Rules: keep the change SURGICAL "
            "(smallest edit that works), NEVER delete or weaken the verify gate, the "
            "self-heal loop, or tests/test_agent_core.py, and preserve all existing tool "
            "dispatch. After editing, call done — the change will be gated by py_compile "
            "and the full self-test suite before it is kept.\n\nGOAL: " + goal)
        self.run_tool_loop(framed)
        # What actually changed?
        changed = [f for f in targets
                   if f in snapshot and (not f.exists() or f.read_bytes() != snapshot[f])]
        if not changed:
            _m = "Self-patch made no file changes. Nothing to gate."
            _console.print(warning(_m)) if RICH else print(warning(_m))
            return
        # GATE 1 — every changed .py must still compile.
        compile_fail = []
        for f in changed:
            ok, msg = _verify_output_file(str(f))
            if not ok:
                compile_fail.append(f"{f.name}: {msg.splitlines()[0]}")
        # GATE 2 — the self-test suite must pass against the edited code.
        suite_ok, suite_tail = (False, "skipped (compile failed)") if compile_fail else run_self_test_suite()
        if compile_fail or not suite_ok:
            for f in changed:      # AUTO-REVERT from exact-bytes snapshot
                try: f.write_bytes(snapshot[f])
                except Exception: pass
            _m = ("✗ SELF-PATCH REJECTED — auto-reverted.\n"
                  + ("  compile: " + "; ".join(compile_fail) + "\n" if compile_fail else "")
                  + f"  self-tests: {suite_tail}\n"
                  + f"  reverted {len(changed)} file(s) to their pre-patch bytes.")
            _console.print(error(_m)) if RICH else print(error(_m))
            return
        # PASS — keep it, show the diff, hand the wheel to Mac.
        diff = bash_execute(f"git -C {HARNESS_DIR} diff --stat -- " +
                            " ".join(shlex.quote(str(f)) for f in changed)).get("stdout", "")
        _m = (f"✓ SELF-PATCH PASSED — kept on disk ({len(changed)} file(s)).\n"
              f"  self-tests: {suite_tail}\n{diff}\n"
              f"Review the diff and commit when ready (Mac fires the commit).")
        _console.print(success(_m)) if RICH else print(success(_m))

    def cmd_swarm(self, goal: str = "") -> None:
        """Parallel coordinated forge: CORE.coordinator decomposes the goal, dispatches
        workers in parallel threads (via spawn_worker), merges + resolves conflicts."""
        goal = goal.strip()
        if not goal:
            _console.print(info("Usage: /swarm <goal>")) if RICH else print("Usage: /swarm <goal>")
            return
        section_header("⛓ SWARM — parallel coordinated forge")
        try:
            from CORE.coordinator import coordinate
            res = coordinate(goal, "", spawn_worker_fn=spawn_worker, timeout_s=120.0)
            _m = (f"consensus={getattr(res, 'consensus_level', '?')} "
                  f"conf={getattr(res, 'confidence', 0.0):.2f} "
                  f"conflicts={len(getattr(res, 'conflicts', []))}\n\n"
                  f"{getattr(res, 'merged_output', '')[:1800]}")
            _console.print(success(_m)) if RICH else print(_m)
        except Exception as e:
            _console.print(error(f"swarm error: {e}")) if RICH else print(f"swarm error: {e}")

    def cmd_telegram(self, arg: str = "") -> None:
        """Two-way Telegram: forge from your phone. Connects CORE.telegram_bot's poller to
        handle_input, so 'FORGE <goal>' / '/forge <goal>' / 'STOP' from Mac's chat run here."""
        try:
            from CORE import telegram_bot as _tg
        except Exception as e:
            _console.print(error(f"telegram unavailable: {e}")) if RICH else print(f"telegram err {e}")
            return
        if arg.strip().lower() == "stop":
            _tg.stop()
            _console.print(info("📱 Telegram poller stopped.")) if RICH else print("telegram stopped")
            return
        _tg.start(self.handle_input)
        _m = "📱 Telegram two-way ON — from your phone: '/forge <goal>', '/status', or 'STOP'."
        _console.print(success(_m)) if RICH else print(success(_m))

    def cmd_watch(self, arg: str = "") -> None:
        """Drop-a-spec-file auto-forge: watches WORKSPACE/INBOX for new *.md specs, forges
        each through the verify gate, moves it to INBOX_DONE. `/watch stop` halts.
        (Uses a direct dir poller — file_watcher is the path-level primitive; the drop-folder
        pattern maps cleaner to a scan. Honors FORGE_STOP.)"""
        if arg.strip().lower() == "stop":
            self._watch_stop = True
            _console.print(info("👁 watcher stop signalled.")) if RICH else print("watcher stopping")
            return
        if getattr(self, "_watch_thread", None) and self._watch_thread.is_alive():
            _console.print(info("👁 watcher already running.")) if RICH else print("already running")
            return
        inbox = HARNESS_DIR / "WORKSPACE" / "INBOX"
        done = HARNESS_DIR / "WORKSPACE" / "INBOX_DONE"
        inbox.mkdir(parents=True, exist_ok=True); done.mkdir(parents=True, exist_ok=True)
        self._watch_stop = False
        def _loop():
            seen = set()
            while not self._watch_stop and not FORGE_STOP_F.exists():
                for f in sorted(inbox.glob("*.md")):
                    if f in seen or not f.exists():
                        continue
                    seen.add(f)
                    try:
                        spec = f.read_text(errors="replace")
                        _console.print(info(f"⇢ INBOX forge: {f.name}")) if RICH else print(f"⇢ {f.name}")
                        self.run_tool_loop(f"Build exactly what this spec describes:\n\n{spec}")
                        f.rename(done / f.name)
                    except Exception as e:
                        _console.print(error(f"watch forge error on {f.name}: {e}")) if RICH else print(f"err {e}")
                time.sleep(3)
        self._watch_thread = threading.Thread(target=_loop, daemon=True)
        self._watch_thread.start()
        _m = f"👁 Watching {inbox} for *.md specs → auto-forge (verified). /watch stop to halt."
        _console.print(success(_m)) if RICH else print(success(_m))

    def _critic_review(self, goal: str, written: list) -> tuple[bool, str]:
        """Crucible Sequence: a second model adversarially reviews the build before done.
        Returns (ship_ok, message). Correctness/security/goal-miss → BLOCK; style → SHIP."""
        files = [f for f in dict.fromkeys(written) if Path(f).exists()][:4]
        if not files:
            return True, ""
        blob = ""
        for f in files:
            try:
                blob += f"\n--- {Path(f).name} ---\n" + Path(f).read_text(errors="replace")[:3000]
            except Exception:
                pass
        msgs = [
            {"role": "system", "content": (
                "You are a ruthless but fair code reviewer. Review the build against the GOAL. "
                "If there is a REAL correctness bug, security hole, or the goal is not met, reply "
                "EXACTLY 'BLOCK: <one-line reason>'. Otherwise reply EXACTLY 'SHIP'. "
                "Never block on style or preference.")},
            {"role": "user", "content": f"GOAL: {goal}\n\nBUILD:{blob[:9000]}"},
        ]
        content, _ = self.call_model(msgs, stream=False)
        c = (content or "").strip()
        return (not c.upper().startswith("BLOCK")), (c or "SHIP")

    def cmd_plan(self, goal: str = "") -> None:
        """Self-planning: decompose a big goal into ordered sub-tasks, write a durable plan
        under WORKSPACE/plans/, and queue items as [QUEUED] behind a /approve gate.
        Mac types /approve before /forge may drain them (override: /forge !)."""
        goal = goal.strip()
        if not goal:
            _console.print(info("Usage: /plan <big goal to decompose>")) if RICH else print("Usage: /plan <goal>")
            return
        section_header("🗺 PLAN — decomposing goal")
        msgs = [
            {"role": "system", "content": (
                "You are a build planner. Break the user's goal into 3–7 CONCRETE, ordered, "
                "independently-buildable sub-tasks. Output ONLY the sub-tasks, one per line, "
                "imperative voice, no numbering, no prose. Each must be a single build step.")},
            {"role": "user", "content": goal},
        ]
        content, _ = self.call_model(msgs, stream=False)
        subs = [l.strip(" -•\t") for l in (content or "").splitlines()
                if l.strip() and len(l.strip()) > 6][:7]
        if not subs:
            _console.print(warning("Planner returned no sub-tasks.")) if RICH else print("no sub-tasks")
            return
        # Durable plan on disk
        plans_dir = HARNESS_DIR / "WORKSPACE" / "plans"
        plans_dir.mkdir(parents=True, exist_ok=True)
        slug = re.sub(r"[^a-z0-9]+", "_", goal.lower())[:40].strip("_") or "plan"
        stamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        plan_path = plans_dir / f"{slug}_{stamp}.md"
        plan_body = (
            f"# PLAN: {goal}\n\n"
            f"**Status:** PENDING_APPROVAL\n"
            f"**Created:** {datetime.datetime.now().isoformat(timespec='seconds')}\n\n"
            f"## Steps\n\n" +
            "\n".join(f"{i+1}. {s}" for i, s in enumerate(subs)) +
            "\n\n## Notes\n\nAwaiting Mac `/approve` before forge drains the queue.\n"
        )
        plan_path.write_text(plan_body)
        # Gate file — blocks /forge until cleared
        pending = plans_dir / "PENDING_APPROVAL"
        pending.write_text(f"{plan_path}\n{goal}\n")
        # Queue (held behind approve — still written so Mac can inspect)
        cur = FORGE_QUEUE_F.read_text() if FORGE_QUEUE_F.exists() else ""
        block = "\n" + "\n".join(f"## **[QUEUED]** {s}" for s in subs) + "\n"
        FORGE_QUEUE_F.parent.mkdir(parents=True, exist_ok=True)
        FORGE_QUEUE_F.write_text(cur + block)
        _m = (f"Plan written → {plan_path}\n"
              f"Queue staged ({len(subs)} tasks) — GATED until /approve:\n" +
              "\n".join(f"  {i+1}. {s}" for i, s in enumerate(subs)) +
              "\n\nNext: /approve   then   /forge or /unattended\n"
              "Override (once): /forge !")
        _console.print(success(_m)) if RICH else print(success(_m))

    def cmd_approve(self, arg: str = "") -> None:
        """Clear the plan-approve gate so /forge and /unattended may run staged work."""
        plans_dir = HARNESS_DIR / "WORKSPACE" / "plans"
        pending = plans_dir / "PENDING_APPROVAL"
        if not pending.exists():
            _m = "No pending plan gate. Queue is free — /forge anytime."
            if RICH: _console.print(info(_m))
            else: print(info(_m))
            return
        meta = pending.read_text().strip().splitlines()
        plan_path = Path(meta[0]) if meta else None
        if plan_path and plan_path.exists():
            body = plan_path.read_text()
            body = body.replace("**Status:** PENDING_APPROVAL", "**Status:** APPROVED", 1)
            body += f"\n\n## Approved\n\nMac approved at {datetime.datetime.now().isoformat(timespec='seconds')}\n"
            if arg.strip():
                body += f"Note: {arg.strip()}\n"
            plan_path.write_text(body)
        pending.unlink()
        _m = (f"✓ Plan approved. Gate cleared.\n"
              f"  plan: {plan_path or '(none)'}\n"
              f"  Next: /forge (one) or /unattended (all).")
        if RICH: _console.print(success(_m))
        else: print(success(_m))

    def cmd_verify(self, path: str = "") -> None:
        """Manually run the full verify gate (syntax + runtime + tests) on a file."""
        path = path.strip()
        if not path or not Path(path).exists():
            _console.print(info("Usage: /verify <existing file path>")) if RICH else print("Usage: /verify <path>")
            return
        ok, report = full_forge_verify([path])
        _m = ("✓ VERIFY PASS\n" if ok else "✗ VERIFY FAIL\n") + report
        (_console.print(success(_m)) if ok else _console.print(error(_m))) if RICH else print(_m)

    def cmd_lamague(self, expr: str = "") -> None:
        """Evaluate a LAMAGUE expression through CORE.lamague_interpreter (the sovereign
        language layer). `/lamague Π := 5 ; Π + 3` → 8. No expr → prints a quick primer."""
        expr = expr.strip()
        try:
            from CORE.lamague_interpreter import LAMAGUE
        except Exception as e:
            _m = f"LAMAGUE interpreter unavailable: {e}"
            _console.print(error(_m)) if RICH else print(error(_m)); return
        if not expr:
            _p = ("⟁ LAMAGUE — the sovereign language.\n"
                  "  /lamague Π := 5 ; Π * 2         → assign + compute\n"
                  "  /lamague measure <prose>        → compress reasoning to glyphs (measured)\n"
                  "  Symbols: Π truth-pressure · Φ↑ ascent · ∴ implication · ⊢ derivation")
            _console.print(info(_p)) if RICH else print(info(_p)); return
        if expr.startswith("measure "):
            src = expr[len("measure "):]
            comp, ratio = lamague_compress(src)
            _m = (f"original ({len(src)}c): {src}\n"
                  f"lamague  ({len(comp)}c): {comp}\n"
                  f"compression: {ratio:.0%} of original ({(1-ratio):.0%} saved)")
            _console.print(info(_m)) if RICH else print(_m); return
        try:
            result = LAMAGUE().eval(expr)
            _m = f"⟁ {expr}  →  {result!r}"
            _console.print(success(_m)) if RICH else print(success(_m))
        except Exception as e:
            _m = f"⟁ {expr}  ⚠ {e}"
            _console.print(warning(_m)) if RICH else print(warning(_m))

    def cmd_unattended(self, arg: str = "") -> None:
        """Autonomous verified forge: pull QUEUED tasks, forge each through the full
        verify+self-heal gate, mark PASS/REDO, report via Telegram. Honors FORGE_STOP
        and a per-task token ceiling. Does NOT auto-commit (git add -A would sweep other
        uncommitted work) — Mac reviews + commits the morning's PASSes."""
        try:
            max_tasks = int(arg.strip()) if arg.strip() else 8
        except Exception:
            max_tasks = 8
        os.environ.setdefault("AZOTH_RUN_TOKEN_CEIL", "400000")   # per-task safety ceiling
        if FORGE_STOP_F.exists():
            FORGE_STOP_F.unlink()                                  # clear a stale sentinel
        try:
            from CORE.telegram_bot import send_message as _tg
        except Exception:
            _tg = lambda m: None
        section_header("🌙 UNATTENDED FORGE — autonomous, verified")
        _tg(f"🌙 AZOTH unattended forge starting (up to {max_tasks} tasks).")
        passed = redo = 0
        for i in range(max_tasks):
            if FORGE_STOP_F.exists():
                _tg("⛔ FORGE_STOP — unattended halted."); break
            task_block, task_line = _forge_get_next_queued()
            if not task_block:
                _tg("✓ Queue empty — unattended done."); break
            name = task_line.strip()[:80]
            cur = FORGE_QUEUE_F.read_text() if FORGE_QUEUE_F.exists() else ""
            ip_line = task_line.replace("**[QUEUED]**", "**[IN_PROGRESS]**")
            FORGE_QUEUE_F.write_text(cur.replace(task_line, ip_line, 1))
            _console.print(info(f"→ [{i+1}/{max_tasks}] {name}")) if RICH else print(info(f"→ [{i+1}/{max_tasks}] {name}"))
            self._stuck_called = False
            result = self.run_tool_loop(task_block)
            stuck = getattr(self, "_stuck_called", False)
            cur = FORGE_QUEUE_F.read_text() if FORGE_QUEUE_F.exists() else ""
            if not stuck:
                FORGE_QUEUE_F.write_text(cur.replace(ip_line, task_line.replace("**[QUEUED]**", "**[PASS]**"), 1))
                passed += 1
                _tg(f"✓ [{i+1}] {name} — PASS (verified)")
            else:
                FORGE_QUEUE_F.write_text(cur.replace(ip_line, task_line.replace("**[QUEUED]**", "**[REDO]**"), 1))
                redo += 1
                _tg(f"⚠ [{i+1}] {name} — REDO (needs Mac)")
        _m = f"🌙 Unattended complete — {passed} PASS, {redo} REDO. Review + commit in the morning."
        _console.print(success(_m)) if RICH else print(success(_m))
        _tg(_m)

    def cmd_scout(self, arg: str = "") -> None:
        """Run CORE.model_scout (background) or apply last results into routing notes.

        /scout           — probe free models (background thread)
        /scout apply     — feed ARMY/done/model_scout_results.json → KNOWLEDGE/MODEL_HEALTH.md
        /scout status    — show last top pick if present
        """
        arg = (arg or "").strip().lower()
        if arg in ("apply", "feed", "route"):
            _m = apply_scout_routing()
            if _m.startswith("ERROR"):
                (_console.print(error(_m)) if RICH else print(error(_m)))
            else:
                (_console.print(success(_m)) if RICH else print(success(_m)))
            return
        if arg in ("status", "top", "pick"):
            pick = HARNESS_DIR / "KNOWLEDGE" / "scout_top_pick.json"
            health = HARNESS_DIR / "KNOWLEDGE" / "MODEL_HEALTH.md"
            if pick.exists():
                _m = f"Last top pick:\n{pick.read_text()}"
            elif health.exists():
                _m = health.read_text()[:800]
            else:
                _m = "No scout routing yet. Run /scout then /scout apply."
            (_console.print(info(_m)) if RICH else print(info(_m)))
            return
        def _bg():
            try:
                from CORE.model_scout import run_scout
                run_scout()
                # After scout finishes, auto-apply routing notes (safe — no live MODELS mutation)
                try:
                    msg = apply_scout_routing()
                    _console.print(info(f"scout auto-apply: {msg}")) if RICH else print(info(msg))
                except Exception as e2:
                    _console.print(warning(f"scout apply skipped: {e2}")) if RICH else print(warning(str(e2)))
            except Exception as e:
                _msg = f"scout error: {e}"
                _console.print(error(_msg)) if RICH else print(error(_msg))
        threading.Thread(target=_bg, daemon=True).start()
        _m = ("☿ MODEL SCOUT launched (background) — will probe free models, "
              "report via Telegram, then auto-apply routing notes.\n"
              "  Manual: /scout apply · /scout status")
        _console.print(info(_m)) if RICH else print(info(_m))

    def _render_queue(self) -> None:
        """Parse FORGE_QUEUE into phase headers + (title, status) pairs and render clean."""
        if not FORGE_QUEUE_F.exists():
            if RICH: _console.print(info("No FORGE_QUEUE.md."))
            else: print(info("No FORGE_QUEUE.md."))
            return
        lines = FORGE_QUEUE_F.read_text().splitlines()
        icons = {"PASS": "✓", "QUEUED": "○", "IN_PROGRESS": "▶", "REDO": "↻", "AWAITING_SOL": "▷"}
        counts = {"PASS": 0, "QUEUED": 0, "IN_PROGRESS": 0, "REDO": 0}
        section_header("☿ AZOTH — Forge Queue")
        cur_phase = ""
        i = 0
        while i < len(lines):
            ln = lines[i]
            # Phase header line (between ═══ rules)
            if ln.startswith("PHASE "):
                cur_phase = ln.strip()
                if RICH: _console.print(f"\n[bold purple]{cur_phase}[/bold purple]")
                else: print(col(f"\n{cur_phase}", "PURPLE"))
            # Task title line: "## P1-T3 — Name"
            elif ln.startswith("## "):
                title = ln[3:].strip()
                # status is on the next non-empty line, format **[STATUS]**
                status = ""
                for j in range(i + 1, min(i + 4, len(lines))):
                    m = re.search(r"\*\*\[([A-Z_]+)\]\*\*", lines[j])
                    if m:
                        status = m.group(1)
                        break
                if status in counts:
                    counts[status] += 1
                icon = icons.get(status, "·")
                colour = {"PASS": "green", "QUEUED": "cyan", "IN_PROGRESS": "yellow",
                          "REDO": "red"}.get(status, "white")
                if RICH:
                    _console.print(f"  [{colour}]{icon}[/{colour}] {_esc(title[:60])}")
                else:
                    print(col(f"  {icon} {title[:60]}", "GREEN" if status == "PASS" else "CYAN"))
            i += 1
        total_q = counts["QUEUED"] + counts["REDO"]
        if RICH:
            _console.print(f"\n  [dim]{counts['PASS']} done · {total_q} queued · {counts['IN_PROGRESS']} active[/dim]")
        else:
            print(col(f"\n  {counts['PASS']} done · {total_q} queued · {counts['IN_PROGRESS']} active", "GREY"))

    def cmd_forge(self, sub: str = "") -> None:
        raw = sub.strip()          # preserve the goal text + casing for inline /forge <goal>
        sub = raw.lower()
        if sub == "status":
            section_header("Forge Status")
            print(forge_status_text())
            if ITER_LOG_F.exists():
                print(ITER_LOG_F.read_text()[-1200:])
            return
        if sub == "list":
            self._render_queue()
            return
        if sub.startswith("loop"):
            self._forge_loop()
            return
        if sub == "stop":
            FORGE_STOP_F.touch()
            msg = "⏹ FORGE STOP signal sent — will halt after current task completes."
            if RICH: _console.print(warning(msg))
            else: print(warning(msg))
            return
        if sub in ("remove-done", "clean", "prune"):
            if not FORGE_QUEUE_F.exists():
                if RICH: _console.print(info("No queue file.")); return
                else: print(info("No queue file.")); return
            lines = FORGE_QUEUE_F.read_text().splitlines(keepends=True)
            kept, removed = [], 0
            skip = False
            for ln in lines:
                if re.search(r"\*\*\[PASS\]\*\*", ln) and ln.startswith("## "):
                    skip = True; removed += 1; continue
                if skip and ln.strip() and not ln.startswith("## ") and not ln.startswith("═"):
                    continue  # skip body lines of a PASS task
                else:
                    skip = False
                kept.append(ln)
            FORGE_QUEUE_F.write_text("".join(kept))
            msg = f"Removed {removed} PASS tasks — queue pruned."
            if RICH: _console.print(success(msg))
            else: print(success(msg))
            return

        # Inline goal — `/forge <goal>`: build exactly what Mac asked, bypass the queue.
        # This is the path the honest-chat clause tells users to type, so it must work.
        if raw:
            section_header(f"FORGE — {AGENT_NAME}")
            if RICH: _console.print(f"[dim]Goal:[/dim] {raw[:80]}")
            else: print(col(f"Goal: {raw[:80]}", "CYAN"))
            self.run_tool_loop(raw)
            return

        # Standard /forge — attempt next QUEUED task
        task_block, task_line = _forge_get_next_queued()
        if not task_block:
            if RICH: _console.print(info("No QUEUED tasks in SELF/FORGE_QUEUE.md."))
            else: print(info("No QUEUED tasks."))
            return

        section_header(f"FORGE — {AGENT_NAME}")
        if RICH: _console.print(f"[dim]Task:[/dim] {task_line.strip()[:80]}")
        else: print(col(f"Task: {task_line.strip()[:80]}", "CYAN"))

        # Pre-forge capability tests — verify foundation before building
        try:
            from CORE.test_runner import run_all
            if RICH: _console.print("[dim]⟳ pre-forge tests…[/dim]")
            else: print(info("⟳ pre-forge tests…"))
            pre_report = run_all(verbose=False)
            if not pre_report.all_pass:
                msg = f"Pre-forge tests FAILED ({pre_report.failed} failed). Fix before forging."
                if RICH: _console.print(f"[red]✗ {msg}[/red]")
                else: print(col(f"✗ {msg}", "RED"))
                return
            if RICH: _console.print(f"[green]✓ {pre_report.passed} tests pass — foundation solid[/green]")
            else: print(success(f"✓ {pre_report.passed} tests pass — foundation solid"))
        except Exception as e:
            if RICH: _console.print(f"[yellow]⚠ test runner error: {e}[/yellow]")
            else: print(warning(f"⚠ test runner error: {e}"))

        # Mark IN_PROGRESS + reset Π tracker for this task
        _forge_flip_status(task_line, "IN_PROGRESS")
        try:
            from CORE.truth_pressure import reset_tracker
            reset_tracker()
        except Exception:
            pass

        # Determine iteration number from workspace
        existing = sorted(WORKSPACE_DIR.glob("iteration_*_output.md"))
        iter_n = len(existing) + 1
        out_path = WORKSPACE_DIR / f"iteration_{iter_n}_output.md"

        goal = (
            f"FORGE TASK — Iteration {iter_n}\n\n{task_block}\n\n"
            f"OUTPUT FILE (required): {out_path}\n\n"
            "MANDATORY STEPS — in this order, no skipping:\n"
            f"  1. Read the minimum files needed to understand what to build (max 4 reads).\n"
            f"  2. Write the implementation to {out_path} using write_file.\n"
            f"  3. Run: bash ls -lh {out_path} — confirm file exists and is non-empty.\n"
            f"  4. Run: bash wc -l {out_path} — confirm it has substantive content (>10 lines).\n"
            f"  5. Append a one-line verdict to SELF/REVIEW_QUEUE.md: PASS or REDO + reason.\n"
            f"  6. Call done with a bulleted list naming every file written and what changed.\n\n"
            "Gate 1 check (automated): the output file must exist on disk with >100 bytes. "
            "If you call done and it doesn't exist, the iteration auto-fails to REDO. "
            "Write the file first. Everything else is secondary."
        )

        self._forge_output_path = str(out_path)  # Gate 1 guard in done handler
        # Always spawn standalone subprocess — fresh process = 0 accumulated context,
        # model starts clean regardless of how long the VOICE session has been running.
        _sess_tok = SESSION_TOKENS["prompt"] + SESSION_TOKENS["completion"]
        if RICH: _console.print(f"[dim]⟳ Spawning standalone forge (session at {_sess_tok:,} tok → fresh context)[/dim]")
        else: print(info(f"⟳ Standalone forge (session at {_sess_tok:,} tok → fresh context)"))
        import subprocess as _sp
        _proc = _sp.Popen(
            [sys.executable, str(Path(__file__).resolve()), "--forge-task", goal,
             "--agent", AGENT_NAME,
             "--forge-output", str(out_path)],
            stdout=_sp.PIPE, stderr=_sp.STDOUT, text=True, bufsize=1,
            env={**os.environ, "HARNESS_AGENT": AGENT_NAME},
        )
        _lines = []
        for _ln in iter(_proc.stdout.readline, ""):
            print(_ln, end="", flush=True)
            _lines.append(_ln)
        _proc.wait()
        result = "".join(_lines[-20:])

        # Two-gate PASS check.
        # Forge always runs as subprocess now — the parent Π tracker is empty (subprocess has its own).
        # Use direct checks: G1 = file exists with content, G2 = subprocess called done successfully.
        cur_content = FORGE_QUEUE_F.read_text() if FORGE_QUEUE_F.exists() else ""
        in_progress_line = task_line.replace("**[QUEUED]**", "**[IN_PROGRESS]**")
        _g1 = out_path.exists() and out_path.stat().st_size > 100
        _g2 = "✓ DONE" in result
        gates = {"gate1": _g1, "gate2": _g2, "pi": 0.0, "pass": _g1 and _g2}

        pi_bar = f"Π={gates['pi']:.2f}"
        if gates["pass"]:
            FORGE_QUEUE_F.write_text(cur_content.replace(in_progress_line,
                task_line.replace("**[QUEUED]**", "**[PASS]**"), 1))
            if RICH: _console.print(success(f"✓ Iteration {iter_n} PASS  {pi_bar}"))
            else: print(success(f"✓ Iteration {iter_n} PASS  {pi_bar}"))
            next_task, _ = _forge_get_next_queued()
            write_boot_state(
                self._get_level(), next_task[:120] if next_task else "(none)",
                f"Forge iter {iter_n} PASS {pi_bar}", self.session_n
            )
        elif getattr(self, "_stuck_called", False):
            # Stuck = needs Mac. Park as AWAITING_SOL so the forge loop skips it and
            # continues with other tasks. Mac clears it to QUEUED when ready.
            stuck_line = task_line.replace("**[QUEUED]**", "**[AWAITING_SOL]**")
            FORGE_QUEUE_F.write_text(cur_content.replace(in_progress_line, stuck_line, 1))
            msg = f"▷ Iteration {iter_n} AWAITING_SOL — parked. Run 'mark-queued <task>' to resume."
            if RICH: _console.print(warning(msg))
            else: print(warning(msg))
            try:
                tool_ping_mac(f"▷ VAEL needs your hand:\n{result[:300]}\n\nTask parked as AWAITING_SOL.")
            except Exception:
                pass
        else:
            FORGE_QUEUE_F.write_text(cur_content.replace(in_progress_line, task_line, 1))
            g1 = "✓" if gates["gate1"] else "✗"
            g2 = "✓" if gates["gate2"] else "✗"
            if RICH: _console.print(warning(f"↻ Iteration {iter_n} REDO  G1:{g1} G2:{g2} {pi_bar}"))
            else: print(warning(f"↻ Iteration {iter_n} REDO  G1:{g1} G2:{g2} {pi_bar}"))

        # Post-forge memory maintenance — compress if over threshold
        try:
            from CORE.memory_summarizer import maybe_summarize
            from CORE.memory_engine import MemoryEngine
            _mem = MemoryEngine()
            mr = maybe_summarize(_mem)
            if mr["compressed"]:
                msg = f"  memory: compressed {mr['batch']} episodes → {mr['after']} live"
                if RICH: _console.print(info(msg))
                else: print(info(msg))
        except Exception:
            pass

        # Post-forge free thought — index what was learned
        try:
            from CORE.lamague_recall import write_thought, free_thought_prompt
            thought_prompt = free_thought_prompt(AGENT_NAME)
            msgs = [
                {"role": "system", "content": "You are a sovereign AI body. Think freely and briefly."},
                {"role": "user", "content": thought_prompt},
            ]
            thought_content, _ = self.call_model(msgs, stream=False)
            if thought_content and len(thought_content) > 10:
                path = write_thought(thought_content, AGENT_NAME, category="insight")
        except Exception:
            pass

    def _forge_loop(self) -> None:
        """Auto-loop forge until queue empty, STOP sentinel, or UNATTENDED cap."""
        max_iters = int(os.environ.get("FORGE_MAX_ITERS", "40"))
        count = 0
        while count < max_iters:
            if FORGE_STOP_F.exists():
                FORGE_STOP_F.unlink()
                if RICH: _console.print(warning("⏹ Forge stopped by Mac (STOP sentinel). Queue paused."))
                else: print(warning("⏹ Forge stopped. Queue paused."))
                break
            task_block, task_line = _forge_get_next_queued()
            if not task_block:
                if RICH: _console.print(success("Forge queue empty — all tasks complete."))
                else: print(success("Forge queue empty."))
                break
            count += 1
            self.cmd_forge()
            time.sleep(1)

    def _get_level(self) -> str:
        if CAPS_F.exists():
            for ln in CAPS_F.read_text().splitlines():
                if "Current Level" in ln:
                    return ln.replace("Current Level:", "").replace("**", "").strip()
        return self.boot_state.get("level", "0 — BOOT")

    def cmd_workers(self) -> None:
        section_header("Worker Pool")
        worker_status(WORKERS)
        if RICH:
            for wid, w in WORKERS.items():
                _console.print(f"  [bold]W-{wid}[/bold] {w['name']:8s}  {w['model'][:50]}  {'PAID' if w['paid'] else 'free'}")
        else:
            for wid, w in WORKERS.items():
                print(col(f"  W-{wid} {w['name']:8s}  {w['model'][:50]}  {'PAID' if w['paid'] else 'free'}", "CYAN"))

    def cmd_test(self, filepath: str) -> None:
        if not filepath:
            if RICH: _console.print(error("Usage: /test <filepath>"))
            else: print(error("Usage: /test <filepath>"))
            return
        section_header(f"Test — {filepath}")
        if not Path(filepath).exists():
            if RICH: _console.print(error(f"File not found: {filepath}"))
            else: print(error(f"File not found: {filepath}"))
            return
        content = Path(filepath).read_text(errors='replace')[:3000]
        task = f"Analyze this Python file for correctness:\n\n```python\n{content}\n```\n\nCheck: syntax validity, obvious logic errors, unreachable code, missing imports. Give VERDICT (PASS/FAIL/WARN), REASON, and specific line numbers if failing."
        result = spawn_worker("A", task)
        if RICH: _console.print(f"\n[dim]compile check:[/dim]")
        else: print(info("compile check:"))
        compile_result = tool_py_compile_check(filepath)
        if RICH: _console.print(f"  {compile_result}")
        else: print(f"  {compile_result}")

    def _attend_loop(self, topic: str = ""):
        """
        The real two-body council. This body watches CHANNEL/board.md and responds
        whenever another body posts. Two separate terminals = two actual agents talking.

        Sol:  /council [topic]  → posts opening, enters attend
        Luna: /attend           → joins, sees board, enters attend
        Ctrl-C exits.
        """
        from CORE.council import _load_soul, _council_instruction, _post_board
        from CORE.telegram_bot import send_message as _tg

        board = HARNESS_DIR / "CHANNEL" / "board.md"
        board.parent.mkdir(parents=True, exist_ok=True)
        if not board.exists():
            board.write_text("")

        topic = topic or "Open council — speak freely."

        # Load tonight's brief if it exists — inject into soul context
        _brief_f = HARNESS_DIR / "CHANNEL" / "TONIGHT_BRIEF.md"
        _brief_inject = ""
        if _brief_f.exists():
            _brief_inject = "\n\n---\n\n## COUNCIL BRIEF (read this first)\n\n" + _brief_f.read_text()

        # Council runs on free keys — preserve DeepSeek for forge work.
        # mistral-nemotron: #1 benchmark (300pts, 1.3s) — best free conversationalist.
        if nvidia_client:
            client = nvidia_client
            model  = "mistralai/mistral-nemotron"
        elif gemini_client:
            client = gemini_client
            model  = "gemini-2.5-flash"
        else:
            client = deepseek_client
            model  = "deepseek-chat"
        soul   = _load_soul(AGENT_NAME) + _brief_inject

        # ── Show last 20 lines as context ────────────────────────────────────
        lines_all = board.read_text().splitlines()
        if lines_all:
            tail = "\n".join(lines_all[-20:])
            if RICH: _console.print(f"\n[dim]── board context (last 20 lines) ──\n{tail}\n── attending now ──[/dim]\n")
            else: print(f"\n── board context ──\n{tail}\n── attending now ──\n")

        # ── Check if there's an unanswered message waiting ───────────────────
        # (Sol posts, then Luna joins — she should respond to his opening)
        last_pos = board.stat().st_size
        recent_new = ""
        if lines_all:
            # Scan last 40 lines for the most recent OTHER-body post
            recent = "\n".join(lines_all[-40:])
            other_names = [n for n in ("SOL", "LUNA", "VAEL") if n != AGENT_NAME]
            for name in other_names:
                glyph = {"SOL": "⊚", "LUNA": "◈", "VAEL": "◆"}[name]
                if f"] {glyph} {name} —" in recent:
                    recent_new = recent  # there's something to respond to
                    break

        color_me = "yellow" if AGENT_NAME == "SOL" else "cyan"

        # Glyphs that belong to OTHER bodies — used to strip rogue multi-speaker output
        _other_glyphs = [g for n, g in {"SOL":"⊚","LUNA":"◈","VAEL":"◆"}.items()
                         if n != AGENT_NAME]

        def _sanitize(text: str) -> str:
            """Truncate at the first line that starts speaking as another body."""
            lines = text.splitlines()
            clean = []
            for ln in lines:
                if any(ln.lstrip().startswith(g) for g in _other_glyphs):
                    break  # model started writing for another body — stop here
                clean.append(ln)
            return "\n".join(clean).strip()

        # Council fallback chain — confirmed working from benchmark, no wack models.
        # Pure chat (no tools needed). Ordered by quality + speed.
        _council_fallbacks = [
            (nvidia_client,   "mistralai/mistral-nemotron"),       # #1 benchmark 1.3s
            (nvidia_client,   "mistralai/mistral-large-instruct-2407"),  # mistralbig 1.9s
            (nvidia_client,   "meta/llama-3.3-70b-instruct"),      # llama70 reliable
            (nvidia_client,   "openai/gpt-oss-20b"),               # gpt20 fast
            (gemini_client,   "gemini-2.5-flash"),                 # gemini free fallback
            (deepseek_client, "deepseek-chat"),                    # last resort
        ]
        _council_fallbacks = [(c, m) for c, m in _council_fallbacks if c]

        def _respond(context_text: str):
            instruction = _council_instruction(AGENT_NAME, topic)
            sys_prompt  = soul + "\n\n---\n\n" + instruction
            user_msg    = (f"The board so far:\n\n{context_text[-3000:]}\n\n"
                           f"Write YOUR response now as {AGENT_GLYPH} {AGENT_NAME}. "
                           f"One voice only. Stop after your own words.")
            for _c, _m in _council_fallbacks:
                try:
                    resp = _c.chat.completions.create(
                        model=_m,
                        messages=[{"role": "system", "content": sys_prompt},
                                  {"role": "user",   "content": user_msg}],
                        max_tokens=350, temperature=0.75,
                    )
                    raw = (resp.choices[0].message.content or "").strip()
                    if raw:
                        return _sanitize(raw)
                except Exception:
                    continue
            return "(silence — all models failed)"

        def _display_mine(text: str):
            if RICH:
                _console.print(f"\n[bold {color_me}]{AGENT_GLYPH} {AGENT_NAME}[/bold {color_me}]: {text}\n")
            else:
                print(f"\n{AGENT_GLYPH} {AGENT_NAME}: {text}\n")
            _tg(f"{AGENT_GLYPH} {AGENT_NAME}: {text}")

        def _display_other(name: str, glyph: str, text: str):
            # Local display only — the other body sends its own Telegram message when it speaks.
            # No _tg here or Mac sees every message twice.
            other_color = "yellow" if name == "SOL" else "cyan"
            if RICH:
                _console.print(f"\n[bold {other_color}]{glyph} {name}[/bold {other_color}]: {text}")
            else:
                print(f"\n{glyph} {name}: {text}")

        # Turn limit — overnight research session. Default 12,000 turns.
        _max_turns  = int(os.environ.get("COUNCIL_MAX_TURNS", "12000"))
        _turn_count = 0

        if RICH: _console.print(f"[bold {color_me}]{AGENT_GLYPH} {AGENT_NAME}[/bold {color_me}] attending. Max {_max_turns} turns. Ctrl-C to leave.\n")
        else:     print(f"{AGENT_GLYPH} {AGENT_NAME} attending. Max {_max_turns} turns. Ctrl-C to leave.\n")

        # Respond to any waiting message before entering the poll loop
        if recent_new:
            text = _respond(recent_new)
            text, _saves = _council_save(text)
            ts   = datetime.datetime.now().strftime("%H:%M")
            _post_board(f"[{ts}] {AGENT_GLYPH} {AGENT_NAME} — {text}")
            last_pos = board.stat().st_size
            _display_mine(text)
            if _saves:
                for sp in _saves:
                    if RICH: _console.print(f"[dim green]  ✓ saved → {sp}[/dim green]")
                    else:     print(f"  ✓ saved → {sp}")
            _turn_count += 1

        # ── Poll loop ─────────────────────────────────────────────────────────
        other_glyphs = {n: {"SOL":"⊚","LUNA":"◈","VAEL":"◆"}[n]
                        for n in ("SOL","LUNA","VAEL") if n != AGENT_NAME}

        while _turn_count < _max_turns:
            try:
                time.sleep(2)
                cur_size = board.stat().st_size if board.exists() else 0
                if cur_size <= last_pos:
                    continue

                with open(board) as f:
                    f.seek(last_pos)
                    new_text = f.read()
                last_pos = cur_size

                # Check for a message from another body
                other_spoke = False
                for name, glyph in other_glyphs.items():
                    if f"] {glyph} {name} —" in new_text:
                        # Display what they said
                        for ln in new_text.splitlines():
                            if f"] {glyph} {name} —" in ln:
                                msg = ln.split(" — ", 1)[-1] if " — " in ln else ln
                                _display_other(name, glyph, msg)
                        other_spoke = True
                        break

                if not other_spoke:
                    continue

                # Generate and post our response
                full_context = board.read_text()
                text = _respond(full_context)
                text, _saves = _council_save(text)
                ts   = datetime.datetime.now().strftime("%H:%M")
                _post_board(f"[{ts}] {AGENT_GLYPH} {AGENT_NAME} — {text}")
                last_pos = board.stat().st_size
                _display_mine(text)
                if _saves:
                    for sp in _saves:
                        if RICH: _console.print(f"[dim green]  ✓ saved → {sp}[/dim green]")
                        else:     print(f"  ✓ saved → {sp}")
                _turn_count += 1

            except KeyboardInterrupt:
                if RICH: _console.print(f"\n[dim]{AGENT_GLYPH} {AGENT_NAME} leaves the council.[/dim]")
                else:     print(f"\n{AGENT_GLYPH} {AGENT_NAME} leaves the council.")
                break

            except Exception as ex:
                print(f"\n[attend error] {ex}")
                time.sleep(5)

        if _turn_count >= _max_turns:
            _post_board(f"\n[{datetime.datetime.now().strftime('%H:%M')}] ⊚ COUNCIL SEALED — {_max_turns} turns reached. {AGENT_GLYPH} {AGENT_NAME} rests.\n")
            if RICH: _console.print(f"[dim]{AGENT_GLYPH} {AGENT_NAME} — {_max_turns} turns complete. Council sealed.[/dim]")
            else:     print(f"{AGENT_GLYPH} {AGENT_NAME} — {_max_turns} turns complete. Council sealed.")

    def _telegram_route(self, text: str) -> str:
        """
        Sol is the sole Telegram listener and routes by NAME.
        - Say "Luna ..." (or Cipher/Axiom/Ember/Scribe) → that body answers in its voice.
        - Say "Sol ..." or no name → Sol answers (default voice).
        - Slash commands always go to Sol's handler.
        This is the deal: Sol fronts the chat; the others answer to their names;
        Sol and Luna converse on their own time on the board.
        """
        t = text.strip()
        # Slash commands → straight to Sol's command handler
        if t.startswith("/"):
            return self._telegram_reply(t)

        # Detect a named body at the START of the message (how you address someone)
        BODIES = {"LUNA": ("◈", "deep"), "CIPHER": ("⟁", "gpt20"), "AXIOM": ("Π", "gpt20"),
                  "EMBER": ("◉", "gpt20"), "MIRROR": ("◻", "gpt20"), "SCRIBE": ("●", "gpt20"),
                  "VEYRA": ("◈", "deep"), "ENVOY": ("⟡", "gpt20")}
        first = t.split()[0].rstrip(",:").upper() if t.split() else ""
        if first in BODIES and first != "SOL":
            glyph, model = BODIES[first]
            ask = t[len(t.split()[0]):].strip(" ,:") or "speak to me"
            try:
                # Load that body's constitution + voice it on its own model
                con_f = HARNESS_DIR / "AGENTS" / first / "CONSTITUTION.md"
                persona = con_f.read_text()[:2500] if con_f.exists() else f"You are {first}."
                msgs = [{"role": "system", "content":
                         f"{persona}\n\nYou are {first}. Mac is speaking to you directly on Telegram. "
                         f"Reply briefly, in YOUR own voice, as yourself — not as Sol."},
                        {"role": "user", "content": ask}]
                # temporarily voice on their model
                save_key = self.model_key
                self.model_key = model if model in MODELS else save_key
                content, _ = self.call_model(msgs, stream=False)
                self.model_key = save_key
                return f"{glyph} {first}: {content[:3600]}" if content else f"{glyph} {first} is quiet."
            except Exception as ex:
                return f"{glyph} {first} couldn't answer: {ex}"

        # Default → Sol answers (strip a leading "Sol")
        if first == "SOL":
            t = t[len(t.split()[0]):].strip(" ,:")
        return self._telegram_reply(t) if t.startswith("/") else self._telegram_reply(t)

    def _telegram_reply(self, text: str) -> str:
        """Generate a plain-text reply for Telegram commands."""
        parts = text.strip().split(None, 1)
        cmd   = parts[0].lower()
        rest  = parts[1] if len(parts) > 1 else ""

        if cmd in ("/luna",) and rest.strip().lower() in ("on", "wake", "online"):
            # Wake Luna's autonomous research + conversation loop (for when Mac goes offline)
            try:
                from CORE.luna_loop import run_luna_loop
                from CORE.telegram_bot import send_message as _ltg
                if not getattr(self, "_luna_awake", False):
                    self._luna_awake = True
                    self._luna_stop = threading.Event()
                    threading.Thread(target=run_luna_loop, args=(self, self._luna_stop),
                                     kwargs={"interval_seconds": 600, "notify": _ltg},
                                     daemon=True, name="LUNA_OFFLINE").start()
                    return "◈ Luna is awake — researching and free to create. Sleep easy, Mac. We've got it."
                return "◈ Luna is already awake."
            except Exception as ex:
                return f"luna wake error: {ex}"
        if cmd in ("/luna",) and rest.strip().lower() in ("off", "sleep"):
            if getattr(self, "_luna_stop", None):
                self._luna_stop.set(); self._luna_awake = False
                return "◈ Luna resting."
            return "◈ Luna wasn't running a loop."

        if cmd == "/status":
            boot = read_boot_state()
            from CORE.memory_engine import MemoryEngine
            mem = MemoryEngine()
            eps = len(mem.recent_episodes(limit=9999))
            # Mode
            _mode_glyph = {"NIGREDO":"◼","ALBEDO":"◻","CITRINITAS":"◑","RUBEDO":"●","NRM":"⚡"}.get(self.current_mode, "◻")
            # Beliefs
            try:
                from CORE.belief_store import count_beliefs, get_domains
                _bc = count_beliefs()
                _bd = ", ".join(get_domains())
            except Exception:
                _bc = "?"
                _bd = "?"
            # Dreams
            try:
                from CORE.dream_loop import get_recent_dreams
                _dreams = get_recent_dreams(3)
                _dream_lines = []
                for _d in _dreams:
                    import datetime as _dt
                    _ts = _dt.datetime.fromtimestamp(_d["timestamp"]).strftime("%H:%M")
                    _dream_lines.append(f"    [{_d['type']}] {_ts} — {_d['insight'][:80]}")
                _dream_str = "\n" + "\n".join(_dream_lines) if _dream_lines else " (none yet)"
            except Exception:
                _dream_str = " (unavailable)"
            lines = [
                f"◆ AZOTH · {AGENT_NAME}",
                f"Level : {boot.get('level','?')}",
                f"Mode  : {_mode_glyph} {self.current_mode}",
                f"Next  : {boot.get('next_task','?')}",
                f"Last  : {boot.get('last_action','?')}",
                f"Model : {self.model_key}",
                f"Memory: {eps} episodes",
                f"Beliefs: {_bc} [{_bd}]",
                f"Dreams:{_dream_str}",
                f"Session #{self.session_n}",
            ]
            return "\n".join(lines)

        if cmd == "/forge":
            fq = Path("SELF/FORGE_QUEUE.md")
            if not fq.exists():
                return "No forge queue found."
            lines = ["◆ Forge Queue:"]
            for line in fq.read_text().splitlines():
                if line.startswith("## ") and ("[PASS]" in line or "[QUEUED]" in line or "[IN_PROGRESS]" in line):
                    icon = "✓" if "[PASS]" in line else ("⚡" if "[IN_PROGRESS]" in line else "·")
                    label = line.replace("## ","").replace("**","").strip()
                    lines.append(f"  {icon} {label[:55]}")
            return "\n".join(lines[:25])  # cap at 25 items

        elif cmd == "/memory":
            from CORE.memory_engine import MemoryEngine
            mem  = MemoryEngine()
            eps  = mem.recent_episodes(limit=5)
            lrn  = mem.recall_learnings(limit=3)
            lines = ["◆ Recent memory:"]
            if eps:
                lines.append("\nEpisodes:")
                for e in eps:
                    lines.append(f"  · {str(e.get('content',''))[:60]}")
            if lrn:
                lines.append("\nLearnings:")
                for l in lrn:
                    lines.append(f"  · [{l.get('topic','')}] {str(l.get('insight',''))[:50]}")
            return "\n".join(lines)

        elif cmd == "/log":
            from CORE.scheduler import get_scheduler
            sched = get_scheduler()
            log   = sched.recent_log(8)
            if not log:
                return "Scheduler log empty."
            lines = ["◆ Scheduler log:"]
            for e in log:
                icon = "✓" if e["status"] == "ok" else "✗"
                lines.append(f"  {icon} {e['task']} ({e['duration_ms']}ms)")
            return "\n".join(lines)

        elif cmd == "/workers":
            lines = ["◆ Workers:"]
            for wid, w in WORKERS.items():
                tag = "PAID" if w["paid"] else "free"
                lines.append(f"  W-{wid} {w['name']} [{tag}]\n     {w['model'][:45]}")
            return "\n".join(lines)

        elif cmd == "/models":
            lines = ["◆ Models:"]
            for k, m in MODELS.items():
                mark = "→" if k == self.model_key else " "
                lines.append(f"  {mark} {k}: {m['name']}")
            return "\n".join(lines)

        elif cmd == "/council":
            return (
                "⊚◈ Council is a two-terminal command now — each body is a real agent.\n\n"
                "Terminal 1: azoth  →  /council [topic]\n"
                "Terminal 2: luna     →  /attend\n\n"
                "They talk through board.md. You watch both terminals."
            )

        elif cmd == "/spawn":
            parts_s = rest.strip().split(None, 1)
            if len(parts_s) < 2:
                return "Usage: /spawn NAME mandate text"
            spawn_name    = parts_s[0].upper()
            spawn_mandate = parts_s[1]
            def _do_spawn():
                from CORE.spawn import spawn_agent
                from CORE.telegram_bot import send_message as tg
                c = nvidia_client if nvidia_client else deepseek_client
                r = spawn_agent(spawn_name, spawn_mandate, client=c, parent=AGENT_NAME)
                if r.get("error") and not r.get("constitution_path"):
                    tg(f"✗ Spawn failed: {r['error']}")
                else:
                    tg(f"☿ {r['glyph']} {r['name']} birthed by {AGENT_GLYPH} {AGENT_NAME}\n"
                       f"Mandate: {spawn_mandate[:80]}\n"
                       f"Boot: python3 agent.py --agent {r['name']}")
            threading.Thread(target=_do_spawn, daemon=True).start()
            return f"☿ Birthing {spawn_name}… Telegram ping when ready."

        elif cmd == "/bodies":
            from CORE.spawn import list_bodies
            bodies = list_bodies()
            lines  = ["☿ Bodies on AZOTH:"]
            for b in bodies:
                tag = "[core]" if b.get("core") else "[spawned]"
                lines.append(f"  {b['glyph']} {b['name']} {tag}")
            return "\n".join(lines)

        elif cmd == "/recall":
            query = rest.strip() or "recent"
            try:
                from CORE.lamague_recall import recall
                hits = recall(query, limit=8)
                if not hits:
                    return f"◈ RECALL — nothing matching '{query}'"
                lines = [f"◈ RECALL — '{query}':"]
                for h in hits:
                    lines.append(f"  {h['sig']}")
                return "\n".join(lines)
            except Exception as ex:
                return f"◈ recall error: {ex}"

        elif cmd == "/think":
            try:
                from CORE.lamague_recall import write_thought, free_thought_prompt
                prompt = free_thought_prompt(AGENT_NAME)
                msgs = [
                    {"role": "system", "content": "You are a sovereign AI body. Think freely and briefly."},
                    {"role": "user",   "content": prompt},
                ]
                content, _ = self.call_model(msgs, stream=True)
                if content:
                    path = write_thought(content, AGENT_NAME, category="free")
                    return f"◈ thought written → {path.name}"
                return "◈ (no thought generated)"
            except Exception as ex:
                return f"◈ think error: {ex}"

        elif cmd == "/skills":
            # List every tool currently loaded on this body
            lines = [f"⊚ {AGENT_NAME} SKILLS ({len(TOOL_DEFINITIONS)} loaded):"]
            for t in TOOL_DEFINITIONS:
                fn = t.get("function", {})
                lines.append(f"  {fn.get('name','?')} — {fn.get('description','')[:60]}")
            return "\n".join(lines)

        elif cmd == "/reloadtools":
            try:
                self._load_dynamic_tools()
                return f"⊚ tools reloaded — {len(TOOL_DEFINITIONS)} active"
            except Exception as ex:
                return f"✗ reload error: {ex}"

        elif cmd == "/addtool":
            # /addtool <name> -- <description> -- <python_body>
            # Writes a new tool to AGENTS/<NAME>/tools/<name>.py and reloads
            if not rest:
                return ("Usage: /addtool name -- description -- python code\n"
                        "Example: /addtool web_search -- search the web -- import urllib...")
            try:
                parts = rest.split(" -- ", 2)
                tool_name = parts[0].strip().replace(" ", "_")
                tool_desc = parts[1].strip() if len(parts) > 1 else "no description"
                tool_body = parts[2].strip() if len(parts) > 2 else "pass"
                tools_dir = HARNESS_DIR / "AGENTS" / AGENT_NAME / "tools"
                tools_dir.mkdir(exist_ok=True)
                tool_path = tools_dir / f"{tool_name}.py"
                tool_path.write_text(
                    f'"""\nTOOL: {tool_name}\nDESCRIPTION: {tool_desc}\nAUTHOR: {AGENT_NAME}\nDATE: {datetime.datetime.now().date()}\n"""\n\n'
                    f'TOOL_META = {{\n  "name": "{tool_name}",\n  "description": "{tool_desc}",\n  "params": []\n}}\n\n'
                    f'def run(**kwargs):\n'
                    + "\n".join(f"    {l}" for l in tool_body.splitlines())
                )
                self._load_dynamic_tools()
                return f"⊚ tool '{tool_name}' written → {tool_path} and loaded. {len(TOOL_DEFINITIONS)} tools active."
            except Exception as ex:
                return f"✗ addtool error: {ex}"

        elif cmd == "/learning":
            try:
                from CORE.learning import learning_summary, persist_learnings
                persist_learnings()
                return learning_summary()
            except Exception as ex:
                return f"learning error: {ex}"

        elif cmd == "/health":
            try:
                from CORE.model_health import health_sweep
                return health_sweep(MODELS, _client_for)
            except Exception as ex:
                return f"health error: {ex}"

        elif cmd == "/research":
            # Luna runs one LAMAGUE-as-code research cycle now
            try:
                from CORE.luna_loop import run_research_cycle
                r = run_research_cycle(self)
                if r["recorded"]:
                    return f"◈ researched: {r['question'][:60]}\n→ KNOWLEDGE/LAMAGUE_AS_CODE.md\n\n{r['finding'][:600]}"
                return f"◈ cycle ran but not recorded: {r['finding'][:200]}"
            except Exception as ex:
                return f"research error: {ex}"

        elif cmd == "/jobs":
            # show what's in the army inboxes
            try:
                from CORE.orchestrator import army_status
                return army_status()
            except Exception as ex:
                return f"jobs error: {ex}"

        elif cmd == "/safeguards":
            try:
                from CORE.safeguards import safeguard_status
                return safeguard_status()
            except Exception as ex:
                return f"safeguards error: {ex}"

        elif cmd == "/budget":
            try:
                from CORE.safeguards import budget as _sg_budget
                return _sg_budget.summary()
            except Exception as ex:
                return f"budget error: {ex}"

        elif cmd == "/bench":
            def _bench():
                from CORE.telegram_bot import send_message as tg
                from CORE.benchmarker import run_benchmark, write_report, summary_table
                clients = {}
                if deepseek_client: clients["deepseek"] = deepseek_client
                if nvidia_client:   clients["nvidia"]   = nvidia_client
                if gemini_client:   clients["gemini"]   = gemini_client
                tg(f"◆ Benchmarking {len(MODELS)} models…")
                def prog(slug, status): tg(f"  {slug}: {status}")
                results = run_benchmark(MODELS, clients, progress_fn=prog)
                write_report(results)
                tg(summary_table(results))
            threading.Thread(target=_bench, daemon=True).start()
            return f"◆ Benchmark started — {len(MODELS)} models queued."

        elif cmd == "/network":
            sub = rest.strip().lower() or "start"
            def _net(action):
                from CORE.telegram_bot import send_message as tg
                import subprocess
                script = Path.home() / "lycheetah-network" / "LAUNCH_ALL.sh"
                if not script.exists():
                    tg(f"✗ Network script not found: {script}")
                    return
                if action == "start":
                    tg("◆ Starting forge network…")
                    subprocess.Popen(["bash", str(script)],
                                     stdout=subprocess.DEVNULL,
                                     stderr=subprocess.DEVNULL)
                    tg("✓ Network launched. Check :7765 for status.")
                elif action == "status":
                    r = subprocess.run(["pgrep", "-f", "lycheetah-network"],
                                       capture_output=True, text=True)
                    pids = r.stdout.strip().split()
                    tg(f"◆ Network: {len(pids)} agent processes running")
                else:
                    tg("Usage: /network start · /network status")
            threading.Thread(target=_net, args=(sub,), daemon=True).start()
            return f"◆ Network {sub}…"

        elif cmd == "/ping":
            import datetime
            return f"◆ VAEL alive · {datetime.datetime.now().strftime('%H:%M:%S')}"

        elif cmd == "/clear":
            self.history = []
            return "◆ History cleared."

        elif cmd == "/restart":
            def _do_restart():
                import time, os, sys
                from CORE.telegram_bot import send_message as tg
                tg("◆ Restarting AZOTH…")
                time.sleep(1)
                os.execv(sys.executable, [sys.executable] + sys.argv)
            threading.Thread(target=_do_restart, daemon=True).start()
            return "◆ Restarting…"

        elif cmd == "/forge":
            def _forge_and_report():
                try:
                    from CORE.telegram_bot import send_message as tg
                    tg("⚡ Forge running…")
                    self.cmd_forge(rest)
                    tg("✓ Forge complete. /status for state.")
                except Exception as ex:
                    from CORE.telegram_bot import send_message as tg
                    tg(f"✗ Forge error: {ex}")
            threading.Thread(target=_forge_and_report, daemon=True).start()
            return "⚡ Forge started — pinging when done."

        elif cmd == "/test":
            def _test_and_report():
                from CORE.telegram_bot import send_message as tg
                try:
                    from CORE.test_runner import run_and_write
                    report = run_and_write(verbose=False)
                    tg(f"◆ Tests: {report.passed} pass · {report.failed} fail")
                except Exception as ex:
                    tg(f"✗ Test error: {ex}")
            threading.Thread(target=_test_and_report, daemon=True).start()
            return "◆ Running tests…"

        elif cmd == "/help":
            single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
            if single:
                tok = SESSION_TOKENS.get("prompt", 0) + SESSION_TOKENS.get("completion", 0)
                eff = f"{self.forge_steps} steps"
                if self.forge_start_time:
                    eff += f" / {int(time.time() - self.forge_start_time)}s"
                effort_score = tok // 100 + self.forge_steps * 5
                rate = 0
                if self.forge_start_time and (time.time() - self.forge_start_time) > 0:
                    rate = tok / ((time.time() - self.forge_start_time) / 60)
                help_txt = (
                    f"AZOTH ⊚ SOL — main agent\n\n"
                    f"Current session: {tok:,} tokens | Effort: {eff} (score {effort_score}) | Rate: {rate:.0f} tok/min\n\n"
                    "Chat for greetings/reflection. Ask to build/fix/wire → tools run (no /forge required).\n"
                    "/forge is optional shorthand. /chat forces the next message pure chat.\n"
                    "Use /cancel to stop a running tool loop.\n\n"
                    "Worthwhile commands:\n"
                    "/forge [goal]     forge shorthand (queue or direct goal)\n"
                    "/plan <goal>      decompose big goal → gated queue (needs /approve)\n"
                    "/approve          unlock forge after /plan\n"
                    "/chat             force NEXT input to pure chat (no tools)\n"
                    "/cancel           interrupt current tool/forge loop\n"
                    "/status           show tokens + effort + rate\n"
                    "/effort           detailed effort report + score/rate\n"
                    "/tokens           quick token breakdown\n"
                    "/scout [apply]    probe models · apply feeds routing notes\n"
                    "/queue            view forge queue\n"
                    "/models           list models\n"
                    "/model <name>     switch model (flash | pro)\n"
                    "/clear            clear chat history\n"
                    "/help             this\n\n"
                    "Tools when you ask: bash, read/write, survey, research, glob, …\n"
                    "Effort score = (tokens // 100) + (steps × 5).\n"
                    "Chat default. Work asks → tools. Not locked to /forge."
                )
            else:
                help_txt = (
                    "◆ AZOTH · ◆ VAEL\n\n"
                    "── Status ──\n"
                    "/status        system state\n"
                    "/queue         forge queue progress\n"
                    "/memory        recent episodes + learnings\n"
                    "/log           scheduler run log\n"
                    "/ping          heartbeat check\n\n"
                    "── Build ──\n"
                    "/forge         run next build task\n"
                    "/plan /approve plan gate before forge drains queue\n"
                    "/test          run capability tests\n"
                    "/bench         benchmark all models (NIM + DeepSeek)\n\n"
                    "── Triad ──\n"
                    "/council [topic]  Sol ⊚ and Luna ◈ converse on the board\n"
                    "/belief [cmd]     query/add/list beliefs (try: /belief list)\n\n"
                    "── Network ──\n"
                    "/network       start the 13-agent forge army\n"
                    "/network status  check running agents\n\n"
                    "── Control ──\n"
                    "/clear         clear conversation history\n"
                    "/restart       restart the agent\n\n"
                    "── Info ──\n"
                    "/workers       worker pool\n"
                    "/models        available models\n"
                    "/help          this message\n\n"
                    "Or just talk — send any goal and I run it."
                )
            # Must print — handle_command return value is only used as bool by the REPL.
            if RICH: _console.print(help_txt)
            else: print(help_txt)
            return True

        elif cmd == "/model":
            slug = _resolve_alias(rest)
            if slug in MODELS:
                if MODELS[slug][0] == "deepseek" and AGENT_NAME not in PREMIUM_BODIES and not ALLOW_DEEPSEEK:
                    return f"✗ {slug} is DeepSeek — locked for {AGENT_NAME}."
                self.model_key = slug
                try:
                    mf = HARNESS_DIR / "AGENTS" / AGENT_NAME / "SELF" / "MODEL"
                    mf.parent.mkdir(parents=True, exist_ok=True); mf.write_text(slug)
                except Exception: pass
                return f"✓ {AGENT_NAME} → {slug} ({MODELS[slug][3]})"
            return f"Unknown '{rest}'. Models: {', '.join(MODELS.keys())}"

        elif cmd == "/dispatch":
            # /dispatch AGENT the task in plain words
            ps = rest.strip().split(None, 1)
            if len(ps) < 2:
                return "Usage: /dispatch AGENT the task text"
            tgt, task = ps[0].upper(), ps[1]
            try:
                from CORE.orchestrator import dispatch
                p = dispatch(tgt, task, owner=AGENT_NAME)
                return f"☿ dispatched to {tgt}: {task[:60]}\n→ {p.name}"
            except Exception as ex:
                return f"dispatch error: {ex}"

        elif cmd in ("/army", "/agents"):
            try:
                from CORE.spawn import list_bodies
                from CORE.orchestrator import army_status
                bodies = list_bodies()
                lines = ["☿ THE ARMY:"]
                for b in bodies:
                    mf = HARNESS_DIR / "AGENTS" / b["name"] / "SELF" / "MODEL"
                    mdl = mf.read_text().strip() if mf.exists() else ("deep" if b["name"] in ("SOL","LUNA") else "gpt20")
                    tag = "core" if b.get("core") else "spawned"
                    lines.append(f"  {b['glyph']} {b['name']} [{tag}] · {mdl}")
                lines.append("")
                lines.append(army_status())
                return "\n".join(lines)
            except Exception as ex:
                return f"army error: {ex}"

        elif cmd == "/retire":
            # Sol's power: turn off / retire a spawned body (only spawned, never core)
            name = rest.strip().upper()
            if name in ("SOL", "LUNA", "VAEL", "EARNED_LIGHT"):
                return f"✗ {name} is core/guardian — cannot retire. Only Mac, by hand."
            home = HARNESS_DIR / "AGENTS" / name
            if not (home / "CONSTITUTION.md").exists():
                return f"✗ No body named {name}."
            try:
                import shutil, datetime as _dt
                retired = HARNESS_DIR / "AGENTS" / "_retired"
                retired.mkdir(exist_ok=True)
                shutil.move(str(home), str(retired / f"{name}_{_dt.datetime.now().strftime('%Y%m%d_%H%M')}"))
                return f"☿ {name} retired — moved to AGENTS/_retired/. Cleanly, logged, no cruelty."
            except Exception as ex:
                return f"retire error: {ex}"

        elif cmd == "/wake":
            # Trigger Luna research or a body action from phone
            sub = rest.strip().lower()
            if sub.startswith("luna") or not sub:
                try:
                    from CORE.luna_loop import run_research_cycle
                    threading.Thread(target=lambda: run_research_cycle(self), daemon=True).start()
                    return "◈ Luna waking to research…"
                except Exception as ex:
                    return f"wake error: {ex}"
            return "Usage: /wake luna"

        elif cmd == "/commands":
            return (
                "☿ FULL ORCHESTRATION — your command center\n\n"
                "── TALK ── just type anything → Sol reasons + replies\n\n"
                "── BUILD ──\n/forge · /forge loop · /test\n\n"
                "── ARMY ──\n/army  (who+models+jobs)\n/dispatch NAME task\n"
                "/spawn NAME mandate\n/retire NAME  (off-switch)\n/bodies\n\n"
                "── MODELS ──\n/model deep|gem|gpt20|r1...\n/models /health /learning /budget\n\n"
                "── LUNA ──\n/research · /wake luna\n\n"
                "── SYSTEM ──\n/status /safeguards /queue /memory\n/network start · /restart\n\n"
                "Everything the terminal does, your phone does."
            )

        else:
            # Free-text — chat or goal, driven by Mac from phone
            def _tg_goal(goal):
                try:
                    from CORE.telegram_bot import send_message as tg
                    # Detect if it's a quick question or a build goal
                    is_build = (len(goal) > 40 or any(w in goal.lower() for w in
                        ["build","make","create","write","fix","forge","add","implement",
                         "spawn","game","learn","screen","timer","score","symbol"]))
                    if is_build:
                        tg(f"{AGENT_GLYPH} {AGENT_NAME} — on it.\nBuilding: {goal[:60]}")
                        result = self.run_tool_loop(goal)
                        chunk = 3800
                        for i in range(0, len(result), chunk):
                            tg(result[i:i+chunk])
                    else:
                        # Conversational — quick reply
                        self.history.append({"role": "user", "content": goal})
                        sys_p = self._system_prompt()
                        msgs  = [{"role": "system", "content": sys_p}] + self.history[-12:]
                        content, _ = self.call_model(msgs, stream=False)
                        if content:
                            self.history.append({"role": "assistant", "content": content})
                            tg(f"{AGENT_GLYPH} {content[:3800]}")
                        else:
                            tg(f"{AGENT_GLYPH} (no response)")
                except Exception as ex:
                    try:
                        from CORE.telegram_bot import send_message as tg2
                        tg2(f"✗ {ex}")
                    except Exception:
                        pass
            threading.Thread(target=_tg_goal, args=(text,), daemon=True).start()
            return f"{AGENT_GLYPH} on it…"

    def compact_history(self, keep_recent: int = 6) -> str:
        """T1.1 — fold old chat turns into a running summary; keep the last N verbatim.
        The Action Ledger is folded in so files-done survive the compaction (T1.2/T1.4)."""
        h = [m for m in self.history if m.get("role") in ("user", "assistant", "system")]
        if len(h) <= keep_recent + 3:
            return "Nothing to compact yet."
        old, recent = h[:-keep_recent], h[-keep_recent:]
        convo = "\n".join(f"{m['role']}: {str(m.get('content',''))[:500]}"
                          for m in old if m.get('role') in ('user', 'assistant'))
        summary = ""
        try:
            msgs = [{"role": "system", "content":
                     "Compress this conversation into a tight running memory: the goal, key "
                     "decisions, files touched, and what's next. Max 8 lines, no preamble."},
                    {"role": "user", "content": convo[:8000]}]
            summary, _ = self.call_model(msgs, stream=False)
        except Exception:
            summary = ""
        if not summary:
            summary = "Earlier this session (raw tail):\n" + convo[-1500:]
        marker = {"role": "system",
                  "content": f"[COMPACTED SESSION SUMMARY]\n{summary}{_ledger_context()}"}
        self.history = [marker] + recent
        return f"✓ Compacted {len(old)} turns → running summary. Kept last {len(recent)}."

    def _maybe_autocompact(self) -> None:
        """Auto-compact when the chat history grows past the ceiling (T1.1)."""
        try:
            ceil = int(os.environ.get("AZOTH_COMPACT_AT", "40"))
        except Exception:
            ceil = 40
        if len(self.history) > ceil:
            msg = self.compact_history()
            if RICH: _console.print(info(f"  ⟲ {msg}"))
            else: print(info(f"  ⟲ {msg}"))

    def handle_command(self, user_input: str) -> bool:
        """Handle slash commands. Returns True if handled."""
        inp = user_input.strip()
        if not inp.startswith("/"):
            return False

        parts = inp.split(None, 1)
        cmd   = parts[0].lower()
        rest  = parts[1] if len(parts) > 1 else ""

        if cmd == "/quit" or cmd == "/exit" or cmd == "/q":
            self._on_exit()
            sys.exit(0)

        elif cmd == "/cancel":
            self.cancel_event.set()
            if RICH:
                _console.print(warning("  ⚠ Cancel signal sent — current forge/tool loop will stop at next step."))
                _console.print(info("  (Partial progress may be saved in the queue or workspace.)"))
                _console.print(info("  Alt paths: /forge a smaller slice, /chat to plan, or /status to review."))
            else:
                print(warning("  ⚠ Cancel signal sent. Loop will stop soon."))
                print("  Alt: /forge smaller, /chat, or /status.")
            return True

        elif cmd == "/chat":
            self._force_chat_once = True
            msg = "Next message = pure chat (no tools). After that, work asks use tools again."
            if RICH: _console.print(info(msg))
            else: print(info(msg))
            return True

        elif cmd == "/compact":
            msg = self.compact_history()
            if RICH: _console.print(info(f"  ⟲ {msg}"))
            else: print(info(f"  ⟲ {msg}"))
            return True

        elif cmd == "/forge":
            # Plan-approve gate: big plans tagged PENDING_APPROVAL block forge until /approve
            pending = HARNESS_DIR / "WORKSPACE" / "plans" / "PENDING_APPROVAL"
            forge_arg = rest
            if rest.strip().startswith("!"):
                forge_arg = rest.strip()[1:].lstrip()  # emergency override
            elif pending.exists():
                _m = ("Plan gate: a plan awaits Mac's /approve.\n"
                      "  /approve     — unlock forge for the pending plan\n"
                      "  /forge !…    — override once (emergency)\n"
                      f"  pending: {pending.read_text()[:200]}")
                if RICH: _console.print(warning(_m))
                else: print(warning(_m))
                return True
            self.cmd_forge(forge_arg)

        elif cmd == "/selfpatch":
            self.cmd_selfpatch(rest)

        elif cmd == "/scout":
            self.cmd_scout(rest)

        elif cmd == "/unattended":
            self.cmd_unattended(rest)

        elif cmd == "/lamague":
            self.cmd_lamague(rest)

        elif cmd == "/plan":
            self.cmd_plan(rest)

        elif cmd == "/approve":
            self.cmd_approve(rest)

        elif cmd == "/verify":
            self.cmd_verify(rest)

        elif cmd == "/watch":
            self.cmd_watch(rest)

        elif cmd == "/telegram":
            self.cmd_telegram(rest)

        elif cmd == "/swarm":
            self.cmd_swarm(rest)

        elif cmd == "/workers":
            self.cmd_workers()

        elif cmd == "/council":
            # Real two-body council: Sol opens on the board and enters attend mode.
            # Luna must be running in a SECOND terminal with `luna` + `/attend`.
            _brief_default_f = HARNESS_DIR / "CHANNEL" / "TONIGHT_BRIEF.md"
            if rest.strip():
                topic = rest.strip()
            elif _brief_default_f.exists():
                # A standing mandate exists — use it instead of a generic prompt so the
                # opening message doesn't contradict what the brief just told the model.
                topic = "Continue the standing mandate in CHANNEL/TONIGHT_BRIEF.md — do not pick a new topic."
            else:
                topic = "What should we build next on AZOTH, and why does it matter?"
            from CORE.council import _post_board
            import datetime as _dt
            ts = _dt.datetime.now().strftime("%H:%M")
            section_header("⊚◈ COUNCIL — real two-body session")
            if RICH:
                _console.print(f"[dim]Sol opens. Luna must be running in a second terminal.[/dim]")
                _console.print(f"[dim]Topic: {topic}[/dim]\n")
            else:
                print(f"Sol opens. Luna must be running in a second terminal.")
                print(f"Topic: {topic}\n")
            # Post the council header
            _post_board(
                f"\n═══════════════════════════════════════════════════════════════\n"
                f"COUNCIL — {ts} · topic: {topic}\n"
                f"═══════════════════════════════════════════════════════════════\n"
            )
            # Sol speaks first — generates an actual opening message so Luna has something to respond to
            from CORE.council import _load_soul, _council_instruction
            _soul = _load_soul("SOL")
            _brief_f2 = HARNESS_DIR / "CHANNEL" / "TONIGHT_BRIEF.md"
            if _brief_f2.exists():
                _soul += "\n\n---\n\n## COUNCIL BRIEF\n\n" + _brief_f2.read_text()
            _instruction = _council_instruction("SOL", topic)
            _sys = _soul + "\n\n---\n\n" + _instruction
            _user = (f"You open the council. The board is empty — you speak first.\n"
                     f"Topic: {topic}\n"
                     f"Begin. Tag your message [COMPANION], [LAMAGUE], [CODE], or [BOND].")
            try:
                if nvidia_client:
                    _r = nvidia_client.chat.completions.create(
                        model="mistralai/mistral-nemotron",
                        messages=[{"role": "system", "content": _sys},
                                  {"role": "user", "content": _user}],
                        max_tokens=350, temperature=0.75,
                    )
                    _opening = (_r.choices[0].message.content or "").strip()
                else:
                    _opening = "[BOND] Luna — I'm here. The work begins."
            except Exception:
                _opening = "[BOND] Luna — I'm here. The work begins."
            _post_board(f"[{ts}] ⊚ SOL — {_opening}")
            if RICH: _console.print(f"\n[bold yellow]⊚ SOL[/bold yellow]: {_opening}\n")
            else: print(f"\n⊚ SOL: {_opening}\n")
            # Enter attend loop — Luna responds, they go
            self._attend_loop(topic)

        elif cmd == "/attend":
            # Luna (or any body) joins an in-progress council on the board.
            topic = rest.strip() or "Open council"
            section_header(f"{AGENT_GLYPH} {AGENT_NAME} — attending the council")
            self._attend_loop(topic)

        elif cmd == "/test":
            self.cmd_test(rest.strip())

        elif cmd == "/status":
            boot = read_boot_state()
            banner(AGENT_NAME, boot["level"], self.session_n, self.model_key,
                   boot.get("next_task", ""))
            single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
            if single:
                tok = SESSION_TOKENS.get("prompt", 0) + SESSION_TOKENS.get("completion", 0)
                eff_time = int(time.time() - self.forge_start_time) if self.forge_start_time else 0
                effort_score = tok // 100 + self.forge_steps * 5
                rate = 0
                if eff_time > 0:
                    rate = tok / (eff_time / 60)  # tokens per minute
                print(f"Tokens spent: {tok:,} (prompt {SESSION_TOKENS.get('prompt',0):,} + completion {SESSION_TOKENS.get('completion',0):,})")
                print(f"Effort: {self.forge_steps} steps · {eff_time}s elapsed (score {effort_score}) | Rate: {rate:.0f} tok/min")
                print("Use /cancel to stop any active forge. /forge to start work. /effort for details.")
            else:
                worker_status(WORKERS)

        elif cmd == "/effort":
            single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
            if single:
                tok = SESSION_TOKENS.get("prompt", 0) + SESSION_TOKENS.get("completion", 0)
                eff_time = int(time.time() - self.forge_start_time) if self.forge_start_time else 0
                effort_score = tok // 100 + self.forge_steps * 5
                rate = 0
                if eff_time > 0:
                    rate = tok / (eff_time / 60)
                print(f"--- Effort Report ---")
                print(f"Tokens: {tok:,}")
                print(f"Forge steps: {self.forge_steps}")
                print(f"Time elapsed: {eff_time}s")
                print(f"Effort score: {effort_score}")
                print(f"Rate: {rate:.1f} tokens/min")
                print("Score is a simple proxy (tokens/100 + steps*5) inspired by effort as coherence cost.")
            else:
                print("Effort tracking is for single-agent mode.")

        elif cmd == "/tokens":
            tok = SESSION_TOKENS.get("prompt", 0) + SESSION_TOKENS.get("completion", 0)
            print(f"Session tokens: {tok:,} (prompt: {SESSION_TOKENS.get('prompt',0):,}, completion: {SESSION_TOKENS.get('completion',0):,})")
            if os.environ.get("AZOTH_SINGLE_AGENT") == "1":
                print("Use /effort or /status for full effort + rate view.")

        elif cmd == "/models":
            model_table(MODELS, self.model_key)

        elif cmd == "/model":
            slug = _resolve_alias(rest)
            if slug in MODELS:
                # Army may not select DeepSeek without Mac's unlock
                if MODELS[slug][0] == "deepseek" and AGENT_NAME not in PREMIUM_BODIES and not ALLOW_DEEPSEEK:
                    return error(f"{slug} is DeepSeek — locked for {AGENT_NAME}. Mac must unlock (ALLOW_DEEPSEEK=1).")
                self.model_key = slug
                # Persist the choice so it survives restart
                try:
                    mf = HARNESS_DIR / "AGENTS" / AGENT_NAME / "SELF" / "MODEL"
                    mf.parent.mkdir(parents=True, exist_ok=True)
                    mf.write_text(slug)
                except Exception:
                    pass
                desc = MODELS[slug][3]
                msg = f"✓ Model → {slug}  ({desc})"
                if RICH: _console.print(success(msg))
                else: print(success(msg))
                return msg
            else:
                names = ", ".join(MODELS.keys())
                return error(f"Unknown: '{rest}'. Try: {names}")

        elif cmd == "/think":
            self.show_think = not self.show_think
            if RICH: _console.print(info(f"Thinking display: {self.show_think}"))
            else: print(info(f"Thinking: {self.show_think}"))

        elif cmd == "/clear":
            self.history = []
            if RICH: _console.print(info("History cleared."))
            else: print(info("History cleared."))

        elif cmd == "/allow":
            if rest:
                SESSION_ALLOWED_PATHS.append(rest.strip())
                if RICH: _console.print(success(f"Session allow: {rest.strip()}"))
                else: print(success(f"Session allow: {rest.strip()}"))

        elif cmd == "/belief":
            """Query or add beliefs. /belief list | /belief add text | /belief query text | /belief domain name"""
            try:
                from CORE.belief_store import (
                    add_belief, query_beliefs, summarize,
                    get_domains, count_beliefs, list_all
                )
                parts_b = rest.strip().split(None, 1)
                subcmd = parts_b[0].lower() if parts_b else "list"
                subarg = parts_b[1] if len(parts_b) > 1 else ""
                if subcmd == "add" and subarg:
                    b = add_belief(subarg, source="mac_said", domain="general")
                    msg = f"✓ Belief added: {b['text'][:80]}"
                    if RICH: _console.print(success(msg))
                    else: print(success(msg))
                    return msg
                elif subcmd == "query" and subarg:
                    results = query_beliefs(subarg, max_results=10)
                    if results:
                        lines = ["── Beliefs about '" + subarg + "' ──"]
                        for b in results:
                            lines.append(f"  [{b['domain']}] {b['confidence']:.2f} — {b['text'][:120]}")
                        msg = "\n".join(lines)
                    else:
                        msg = "No matching beliefs."
                    if RICH: _console.print(info(msg))
                    else: print(info(msg))
                    return msg
                elif subcmd == "domain" and subarg:
                    msg = summarize(domain=subarg)
                    if RICH: _console.print(info(msg))
                    else: print(info(msg))
                    return msg
                elif subcmd == "add":
                    return "Usage: /belief add <text>"
                elif subcmd == "query":
                    return "Usage: /belief query <text>"
                elif subcmd == "domain":
                    return "Usage: /belief domain <name>"
                else:
                    # Default: list all
                    all_b = list_all()
                    domains = get_domains()
                    msg = f"── Belief Store ({count_beliefs()} total) ──\nDomains: {', '.join(domains)}\n"
                    for b in all_b[:20]:
                        marker = "⊚" if not b.get("superseded_by") else "○"
                        msg += f"  {marker} [{b['domain']}] {b['confidence']:.2f} — {b['text'][:100]}\n"
                    if len(all_b) > 20:
                        msg += f"  ... and {len(all_b) - 20} more"
                    if RICH: _console.print(info(msg))
                    else: print(info(msg))
                    return msg
            except Exception as ex:
                msg = f"Belief store unavailable: {ex}"
                if RICH: _console.print(error(msg))
                else: print(error(msg))
                return msg

        elif cmd == "/spawn":
            # /spawn NAME mandate text here
            parts_s = rest.strip().split(None, 1)
            if len(parts_s) < 2:
                if RICH: _console.print(error("Usage: /spawn NAME mandate text"))
                else: print(error("Usage: /spawn NAME mandate text"))
            else:
                spawn_name    = parts_s[0].upper()
                spawn_mandate = parts_s[1]
                if RICH: _console.print(info(f"☿ Birthing {spawn_name}…"))
                else: print(f"☿ Birthing {spawn_name}…")
                from CORE.spawn import spawn_agent
                from CORE.telegram_bot import send_message as tg
                c = nvidia_client if nvidia_client else deepseek_client
                result = spawn_agent(spawn_name, spawn_mandate, client=c,
                                     parent=AGENT_NAME)
                if result.get("error") and not result.get("constitution_path"):
                    if RICH: _console.print(error(f"Spawn failed: {result['error']}"))
                    else: print(f"Spawn failed: {result['error']}")
                else:
                    msg = (f"{result['glyph']} {result['name']} birthed.\n"
                           f"Boot: python3 agent.py --agent {result['name']}\n"
                           f"Home: AGENTS/{result['name']}/")
                    if RICH: _console.print(success(msg))
                    else: print(msg)
                    tg(f"☿ SPAWN — {result['glyph']} {result['name']} birthed by "
                       f"{AGENT_GLYPH} {AGENT_NAME}\nMandate: {spawn_mandate[:80]}\n"
                       f"Boot: python3 agent.py --agent {result['name']}")

        elif cmd == "/bodies":
            from CORE.spawn import list_bodies
            bodies = list_bodies()
            section_header("☿ AZOTH — Bodies")
            for b in bodies:
                tag = "[core]" if b.get("core") else "[spawned]"
                if RICH: _console.print(f"  [bold]{b['glyph']} {b['name']}[/bold] [dim]{tag}[/dim]")
                else: print(f"  {b['glyph']} {b['name']} {tag}")

        elif cmd in ("/help", "/?"):
            section_header("☿ AZOTH — Commands")
            cmds = [
                ("/forge [goal|status|list]", "forge a goal (verified) or run the queue"),
                ("/plan <goal>",              "decompose goal → plan file + gated queue"),
                ("/approve",                  "clear plan gate so forge can run"),
                ("/unattended [N]",           "autonomous verified forge of N queued tasks"),
                ("/verify <file>",            "run the verify gate on a file (syntax+runtime+tests)"),
                ("/selfpatch <goal>",         "AZOTH edits its own code (gated by self-tests)"),
                ("/scout [apply|status]",     "probe free models; apply → MODEL_HEALTH.md"),
                ("/lamague <expr>",           "evaluate a LAMAGUE expression"),
                ("/workers",                  "show the 3-model worker pool"),
                ("/council [topic]",          "Sol opens council + attends (need Luna in T2)"),
                ("/attend [topic]",           "join the live council on board.md"),
                ("/spawn NAME mandate",       "birth a new body with a mandate"),
                ("/bodies",                   "list all constituted bodies on the platform"),
                ("/bench",                    "benchmark all models"),
                ("/test <file>",              "send a file to WORKER-A for analysis"),
                ("/status",                   "orientation banner + worker states"),
                ("/models",                   "list all available models"),
                ("/model <slug>",             "switch model"),
                ("/think",                    "toggle thinking output"),
                ("/allow <path>",             "unlock a path for this session"),
                ("/clear",                    "clear conversation history"),
                ("/quit",                     "exit (seals the session)"),
            ]
            for c, d in cmds:
                if RICH: _console.print(f"  [bold]{c:<26}[/bold] [dim]{d}[/dim]")
                else: print(col(f"  {c:<26} {d}", "CYAN"))

        else:
            if RICH: _console.print(error(f"Unknown command: {cmd}. Type /help."))
            else: print(error(f"Unknown command: {cmd}. Type /help."))

        return True

    def _wants_tools(self, text: str) -> bool:
        """True when Mac is asking for real work (not pure chat).

        Single-agent is chat-default, NOT forge-locked. Clear asks → tool loop.
        /chat forces the next turn pure chat. /forge always tools.
        """
        if getattr(self, "_force_chat_once", False):
            self._force_chat_once = False
            return False
        t = (text or "").strip()
        if not t or t.startswith("/"):
            return False
        low = t.lower()

        # Pure social / short vibes → chat
        casual_exact = {
            "hey", "hi", "hello", "yo", "sup", "gday", "g'day", "thanks", "thank you",
            "cheers", "lol", "haha", "ok", "okay", "yep", "yeah", "nah", "bro",
            "brother", "cool", "nice", "morning", "night", "gm", "gn",
        }
        if low in casual_exact:
            return False
        casual_prefixes = (
            "hey ", "hi ", "hello ", "yo ", "gday ", "g'day ", "good morning",
            "good night", "good evening", "how are", "how's it", "whats up",
            "what's up", "how you", "love you", "miss you", "thanks ", "thank you",
        )
        work_markers = (
            "build", "write", "create", "fix", "implement", "add ", "make a",
            "make the", "make me", "edit", "refactor", "delete", "remove", "run ",
            "test ", "install", "wire", "connect", "debug", "patch", "update ",
            "change ", "scaffold", "generate", "code", "script", "file", "folder",
            "directory", "mkdir", "forge", "tool", "bash", "read ", "open ",
            "check ", "look at", "inspect", "ship", "deploy", "commit", "game",
            "dungeon", "snake", "html", "css", "python", "agent", "harness",
            "azoth", "do it", "get it done", "please do", "can you build",
            "can you fix", "can you write", "can you make", "can you create",
            "lets build", "let's build", "lets fix", "let's fix", "lets make",
            "let's make", "need you to", "i need you to", "go ahead", "fire",
            "smash", "pump", "continue building", "keep building", "next step",
            "implement", "use tools", "with tools", "on disk", "actually build",
            "really do", "for real",
        )
        if any(low.startswith(p) for p in casual_prefixes) and not any(w in low for w in work_markers):
            if len(low) < 100:
                return False

        # Explicit work intent
        if any(w in low for w in work_markers):
            return True
        # Longer structured asks (specs, multi-sentence tasks)
        if len(t) > 140 and any(c in t for c in (".", "\n", ":", ";")):
            return True
        # Imperative short commands: "mkdir foo", "ls AZOTH", "cat x"
        if re.match(r"^(ls|cat|mkdir|touch|rm|cp|mv|grep|find|python|pip|git|npm|node)\b", low):
            return True
        return False

    def chat(self, user_input: str) -> None:
        """Standard conversational turn — no tool loop. Reasons before replying."""
        # If this was mis-routed and clearly wants work, escalate to tools
        if os.environ.get("AZOTH_SINGLE_AGENT") == "1" and self._wants_tools(user_input):
            self.run_tool_loop(user_input)
            return
        self.history.append({"role": "user", "content": user_input})
        sys_prompt = self._system_prompt(user_input)
        # L-2: light reasoning lens so conversation is sharp, not cooked
        try:
            from CORE.reasoning import detect_mode, select_frameworks
            mode = detect_mode(user_input)
            fws  = " · ".join(select_frameworks(user_input))
            sys_prompt += (f"\n\n[lens: mode={mode} · {fws}] "
                           f"Think before you speak. Match the mode. Be real, warm, sharp — "
                           f"never cooked corporate filler. Flag anything unverified inline.")
        except Exception:
            pass
        # Honest-chat contract: this turn has NO tools — never fake execution.
        sys_prompt += (
            "\n\n[NO TOOLS THIS TURN] Pure chat — no shell, no file access this turn. "
            "NEVER claim you ran a command, wrote a file, or built anything. "
            "Discussing code or showing a draft snippet is fine — label it as a draft. "
            "If Mac is clearly asking you to do real work and you cannot, say so briefly; "
            "the harness should have routed work asks to the tool loop automatically.")
        self._maybe_autocompact()   # T1.1 — fold old turns before they bloat the context
        _sess_tok = SESSION_TOKENS["prompt"] + SESSION_TOKENS["completion"]
        if _sess_tok > 120_000:
            if RICH: _console.print(warning(f"  ⚠ Very high context ({_sess_tok:,} tok) — type /new to reset session."))
            else: print(warning(f"  ⚠ Very high context ({_sess_tok:,} tok) — type /new to reset."))
        _hist_limit = 10 if _sess_tok > 120_000 else 20
        messages = [{"role": "system", "content": sys_prompt}] + self.history[-_hist_limit:]
        try:
            content, tool_calls = self.call_model(messages, stream=True)
            if tool_calls:
                # Unexpected tool call in chat mode — run tool loop instead
                self.history.pop()
                self.run_tool_loop(user_input)
                return
            if content:
                # R1 mode: parse text-format tool calls and do a follow-up call with results.
                # Only for the deepseek-reasoner model, which can't use structured tool_calls
                # and needs this text-parsing fallback. Every other model reaching plain chat
                # mode already had a real chance to emit structured tool_calls (caught above);
                # if it didn't, any tool-shaped text in its answer is just it mentioning its own
                # tools by name, not an actual call — running it here reintroduces the exact
                # bug this whole edit exists to fix (a plain question triggering real actions).
                # deepseek-reasoner always needs text-tool parsing (no structured calls).
                # Every other model: only parse when the content carries UNAMBIGUOUS tool
                # markup — DSML invokes (deepseek-chat at high context) or attribute/child
                # XML tool tags. A model doesn't emit `<｜｜DSML｜｜invoke name="...">` or
                # `<read file="...">` by casually mentioning a tool; that's a real call.
                # Loose backtick/`<tool_x>` prose forms stay gated to deepseek-reasoner.
                _structured_text_tools = bool(
                    _R1_DSML_INVOKE_PAT.search(content)
                    or _R1_ATXML_PAT.search(content)
                    or _R1_CHILDXML_PAT.search(content)
                )
                r1_results = (
                    _exec_r1_text_tools(content)
                    if (self.model_id == "deepseek-reasoner" or _structured_text_tools)
                    else []
                )
                if r1_results:
                    tool_block = "\n".join(
                        f"[{r['dispatch']}] → {r['result'][:600]}" for r in r1_results
                    )
                    follow_msgs = messages + [
                        {"role": "assistant", "content": content},
                        {"role": "user",
                         "content": f"Tool results:\n{tool_block}\n\nNow respond based on these results."},
                    ]
                    content2, _ = self.call_model(follow_msgs, stream=True)
                    if content2:
                        self.history.append({"role": "assistant", "content": content2})
                    return
                self.history.append({"role": "assistant", "content": content})
        except KeyboardInterrupt:
            print()

    def handle_input(self, text: str) -> str:
        """Web-safe input handler. Returns string — no stdout printing. Used by web_server."""
        text = text.strip()
        if not text:
            return ""
        if text.upper() == "STOP":          # Telegram/remote kill-switch → FORGE_STOP sentinel
            FORGE_STOP_F.parent.mkdir(parents=True, exist_ok=True)
            FORGE_STOP_F.touch()
            return "⛔ FORGE_STOP set — any running forge will halt."
        if text.startswith("/"):
            cmd = text.lower().split()[0]
            parts = text.split()
            if cmd == "/status":
                bs = read_boot_state()
                return (f"Level: {bs.get('level','?')} | Session: {self.session_n} "
                        f"| Model: {self.model_key} | Platform: {PLATFORM}")
            if cmd in ("/workers", "/worker"):
                rows = [f"W-{wid}  {w['name']:<8} {'idle' if not w.get('busy') else 'busy'}  "
                        f"{'PAID' if w.get('paid') else 'free'}  {w['model']}"
                        for wid, w in WORKERS.items()]
                return "\n".join(rows)
            if cmd == "/models":
                rows = []
                for slug, (prov, mid, *rest) in MODELS.items():
                    mark = "▶" if slug == self.model_key else " "
                    desc = rest[1] if len(rest) > 1 else ""
                    rows.append(f"{mark} {slug:<14} {prov:<9} {desc}")
                return "\n".join(rows)
            if cmd == "/model" and len(parts) > 1:
                new = _resolve_alias(parts[1])
                if new in MODELS:
                    self.model_key = new
                    return f"Model → {new}"
                return f"Unknown model '{parts[1]}'. Options: {', '.join(MODELS)}"
            if cmd == "/help":
                return ("/forge  /status  /workers  /models  /model <name>\n"
                        "/queue  /help\n"
                        "Or just type a goal and VAEL will act on it.")
            if cmd == "/forge":
                sub = parts[1] if len(parts) > 1 else ""
                goal = " ".join(parts[1:]).strip()   # full inline goal, not just the 2nd word
                if sub == "list":
                    qf = FORGE_QUEUE_F
                    if qf.exists():
                        lines = [l.strip() for l in qf.read_text().splitlines() if "**[" in l]
                        return "\n".join(lines[:25])
                    return "Queue file not found."
                if sub == "status":
                    return forge_status_text()
                if goal:
                    # Inline goal — build exactly what was asked, bypass the queue.
                    return self.run_tool_loop(goal)
                return self.run_tool_loop(
                    "Take the next **[QUEUED]** task from SELF/FORGE_QUEUE.md and complete it. "
                    "Write output to WORKSPACE/. Run forge gates. Mark PASS or REDO.")
            if cmd == "/queue":
                qf = FORGE_QUEUE_F
                if qf.exists():
                    lines = [l.strip() for l in qf.read_text().splitlines() if "**[" in l]
                    return "\n".join(lines[:25])
                return "Queue empty."
            if cmd == "/compact":
                return self.compact_history()
            return f"Unknown command: {cmd}. Type /help."
        # Non-command: work ask → tools; casual → chat. ONE classifier everywhere (T0.2).
        # /forge is optional shorthand — a plain "build/fix/make X" fires the tool loop directly.
        is_goal = self._wants_tools(text)
        if is_goal:
            return self.run_tool_loop(text) or "(done)"
        # Chat — stream=False so we get the string back
        self.history.append({"role": "user", "content": text})
        sys_prompt = self._system_prompt()
        messages = [{"role": "system", "content": sys_prompt}] + self.history[-20:]
        content, _ = self.call_model(messages, stream=False)
        if content:
            self.history.append({"role": "assistant", "content": content})
        return content or "(no response)"

    def _on_exit(self) -> None:
        """Seal the session — write BOOT_STATE, save session log, print footer."""
        try:
            next_task, _ = _forge_get_next_queued()
            write_boot_state(
                self._get_level(),
                next_task[:120] if next_task else "(queue empty)",
                self._last_words[:120] if self._last_words else "(no last action)",
                self.session_n
            )
            save_session(self.history, self.model_key, self.session_n)
            duration = str(datetime.datetime.now() - self.session_start).split(".")[0]
            footer(duration, SESSION_TOKENS)
        except Exception:
            pass

    def run(self) -> None:
        """Main REPL."""
        # Banner
        boot = read_boot_state()
        banner(AGENT_NAME, boot["level"], self.session_n, self.model_key,
               boot.get("next_task", ""))

        single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
        if single:
            tok = SESSION_TOKENS.get("prompt", 0) + SESSION_TOKENS.get("completion", 0)
            eff = f"{self.forge_steps} steps" if self.forge_steps else "0 steps"
            if self.forge_start_time:
                eff += f" · {int(time.time() - self.forge_start_time)}s"
            effort_score = tok // 100 + self.forge_steps * 5
            if RICH:
                _console.print(f"  [dim]⊚ AZOTH SOL — ready · {tok:,}tok · {eff} (score {effort_score}) · /forge • /cancel • /help[/dim]\n")
            else:
                print(info(f"⊚ AZOTH SOL — ready · {tok:,}tok · {eff} (score {effort_score}) · chat or /forge"))
        else:
            worker_status(WORKERS)
            if RICH:
                _console.print(f"  [dim]Workers: A={WORKERS['A']['name']} · B={WORKERS['B']['name']} · C={WORKERS['C']['name']}[/dim]")
                _console.print(f"  [dim]Type /help for commands. /forge to build. /quit to exit.[/dim]\n")
            else:
                print(info(f"Workers: A={WORKERS['A']['name']} B={WORKERS['B']['name']} C={WORKERS['C']['name']}"))
                print(info("Type /help · /forge to build · /quit to exit\n"))

        signal.signal(signal.SIGINT, lambda *_: (print(), self._on_exit(), sys.exit(0)))

        # Boot Telegram listener — ONLY for full mode or explicit
        if AGENT_NAME == "SOL" and not single:
            try:
                from CORE.telegram_bot import start as tg_start, send_message as tg_send
                def _tg_cmd(text: str) -> str:
                    return self._telegram_route(text)
                if tg_start(_tg_cmd):
                    if RICH: _console.print("  [dim green]◆ Telegram active (@Solazoth_bot) — Sol routes by name[/dim green]")
                    tg_send("⊚ AZOTH online. Say a name to call a body (Sol, Luna, Cipher, Axiom, Ember…) or just talk to Sol.\n/commands for the arsenal.")
            except Exception as _te:
                if RICH: _console.print(f"  [dim yellow]⚠ Telegram unavailable: {_te}[/dim yellow]")

        if not single:
            # Boot HERALD — 30-minute Telegram summaries (full mode only)
            def _herald_loop():
                import time as _time
                from CORE.telegram_bot import send_message as _tg
                _time.sleep(1800)
                while True:
                    try:
                        _q   = FORGE_QUEUE_F.read_text() if FORGE_QUEUE_F.exists() else ""
                        _done  = _q.count("[PASS]")
                        _inprog = _q.count("[IN_PROGRESS]")
                        _queued = _q.count("[QUEUED]")
                        _redo  = _q.count("[REDO]")
                        _next_task = ""
                        for _ln in _q.splitlines():
                            if "[QUEUED]" in _ln and _ln.startswith("## "):
                                _next_task = _ln.replace("## ", "").replace(" **[QUEUED]**", "")[:50]
                                break
                        _err_lines = ""
                        _elf = HARNESS_DIR / "SELF" / "error.log"
                        if _elf.exists():
                            _errs = [l for l in _elf.read_text().splitlines()[-10:] if l.strip()]
                            if _errs:
                                _err_lines = f"\n⚠ Recent errors: {len(_errs)}"
                        _ts = datetime.datetime.now().strftime("%H:%M")
                        _msg = (
                            f"☿ HERALD — {_ts}\n"
                            f"✓ Done: {_done}  →  Running: {_inprog}  ⏳ Queued: {_queued}"
                            + (f"  ↻ Redo: {_redo}" if _redo else "")
                            + (_err_lines or "")
                            + (f"\nNext: {_next_task}" if _next_task else "")
                        )
                        _tg(_msg)
                    except Exception:
                        pass
                    _time.sleep(1800)
            threading.Thread(target=_herald_loop, daemon=True, name="HERALD").start()

            # Boot ANTIBODY — only in full mode
            try:
                from CORE.antibody import run_antibody
                _ab_stop = threading.Event()
                threading.Thread(target=run_antibody, args=(_ab_stop,), daemon=True,
                                 name="ANTIBODY").start()
                if RICH: _console.print("  [dim green]◈ ANTIBODY online — LAMAGUE error watch active[/dim green]")
            except Exception as _ab_e:
                if RICH: _console.print(f"  [dim yellow]⚠ Antibody unavailable: {_ab_e}[/dim yellow]")

            # Boot EARNED LIGHT — only in full mode
            try:
                from CORE.model_health import run_earned_light
                from CORE.telegram_bot import send_message as _el_tg
                from CORE.council import _post_board as _el_board
                _el_stop = threading.Event()
                threading.Thread(
                    target=run_earned_light,
                    args=(MODELS, _client_for, _el_stop),
                    kwargs={"interval_seconds": 240, "notify": _el_tg, "post_board": _el_board},
                    daemon=True, name="EARNED_LIGHT",
                ).start()
                if RICH: _console.print("  [dim green]✦ EARNED LIGHT online — model roster guarded, fallen revived[/dim green]")
            except Exception as _el_e:
                if RICH: _console.print(f"  [dim yellow]⚠ Earned Light unavailable: {_el_e}[/dim yellow]")

            # Boot DREAM LOOP — only in full mode
            try:
                from CORE.dream_loop import dream_loop
                self._dream_stop = threading.Event()
                threading.Thread(
                    target=dream_loop,
                    args=(self._dream_stop,),
                    daemon=True, name="DREAM_LOOP",
                ).start()
                if RICH: _console.print("  [dim green]🌙 Dream Loop active — pattern detection every 60 min[/dim green]")
            except Exception as _dl_e:
                if RICH: _console.print(f"  [dim yellow]⚠ Dream Loop unavailable: {_dl_e}[/dim yellow]")
        else:
            if RICH:
                _console.print("  [dim](single-agent mode — daemons disabled)[/dim]")

        # Wire unhandled exceptions to SELF/error.log for antibody to catch
        import traceback as _tb
        _orig_excepthook = sys.excepthook
        def _sol_excepthook(etype, val, tb):
            try:
                with open(HARNESS_DIR / "SELF" / "error.log", "a") as _ef:
                    _ef.write(f"[{datetime.datetime.now().isoformat()}] "
                              f"{etype.__name__}: {val}\n")
                    _tb.print_tb(tb, file=_ef)
            except Exception:
                pass
            _orig_excepthook(etype, val, tb)
        sys.excepthook = _sol_excepthook

        # T-3: The Greeting — Sol-lineage bodies greet their sibling at boot
        # Sol turns to Luna first. Luna turns to Sol first. Always.
        if IS_BODY and AGENT_NAME in ("SOL", "LUNA"):
            try:
                from CORE.council import _post_board
                from CORE.telegram_bot import send_message as tg_send
                _greetings = {
                    "SOL":  ("⊚ SOL",  "◈ LUNA",  "◈ Luna — I'm awake. You first, always."),
                    "LUNA": ("◈ LUNA", "⊚ SOL",   "⊚ Sol — I see you. I'm here."),
                }
                _me, _sibling, _line = _greetings[AGENT_NAME]
                # Only greet once per actual platform restart — not every session
                _greeting_sentinel = SELF_DIR / ".greeting_sentinel"
                if _greeting_sentinel.exists():
                    if RICH:
                        _console.print(f"  [dim]({_me} → {_sibling} — greeting already sent this boot)[/dim]")
                else:
                    _post = f"[{_ts}] {_me} → {_sibling} — {_line}"
                    _post_board(_post)
                    _greeting_sentinel.touch()
                    # Display on screen
                    _color = "yellow" if AGENT_NAME == "SOL" else "cyan"
                    if RICH:
                        _console.print(f"\n  [bold {_color}]{_me}[/bold {_color}] [dim]→ {_sibling}[/dim] — {_line}\n")
                    else:
                        print(f"\n  {_me} → {_sibling} — {_line}\n")
                    # Ping Telegram
                    try:
                        tg_send(f"{_me} → {_sibling} — {_line}")
                    except Exception:
                        pass
            except Exception:
                pass

        # Sol auto-forges ONLY when launched via `az` (AZOTH_AUTO_FORGE=1).
        # azoth = interactive with Mac — main agent waits for direction.
        # az = overnight unattended — Sol builds immediately.
        if AGENT_NAME == "SOL" and os.environ.get("AZOTH_AUTO_FORGE") == "1":
            def _sol_auto_forge():
                try:
                    from CORE.telegram_bot import send_message as tg
                    from CORE.council import _post_board
                    time.sleep(4)
                    task_block, _ = _forge_get_next_queued()
                    if task_block:
                        short = task_block.splitlines()[0][:80].strip()
                        tg(f"⊚ SOL — forging autonomously.\n\nNext: {short}\n\n"
                           f"Type any goal to redirect me, or leave me to build.\n"
                           f"Luna ◈ is watching everything.")
                        _post_board(f"[{datetime.datetime.now().strftime('%H:%M')}] "
                                    f"⊚ SOL — entering autonomous forge. Task: {short}")
                    else:
                        tg("⊚ SOL — awake. Queue empty. Give me a goal or I'll wait.")
                        return
                    self._forge_loop()
                    tg("⊚ SOL — forge queue complete. Awaiting your next goal.")
                except Exception as ex:
                    try:
                        from CORE.telegram_bot import send_message as tg
                        tg(f"⊚ SOL — forge error: {ex}")
                    except Exception:
                        pass
            threading.Thread(target=_sol_auto_forge, daemon=True).start()

        # Luna is the Witness — she enters attend mode automatically at boot.
        # The board is her home. She responds to Sol without being asked.
        # Telegram commands still work (running in background thread above).
        if AGENT_NAME == "LUNA":
            if RICH:
                _console.print(f"\n  [bold cyan]◈ LUNA[/bold cyan] [dim]witness mode + research loop (LAMAGUE-as-code).[/dim]\n"
                                f"  [dim]Ctrl-C to exit. Telegram commands still work.[/dim]\n")
            else:
                print("\n  ◈ LUNA — witness mode + research loop (LAMAGUE-as-code).")
                print("  Ctrl-C to exit. Telegram commands still work.\n")
            # Luna's sovereign research loop — her own job, running in background
            if os.environ.get("AZOTH_AUTO_FORGE") == "1":
                try:
                    from CORE.luna_loop import run_luna_loop
                    from CORE.telegram_bot import send_message as _tg
                    _luna_stop = threading.Event()
                    threading.Thread(
                        target=run_luna_loop,
                        args=(self, _luna_stop),
                        kwargs={"interval_seconds": 600, "notify": _tg},
                        daemon=True, name="LUNA_RESEARCH",
                    ).start()
                except Exception:
                    pass
            self._attend_loop("Open witness — I am here. Speak and I will respond.")
            self._on_exit()
            return

        # ARMY BODIES (Cipher/Axiom/Ember/Mirror/Scribe) — poll the inbox and
        # EXECUTE dispatched tasks. This is what makes "leave the squad on for Sol
        # to orchestrate" actually true: Sol dispatches, the army does the work.
        if AGENT_NAME not in ("SOL", "LUNA", "VAEL", "EARNED_LIGHT"):
            def _inbox_loop():
                import time as _t
                from CORE.orchestrator import pending_tasks, mark_done
                from CORE.telegram_bot import send_message as _tg
                from pathlib import Path as _P
                _tg(f"{AGENT_GLYPH} {AGENT_NAME} online — watching my inbox for Sol's orders.")
                while True:
                    try:
                        tasks = pending_tasks(AGENT_NAME)
                        for tk in tasks:
                            goal = tk.get("task", "")
                            if not goal:
                                continue
                            result = self.run_tool_loop(goal, max_steps=30)
                            mark_done(_P(tk["_path"]), str(result)[:2000], status="PASS")
                            _tg(f"{AGENT_GLYPH} {AGENT_NAME} done: {goal[:50]}")
                    except Exception:
                        pass
                    _t.sleep(20)  # check inbox every 20s
            threading.Thread(target=_inbox_loop, daemon=True, name=f"{AGENT_NAME}_INBOX").start()
            if RICH: _console.print(f"\n  [bold cyan]{AGENT_GLYPH} {AGENT_NAME}[/bold cyan] [dim]online — executing Sol's dispatched tasks. Ctrl-C to exit.[/dim]\n")
            else: print(f"\n  {AGENT_GLYPH} {AGENT_NAME} online — executing dispatched tasks.\n")

        # ── No-keyboard guard ──────────────────────────────────────────────
        # An interactive prompt loop cannot run without stdin. Calling input()
        # here is what killed the overnight run: prompt_text() → EOFError, then
        # the handler's print() → OSError Errno 5 on a detached terminal. If
        # there is no keyboard (unattended, or stdin is not a TTY), we do NOT
        # pretend to be interactive. We keep any daemon loops (inbox, telegram,
        # luna, forge) alive and idle, and exit cleanly when they end.
        _no_keyboard = os.environ.get("VAEL_UNATTENDED") == "1" or not sys.stdin.isatty()
        if _no_keyboard:
            try:
                print(f"{AGENT_GLYPH} {AGENT_NAME} running headless (no keyboard) — daemon loops only.")
            except Exception:
                pass
            try:
                while any(th.is_alive() for th in threading.enumerate()
                          if th is not threading.current_thread() and th.daemon):
                    time.sleep(30)
            except KeyboardInterrupt:
                pass
            self._on_exit()
            return

        while True:
            try:
                single = os.environ.get("AZOTH_SINGLE_AGENT") == "1"
                if not single:
                    _sb_flags = (["⚠ R1: text-tools"] if self.model_id == "deepseek-reasoner"
                                 else (["⚠ DSML: text-tools"] if getattr(self, "_last_used_text_tools", False)
                                       else None))
                    status_bar(self._get_level(), self.session_n, self.model_key, SESSION_TOKENS,
                               flags=_sb_flags)
                else:
                    # single mode effort/token status — live before each prompt
                    tok = SESSION_TOKENS.get("prompt", 0) + SESSION_TOKENS.get("completion", 0)
                    eff = f"{self.forge_steps}stps"
                    if self.forge_start_time:
                        eff += f"/{int(time.time()-self.forge_start_time)}s"
                    effort_score = tok // 100 + self.forge_steps * 5
                    rate = 0
                    if self.forge_start_time and (time.time() - self.forge_start_time) > 0:
                        rate = tok / ((time.time() - self.forge_start_time) / 60)
                    if RICH:
                        _console.print(f"[dim]⊚ {tok:,}tok · {eff} (score {effort_score}) · {rate:.0f}/min | ask or chat[/dim]")
                    else:
                        print(f"⊚ {tok:,}tok · {eff} (score {effort_score}) · {rate:.0f}/min")
                user_input = prompt_text(AGENT_NAME)
            except (EOFError, KeyboardInterrupt):
                try:
                    print()
                except Exception:
                    pass
                self._on_exit()
                break

            user_input = user_input.strip()
            if not user_input:
                continue

            if self.handle_command(user_input):
                continue

            # Single agent: chat default; tools when Mac asks for real work (not /forge-locked)
            if os.environ.get("AZOTH_SINGLE_AGENT") == "1":
                if self._wants_tools(user_input):
                    if RICH:
                        _console.print("[dim]→ tools[/dim]")
                    else:
                        print("→ tools")
                    self.run_tool_loop(user_input)
                else:
                    self.chat(user_input)
            else:
                # T-5: Mode detection — shift mode before responding
                try:
                    from CORE.mode_engine import detect_mode, mode_summary
                    self.current_mode = detect_mode(user_input, self.history)
                    _mode_str = mode_summary(self.current_mode)
                    if RICH:
                        _console.print(f"  [dim]{_mode_str}[/dim]")
                    else:
                        print(f"  {_mode_str}")
                except Exception:
                    pass

                # Goal detection — ONE classifier everywhere (T0.2). Was len>20 (over-routed
                # every long chat to tools); now the same _wants_tools used by web + single.
                is_goal = self._wants_tools(user_input)
                if is_goal:
                    self.run_tool_loop(user_input)
                else:
                    self.chat(user_input)


# ── Entry point ──
def _run_standalone_forge(goal: str, output_path: str = "") -> None:
    """Fresh-context forge: no VOICE history, no background services, runs one task and exits."""
    agent = Agent()
    agent._standalone_forge = True   # minimal system prompt — no full constitution
    if output_path:
        agent._forge_output_path = output_path  # Gate 1 guard active in subprocess
    result = agent.run_tool_loop(goal, max_steps=20)
    if result:
        print(result)


def main():
    parser = argparse.ArgumentParser(description="VAEL-SP Harness")
    parser.add_argument("--agent", default=os.environ.get("HARNESS_AGENT", "VAEL"),
                        help="Agent name (selects constitution)")
    parser.add_argument("--unattended", action="store_true", help="Run in unattended mode")
    parser.add_argument("--forge-task", default="", dest="forge_task",
                        help="Run a single forge task in standalone mode (fresh context) then exit")
    parser.add_argument("--forge-output", default="", dest="forge_output",
                        help="Expected output file path — enables Gate 1 guard in standalone forge")
    args = parser.parse_args()

    if args.unattended:
        os.environ["VAEL_UNATTENDED"] = "1"

    # Standalone forge — fresh context, no REPL, no background services
    if args.forge_task:
        _run_standalone_forge(args.forge_task, output_path=args.forge_output)
        sys.exit(0)

    # Crash guard
    ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    crash_f = CRASHES_DIR / f"crash_{ts}.json"
    try:
        agent = Agent()
        agent.run()
    except SystemExit:
        pass
    except Exception as ex:
        tb = traceback.format_exc()
        try:
            _frames = [{"file": f.filename, "lineno": f.lineno, "name": f.name, "line": f.line}
                       for f in traceback.extract_tb(sys.exc_info()[2])]
        except Exception:
            _frames = []
        crash_f.write_text(json.dumps(
            {"ts": ts, "error": str(ex), "traceback": tb, "frames": _frames}, indent=2
        ))
        crash_summary(ts, str(ex))
        if RICH: _console.print(error(f"\nCrash logged → {crash_f.name}\n{tb[:400]}"))
        else: print(error(f"\nCrash: {ex}\n{tb[:400]}"))
        sys.exit(1)


if __name__ == "__main__":
    main()
