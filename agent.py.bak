# ── Agent home resolution (T-1: the loader) ───────────────────────────────────
# Bodies live in AZOTH/bodies/<name>/ for complete AZOTH separation.
# Main agent (SOL) is isolated from the network.
def _resolve_agent_home(name: str) -> Path:
    name_u = name.upper()
    # Dedicated separated body first
    body_path = BODY_BASE / name.lower()
    if body_path.exists():
        if (body_path / "CONSTITUTION.md").exists() or name_u in ("SOL", "LUNA", "VAEL"):
            return body_path
    if name_u == "VAEL":
        return HARNESS_DIR
    candidate = AGENTS_DIR / name_u
    if candidate.exists() and (candidate / "CONSTITUTION.md").exists():
        return candidate
    return HARNESS_DIR

AGENT_HOME    = _resolve_agent_home(AGENT_NAME)
IS_BODY       = AGENT_HOME != HARNESS_DIR        # True for SOL/LUNA, False for VAEL

