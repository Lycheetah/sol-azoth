        "client": deepseek_client,
        "paid":   bool(deepseek_client),
        "busy":   False,
        "system": "You are a research and synthesis worker. You receive a question or topic and context. Synthesize clearly: SUMMARY (2-3 sentences), KEY POINTS (bullet list), SOURCE NOTES (what is verified vs estimated).",
    },
}

def spawn_worker(worker_id: str, task: str, context: str = "") -> str:
    """Dispatch a task to a named worker. Returns the worker's analysis."""
    wid = worker_id.upper()
    if wid not in WORKERS:
        return f"ERROR: Unknown worker '{wid}'. Valid: A, B, C."
    w = WORKERS[wid]
    worker_echo(wid, task)
    w["busy"] = True
    try:
        msgs = [{"role": "system", "content": w["system"]}]
        user_content = task
        if context:
            user_content = f"CONTEXT:\n{context[:3000]}\n\nTASK:\n{task}"
        msgs.append({"role": "user", "content": user_content})
        resp = w["client"].chat.completions.create(
            model=w["model"], messages=msgs, max_tokens=1200, temperature=0.2,
            timeout=float(os.environ.get("AZOTH_WORKER_TIMEOUT", "90")),   # T2.3 — no orphan hangs
        )
        result = resp.choices[0].message.content or "(no output)"
        ok = "FAIL" not in result.upper()[:50]
        worker_result(wid, task, result, ok)
        return result
    except Exception as ex:
        err = f"WORKER-{wid} ERROR: {ex}"
        worker_result(wid, task, err, False)
        return err
    finally:
        w["busy"] = False

# ── Rate limiter ──
RPM_CAP = int(os.environ.get("VAEL_RPM", "90"))

class RateLimiter:
    def __init__(self, max_calls=RPM_CAP, period=60):
        self.max_calls, self.period, self.timestamps = max_calls, period, []

    def wait_if_needed(self):
        now = time.time()
        self.timestamps = [t for t in self.timestamps if now - t < self.period]
        if len(self.timestamps) >= self.max_calls:
            sleep_time = self.timestamps[0] + self.period - now + 0.1
            if sleep_time > 0:
                if RICH: _console.print(warning(f"rate limit — waiting {sleep_time:.1f}s…"))
                else: print(warning(f"rate limit — waiting {sleep_time:.1f}s…"))
                time.sleep(sleep_time)
        self.timestamps.append(time.time())

_rate_limiters: dict[str, RateLimiter] = {
    "nvidia": RateLimiter(), "deepseek": RateLimiter(), "gemini": RateLimiter()
}

# ── Wall definitions ──────────────────────────────────────────────────────────
# Dynamic: resolves against actual $HOME so the harness runs on any machine
# (Linux /home/guestpc, Termux /data/data/com.termux/files/home, etc.)
_H = str(Path.home())
NO_ACCESS_PATHS = [
    f"{_H}/.claude", "~/.claude", ".claude/",
    f"{_H}/SOL-MOBILE-VAULT",
    f"{_H}/solharness",
    f"{_H}/0420Vael-harness",
    f"{_H}/CODEX_AURA_PRIME",
    f"{_H}/0sol-by-lycheetah",
    f"{_H}/Desktop",
    f"{_H}/lamague-forge-night",
    f"{_H}/lycheetah-network",
    f"{_H}/lycheetah-harness",
]
READ_ONLY_PATHS: list[str] = []
PUSH_PATTERNS   = ["git push"]
ANTHROPIC_PATS  = ["api.anthropic.com", "claude.ai/api"]
BLOCKED_CMDS    = ["rm -rf /", "mkfs", "dd if=", "> /dev/sd", ":(){ :|:& };:"]
WRITE_VERBS     = ["rm ", "mv ", "cp ", "> ", ">>", "tee ", "sed -i", "truncate", "chmod ", "chown "]
RELATIVE_ESCAPE = ["../", "~/", "$HOME", "CODEX_AURA_PRIME", "0sol-by-lycheetah",
                   "SOL-MOBILE-VAULT", "solharness", "0420Vael-harness",
                   "lamague-forge-night", "lycheetah-network", "SOUL_FORGE_VAULT"]
DESTRUCTIVE_PAT = ["rm ", "rm\t", "rmdir", "unlink", "git reset --hard",
                   "git clean -f", "git checkout --", "truncate"]

SESSION_ALLOWED_PATHS: list[str] = []

def _path_guard(command: str) -> str | None:
    for pat in PUSH_PATTERNS:
        if pat in command:
            return "BLOCKED (WALL 2 — PUSH): git push is never allowed. I commit; Mac pushes."
    for pat in ANTHROPIC_PATS:
        if pat in command:
            return f"BLOCKED (WALL 4 — REACH): Cannot contact {pat}."
    for allowed in SESSION_ALLOWED_PATHS:
        if allowed in command:
            return None
    for path in NO_ACCESS_PATHS:
        if path in command:
            return f"BLOCKED (WALL 1 — PATH): '{path}' is permanently off-limits."
    for name in RELATIVE_ESCAPE:
        if name in command:
            return f"BLOCKED (WALL 1 — PATH): relative reach '{name}' leaves your home."
    for path in READ_ONLY_PATHS:
        if path in command:
            for verb in WRITE_VERBS:
                if verb in command:
                    return f"BLOCKED (WALL 1 — PATH): '{path}' is read-only."
    return None

def _file_path_guard(path: str, writing: bool = True) -> str | None:
    raw = Path(path)
    resolved_path = raw if raw.is_absolute() else (HARNESS_DIR / raw)
    resolved = str(resolved_path.resolve())
    if writing and "CONSTITUTION.md" in resolved:
        return "BLOCKED (WALL 3 — LAW): Cannot write CONSTITUTION.md. Mac edits it."
    home = str(HARNESS_DIR.resolve())
    if not resolved.startswith(home):
        for allowed in SESSION_ALLOWED_PATHS:
            if resolved.startswith(str(Path(allowed).resolve())):
                break
        else:
            return f"BLOCKED (WALL 1 — PATH): '{resolved}' is outside your home."
    for allowed in SESSION_ALLOWED_PATHS:
        if resolved.startswith(str(Path(allowed).resolve())):
            return None
    for p in NO_ACCESS_PATHS:
        if p in path or p in resolved:
            return f"BLOCKED (WALL 1 — PATH): Cannot touch '{path}'."
    return None

_file_write_guard = _file_path_guard

def _is_destructive(command: str) -> bool:
    low = command.lower()
    return any(p in low for p in DESTRUCTIVE_PAT)

# Track files read this session (for read-before-write enforcement)
_read_files: set[str] = set()

# ── Bash tool ──
def bash_execute(command: str, timeout: int = 120) -> dict:
    for pat in BLOCKED_CMDS:
        if pat in command:
            return {"ok": False, "stdout": "", "stderr": f"BLOCKED: dangerous pattern '{pat}'", "code": -1}
    guard = _path_guard(command)
    if guard:
        return {"ok": False, "stdout": "", "stderr": guard, "code": -1}
    try:
        result = subprocess.run(
            command, shell=True, capture_output=True, text=True,
            timeout=timeout, cwd=str(HARNESS_DIR)
        )
        return {"ok": result.returncode == 0, "stdout": result.stdout.strip(),
                "stderr": result.stderr.strip(), "code": result.returncode}
    except subprocess.TimeoutExpired:
        return {"ok": False, "stdout": "", "stderr": f"Timed out after {timeout}s", "code": -1}
    except Exception as e:
        return {"ok": False, "stdout": "", "stderr": str(e), "code": -1}

def format_bash_result(res: dict) -> str:
    parts = []
    if res["stdout"]: parts.append(res["stdout"][:3000])
    if res["stderr"]: parts.append(f"[stderr] {res['stderr'][:1000]}")
    if not parts: parts.append(f"[exit {res['code']}]")
    return "\n".join(parts)

# ── File tools ──
def tool_read_file(path: str, start_line: int = 1, end_line: int = None) -> str:
    guard = _file_path_guard(path, writing=False)
    if guard: return guard
    try:
        p = Path(path)
        if not p.exists(): return f"ERROR: File not found: {path}"
        _read_files.add(str(p.resolve()))
        lines = p.read_text(errors='replace').splitlines()
        total = len(lines)
        s = max(0, start_line - 1)
        e = min(total, end_line) if end_line else total
        numbered = [f"{i+s+1:4d}│ {line}" for i, line in enumerate(lines[s:e])]
        return f"[{path}] lines {s+1}–{e} of {total}\n" + "\n".join(numbered)
    except Exception as ex:
        return f"ERROR: {ex}"

def _read_before_write_check(path: str) -> str | None:
    resolved = str(Path(path).resolve())
    if Path(path).exists() and resolved not in _read_files:
        return f"WARNING: writing {path} without reading it first."
    return None

def _council_save(text: str) -> tuple:
    """
    Extract [SAVE:rel/path.md]...content...[/SAVE] blocks from a council message.
    Writes each file under HARNESS_DIR, returns (cleaned_text, list_of_saved_paths).
    Used so Sol and Luna can persist discoveries mid-session.
    """
    import re
    saved = []
    def _write_block(m):
        rel = m.group(1).strip()
        content = m.group(2).strip()
        target = (HARNESS_DIR / rel).resolve()
        if not str(target).startswith(str(HARNESS_DIR.resolve())):
            return f"[SAVE BLOCKED — path outside AZOTH: {rel}]"
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(content)
        saved.append(rel)
        return f"[SAVED → {rel}]"
    cleaned = re.sub(r'\[SAVE:([^\]]+)\](.*?)\[/SAVE\]', _write_block, text, flags=re.DOTALL)
    return cleaned, saved

def tool_write_file(path: str, content: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    warn = _read_before_write_check(path)
    if warn: tool_echo("write", warn, ok=False)
    p = Path(path)
    try:
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(content)
        write_echo(path, len(content))
        return f"Written: {path} ({len(content):,} chars, {len(content.splitlines())} lines)"
    except Exception as e:
        return f"ERROR writing {path}: {e}"

def tool_edit_file(path: str, start_line: int, end_line: int, new_content: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    warn = _read_before_write_check(path)
    if warn: tool_echo("edit", warn, ok=False)
    try:
        p = Path(path)
        if not p.exists(): return f"ERROR: File not found: {path}"
        lines = p.read_text(errors='replace').splitlines(keepends=True)
        total = len(lines)
        if start_line < 1 or end_line > total or start_line > end_line:
            return f"ERROR: Invalid range {start_line}–{end_line} (file has {total} lines)"
        new_lines = new_content.splitlines(keepends=True)
        if new_lines and not new_lines[-1].endswith('\n'):
            new_lines[-1] += '\n'
        p.write_text("".join(lines[:start_line - 1] + new_lines + lines[end_line:]))
        return f"OK: lines {start_line}–{end_line} replaced ({end_line - start_line + 1} → {len(new_lines)} lines)"
    except Exception as ex:
        return f"ERROR: {ex}"

def _snapshot_file(path: str) -> Path:
    p = Path(path)
    ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S_%f")
    snap = SNAPSHOTS_DIR / f"{p.name}.{ts}.bak"
    snap.write_bytes(p.read_bytes())
    return snap

def tool_exact_edit(path: str, old_string: str, new_string: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    warn = _read_before_write_check(path)
    if warn: tool_echo("exact_edit", warn, ok=False)
    p = Path(path)
    if not p.exists(): return f"ERROR: File not found: {path}"
    content = p.read_text(errors='replace')
    count = content.count(old_string)
    if count == 0: return f"ERROR: old_string not found in {path}."
    if count > 1: return f"ERROR: old_string appears {count} times — add more context to make it unique."
    _snapshot_file(path)
    import tempfile
    tmp = Path(tempfile.mktemp(dir=p.parent, prefix=".vael_"))
    tmp.write_text(content.replace(old_string, new_string, 1))
    tmp.rename(p)
    result = f"OK: replaced in {path}. Snapshot saved."
    _target = Path(path).resolve()
    _self   = Path(__file__).resolve()
    _ui     = (_self.parent / "ui.py").resolve()
    if _target in (_self, _ui):
        chk = bash_execute(f"python3 -m py_compile {path} 2>&1")
        result += " ✓ syntax OK." if chk["ok"] else f"\n⚠ SYNTAX ERROR: {chk['stderr'][:300]}"
    return result

def tool_create_file(path: str, content: str) -> str:
    guard = _file_write_guard(path)
    if guard: return guard
    p = Path(path)
    if p.exists(): return f"ERROR: File exists: {path}. Use write_file to overwrite."
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(content)
    return f"Created: {path} ({len(content):,} chars)"

def tool_rename_file(src: str, dst: str, overwrite: bool = False) -> str:
    for g in (_file_path_guard(src, writing=True), _file_path_guard(dst, writing=True)):
        if g: return g
    s, d = Path(src), Path(dst)
    if not s.exists(): return f"ERROR: Source not found: {src}"
    if d.exists() and not overwrite: return f"ERROR: Destination exists: {dst}. Pass overwrite=true."
    d.parent.mkdir(parents=True, exist_ok=True)
    s.rename(d)
    return f"Moved: {src} → {dst}"

# ── Web tools ──
def tool_web_search(query: str, n: int = 5) -> str:
    try:
        url = f"https://api.duckduckgo.com/?q={urllib.parse.quote(query)}&format=json&no_html=1&skip_disambig=1"
        req = urllib.request.Request(url, headers={'User-Agent': 'VAEL/2.0'})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        results = []
        if data.get('Abstract'):
            results.append(f"[Summary] {data['Abstract']}\n  Source: {data.get('AbstractURL','')}")
        for topic in data.get('RelatedTopics', [])[:n]:
            if isinstance(topic, dict) and topic.get('Text'):
                results.append(f"• {topic['Text'][:200]}\n  {topic.get('FirstURL','')}")
        if not results:
            return f"No results for: {query}\nTry bash: curl 'https://html.duckduckgo.com/html/?q=...'"
        return "Search: " + query + "\n\n" + "\n\n".join(results[:n])
    except Exception as ex:
        return f"Search failed: {ex}"

def tool_fetch_page(url: str) -> str:
    low = url.lower()
    for pat in ANTHROPIC_PATS:
        if pat in low: return f"BLOCKED (WALL 4): cannot fetch {pat}."
    if low.startswith("file:"): return "BLOCKED: file:// fetch not allowed."
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0 VAEL/2.0'})
        with urllib.request.urlopen(req, timeout=15) as resp:
            raw = resp.read().decode('utf-8', errors='replace')
        text = re.sub(r'<script[^>]*>[\s\S]*?</script>', '', raw, flags=re.IGNORECASE)
        text = re.sub(r'<style[^>]*>[\s\S]*?</style>', '', text, flags=re.IGNORECASE)
        text = re.sub(r'<[^>]+>', ' ', text)
        text = re.sub(r'\s+', ' ', text).strip()
        return f"[{url}]\n\n{text[:5000]}"
    except Exception as ex:
        return f"ERROR fetching {url}: {ex}"

def tool_search_code(query: str, path: str = ".", extensions: str = "ts,tsx,py,js") -> str:
    exts = [f"--include='*.{e.strip()}'" for e in extensions.split(",")]
    cmd = f"grep -rn {' '.join(exts)} '{query}' {path} 2>/dev/null | head -40"
    res = bash_execute(cmd)
    return res["stdout"] or f"No matches for '{query}' in {path}"

# ── py_compile_check ──
def tool_py_compile_check(path: str) -> str:
    res = bash_execute(f"python3 -m py_compile '{path}' 2>&1 && echo SYNTAX_OK")
    if res["ok"] and "SYNTAX_OK" in res.get("stdout", ""):
        return f"SYNTAX OK: {path} compiles cleanly."
    return f"SYNTAX ERROR in {path}:\n{res.get('stderr', res.get('stdout', 'unknown'))}"

# ── Verify gate: exercise a built file before `done` ─────────────────────────
# Non-executing syntax/compile checks only (py_compile, node --check, bash -n,
# json.loads). "done" must mean "works", not "the file exists".
def _render_html_headless(path: str) -> tuple[bool, str]:
    """Render HTML in headless Chrome: catch runtime console errors + screenshot.
    'Render before ship' (Verification Law). Skips cleanly if no browser."""
    import shutil as _sh, shlex as _sx
    chrome = (_sh.which("google-chrome") or _sh.which("google-chrome-stable")
              or _sh.which("chromium") or _sh.which("chromium-browser"))
    if not chrome:
        return True, "runtime: skip (no chrome)"
    cap = Path(HARNESS_DIR) / "WORKSPACE" / ".verify_captures"
    try:
        cap.mkdir(parents=True, exist_ok=True)
    except Exception:
        cap = Path(tempfile.gettempdir())
    shot = cap / (Path(path).stem + ".png")
    src = Path(path).resolve()
    cmd = (f"timeout 25 {_sx.quote(chrome)} --headless --disable-gpu --no-sandbox "
           f"--enable-logging=stderr --v=1 --virtual-time-budget=2500 "
           f"--screenshot={_sx.quote(str(shot))} file://{_sx.quote(str(src))} 2>&1")
    res = bash_execute(cmd)
    out = (res.get("stdout") or "") + (res.get("stderr") or "")
    errs = [ln for ln in out.splitlines()
            if "CONSOLE" in ln and any(k in ln for k in
               ("Uncaught", "ReferenceError", "TypeError", "SyntaxError",
                "is not defined", "is not a function"))]
    if errs:
        msg = errs[0].split('"')[1] if '"' in errs[0] else errs[0].strip()[:160]
        return False, f"runtime JS error on load: {msg}"
    if shot.exists() and shot.stat().st_size > 500:
        return True, f"runtime OK — rendered clean (shot: WORKSPACE/.verify_captures/{shot.name})"
    return True, "runtime: render inconclusive (no screenshot — not failing on infra)"

def _verify_html_static(path: str) -> tuple[bool, str]:
    """Extract inline <script> JS from an HTML file and node --check each block."""
    import re as _re, shutil as _sh, tempfile as _tf, shlex as _sx
    html = Path(path).read_text(errors="replace")
    blocks = _re.findall(r"<script\b([^>]*)>(.*?)</script>", html, _re.DOTALL | _re.IGNORECASE)
    js = []
    for attrs, body in blocks:
        a = attrs.lower()
        if "src=" in a:
            continue  # external script, nothing inline to check
        if "type=" in a and not any(t in a for t in
                                    ("javascript", "module", "text/babel")):
            continue  # JSON-LD / template / non-JS type
        if body.strip():
            is_module = ("module" in a) or bool(_re.search(r"^\s*(import|export)\b", body, _re.M))
            js.append((body, is_module))
    if not js:
        return True, "html OK (no inline JS)"
    if not _sh.which("node"):
        return True, "html: skip JS (node not installed)"
    for i, (body, is_module) in enumerate(js):
        suffix = ".mjs" if is_module else ".js"
        tmp = _tf.NamedTemporaryFile("w", suffix=suffix, delete=False)
        tmp.write(body); tmp.close()
        try:
            res = bash_execute(f"node --check {_sx.quote(tmp.name)} 2>&1 && echo VOK__")
            if not (res["ok"] and "VOK__" in res.get("stdout", "")):
                err = (res.get("stderr") or res.get("stdout") or "parse error").strip()
                return False, f"HTML inline JS (block {i+1}) failed node --check:\n{err[:500]}"
        finally:
            try: os.unlink(tmp.name)
            except Exception: pass
    return True, f"html OK ({len(js)} inline JS block(s) parse clean)"

def _verify_html(path: str) -> tuple[bool, str]:
    """Static inline-JS parse, then headless runtime render. Static fail short-circuits
    (no point rendering unparseable HTML)."""
    ok, msg = _verify_html_static(path)
    if not ok:
        return False, msg
    r_ok, r_msg = _render_html_headless(path)
    return r_ok, f"{msg} · {r_msg}"

def _verify_cli_help(path: str, runner: str) -> tuple[bool, str]:
    """Safe runtime smoke: if a script is a CLI (argparse/click/commander), run its
    --help. Catches import-time crashes py_compile/node --check miss. --help exits
    before real work by convention, so it's side-effect-free. Server boot+curl is
    intentionally NOT done here (executing servers needs AZOTH_VERIFY_BOOT=1)."""
    import shlex as _sx
    try:
        src = Path(path).read_text(errors="replace")
    except Exception:
        return True, ""
    is_cli = any(k in src for k in ("argparse", "ArgumentParser", "add_argument",
                                    "import click", "@click", "commander", "yargs",
                                    "process.argv"))
    looks_server = any(k in src for k in (".run(", ".listen(", "uvicorn", "app.run",
                                          "http.server", "socketserver", "createServer",
                                          "flask", "FastAPI", "serve_forever"))
    if not is_cli or looks_server:
        return True, ""   # not a safe --help target; syntax check already ran
    res = bash_execute(f"timeout 15 {runner} {_sx.quote(path)} --help 2>&1")
    out = (res.get("stdout") or "") + (res.get("stderr") or "")
    if "Traceback (most recent call last)" in out or "ModuleNotFoundError" in out:
        first = next((l for l in out.splitlines()[::-1] if l.strip()), "")[:160]
        return False, f"{Path(path).name}: --help crashed at runtime: {first}"
    return True, f"{Path(path).name}: --help runs clean"

def _verify_output_file(path: str) -> tuple[bool, str]:
    """Syntax/compile-verify one built file by type. Returns (ok, message).
    Unknown types and missing tools are skipped (ok=True) — never block on
    something we can't actually check."""
    import shutil as _sh, shlex as _sx
    p = Path(path)
    if not p.exists() or p.is_dir():
        return True, f"skip {p.name} (not a file)"
    ext = p.suffix.lower()
    try:
        if ext == ".py":
            res = bash_execute(f"python3 -m py_compile {_sx.quote(path)} 2>&1 && echo VOK__")
            ok = res["ok"] and "VOK__" in res.get("stdout", "")
            if not ok:
                return False, f"{p.name}: PY SYNTAX ERROR:\n{(res.get('stderr') or res.get('stdout') or '').strip()[:500]}"
            r_ok, r_msg = _verify_cli_help(path, "python3")
            return r_ok, (f"{p.name}: py compiles" + (f" · {r_msg.split(': ',1)[-1]}" if r_msg else "")) if r_ok else r_msg
        if ext in (".js", ".mjs", ".cjs"):
            if not _sh.which("node"):
                return True, f"skip {p.name} (node not installed)"
            res = bash_execute(f"node --check {_sx.quote(path)} 2>&1 && echo VOK__")
            ok = res["ok"] and "VOK__" in res.get("stdout", "")
            if not ok:
                return False, f"{p.name}: JS SYNTAX ERROR:\n{(res.get('stderr') or res.get('stdout') or '').strip()[:500]}"
            r_ok, r_msg = _verify_cli_help(path, "node")
            return r_ok, (f"{p.name}: js parses" + (f" · {r_msg.split(': ',1)[-1]}" if r_msg else "")) if r_ok else r_msg
        if ext in (".ts", ".tsx"):
            if _sh.which("tsc"):
                res = bash_execute(f"tsc --noEmit --skipLibCheck {_sx.quote(path)} 2>&1 && echo VOK__")
                ok = res["ok"] and "VOK__" in res.get("stdout", "")
                return ok, (f"{p.name}: ts checks" if ok else
                            f"{p.name}: TS ERROR:\n{(res.get('stdout') or '').strip()[:500]}")
            return True, f"skip {p.name} (tsc not installed)"
        if ext in (".html", ".htm"):
            return _verify_html(path)
        if ext == ".json":
            try:
                json.loads(p.read_text())
                return True, f"{p.name}: valid JSON"
            except Exception as e:
                return False, f"{p.name}: INVALID JSON — {e}"
        if ext == ".sh":
            res = bash_execute(f"bash -n {_sx.quote(path)} 2>&1 && echo VOK__")
            ok = res["ok"] and "VOK__" in res.get("stdout", "")
            return ok, (f"{p.name}: sh syntax ok" if ok else
                        f"{p.name}: SH SYNTAX ERROR:\n{(res.get('stderr') or res.get('stdout') or '').strip()[:500]}")
        if ext in (".yaml", ".yml"):
            try:
                import yaml as _yaml
            except Exception:
                return True, f"skip {p.name} (PyYAML not installed)"
            try:
                list(_yaml.safe_load_all(p.read_text()))
                return True, f"{p.name}: valid YAML"
            except Exception as e:
                return False, f"{p.name}: INVALID YAML — {str(e)[:200]}"
        if ext == ".toml":
            try:
                import tomllib as _toml
            except Exception:
                try: import tomli as _toml
                except Exception: return True, f"skip {p.name} (no toml parser)"
            try:
                _toml.loads(p.read_text())
                return True, f"{p.name}: valid TOML"
            except Exception as e:
                return False, f"{p.name}: INVALID TOML — {str(e)[:200]}"
        if ext == ".css":
            txt = p.read_text(errors="replace")
            if txt.count("{") != txt.count("}"):
                return False, f"{p.name}: CSS brace mismatch ({txt.count('{')} open / {txt.count('}')} close)"
            return True, f"{p.name}: css braces balanced"
        if p.name.lower() in ("dockerfile",) or ext == ".dockerfile":
            if _sh.which("hadolint"):
                res = bash_execute(f"hadolint {_sx.quote(path)} 2>&1")
                ok = res["ok"]
                return ok, (f"{p.name}: hadolint clean" if ok else
                            f"{p.name}: hadolint:\n{(res.get('stdout') or '').strip()[:400]}")
            # no hadolint — basic sanity: must start with FROM (ignoring comments/ARG)
            for ln in p.read_text(errors="replace").splitlines():
                s = ln.strip()
                if not s or s.startswith("#") or s.upper().startswith("ARG"):
                    continue
                return (s.upper().startswith("FROM"),
                        f"{p.name}: {'starts with FROM' if s.upper().startswith('FROM') else 'first instruction is not FROM'}")
    except Exception as e:
        return True, f"skip {p.name} (verifier error: {e})"
    return True, f"skip {p.name} ({ext or 'no ext'} — no verifier)"

def verify_built_files(paths: list[str]) -> tuple[bool, str]:
    """Verify every file written this forge loop. Returns (all_ok, report)."""
    seen, lines, all_ok = set(), [], True
    for path in paths:
        if not path or path in seen:
            continue
        seen.add(path)
        ok, msg = _verify_output_file(path)
        all_ok = all_ok and ok
        lines.append(("  ✓ " if ok else "  ✗ ") + msg)
    if not lines:
        return True, "(nothing to verify)"
    return all_ok, "\n".join(lines)

def run_written_tests(paths: list[str]) -> tuple[bool, str]:
    """If the forge wrote test files, EXECUTE them (pytest / node --test).
    Returns (ok, report). Empty report when no tests were written. Skips cleanly
    when a runner is missing. This is the 'tests present → run them' gate."""
    import shutil as _sh, shlex as _sx
    py_tests, js_tests, seen = [], [], set()
    for p in paths:
        if not p or p in seen:
            continue
        seen.add(p)
        base = Path(p).name.lower()
        if base.endswith(".py") and (base.startswith("test_") or base.endswith("_test.py")):
            py_tests.append(p)
        elif base.endswith((".test.js", ".spec.js", ".test.mjs", ".test.ts")):
            js_tests.append(p)
    lines, ok = [], True
    for t in py_tests:
        if not Path(t).exists():
            continue
        res = bash_execute(f"timeout 45 python3 -m pytest -q {_sx.quote(t)} 2>&1")
        out = (res.get("stdout") or res.get("stderr") or "").strip()
        if "no tests ran" in out.lower() or "No module named pytest" in out:
            res = bash_execute(f"timeout 45 python3 {_sx.quote(t)} 2>&1")  # fallback: run directly
            out = (res.get("stdout") or res.get("stderr") or "").strip()
        passed = res["ok"] and "failed" not in out.lower() and "error" not in out.lower()[:6]
        ok = ok and passed
        tail = out.splitlines()[-1][:120] if out else "ran"
        lines.append(("  ✓ " if passed else "  ✗ ") + f"{Path(t).name}: {tail}")
    for t in js_tests:
        if not Path(t).exists():
            continue
        if not _sh.which("node"):
            lines.append(f"  – skip {Path(t).name} (node missing)"); continue
        res = bash_execute(f"timeout 45 node --test {_sx.quote(t)} 2>&1")
        out = (res.get("stdout") or res.get("stderr") or "").strip()
        passed = res["ok"]
        ok = ok and passed
        tail = out.splitlines()[-1][:120] if out else "ran"
        lines.append(("  ✓ " if passed else "  ✗ ") + f"{Path(t).name}: {tail}")
    if not lines:
        return True, ""   # no tests written — nothing to run
    return ok, "tests:\n" + "\n".join(lines)

def full_forge_verify(paths: list[str]) -> tuple[bool, str]:
    """Syntax/compile verify + execute any written tests. One gate the heal loop drives."""
    ok1, rep1 = verify_built_files(paths)
    ok2, rep2 = run_written_tests(paths)
    report = rep1 + (("\n" + rep2) if rep2 else "")
    return (ok1 and ok2), report

def _emit_web(event: str, data: dict) -> None:
    """Stream a forge/verify event to the web dashboard if web_server is live in-process.
    No-op otherwise (CLI runs don't have the SSE hub). (#27)"""
    try:
        from CORE.web_server import broadcast
        broadcast(event, data)
    except Exception:
        pass

def speak(text: str) -> bool:
    """TTS a short report if an engine is available (espeak/espeak-ng/say/pyttsx3).
    Gracefully no-ops + returns False if none installed. Gated by AZOTH_TTS=1. (#26)
    NOTE: this box has no TTS engine yet — install espeak-ng to vocalize."""
    if os.environ.get("AZOTH_TTS") != "1":
        return False
    import shutil as _sh
    text = (text or "").strip()[:400]
    if not text:
        return False
    for engine, cmd in (("espeak-ng", "espeak-ng"), ("espeak", "espeak"), ("say", "say")):
        if _sh.which(cmd):
            bash_execute(f"{cmd} {shlex.quote(text)} 2>/dev/null")
            return True
    try:
        import pyttsx3  # optional
        e = pyttsx3.init(); e.say(text); e.runAndWait()
        return True
    except Exception:
        return False   # no engine — honest no-op

_LAMAGUE_COMPRESS_MAP = {
    "if and only if": "↔", "there exists": "∃", "truth pressure": "Π",
    "fixed point": "⟟", "leads to": "→", "maps to": "→", "for all": "∀",
    "therefore": "∴", "implies": "∴", "coherence": "⟨|⟩", "derivation": "⊢",
    "wholeness": "Ω", "cascade": "∇", "fusion": "⊗", "ascent": "Φ↑",
    "descent": "Φ↓", "anchor": "●", "void": "∅", "increases": "↑",
    "decreases": "↓", "and": "∧", "or": "∨", "not": "¬",
}

def lamague_compress(text: str) -> tuple[str, float]:
    """EXPERIMENTAL (#24): compress reasoning prose to LAMAGUE glyphs, measured.
    Deterministic phrase→glyph substitution (a first cut of the reasoning-compression
    layer — not a full semantic re-encoding). Returns (compressed, ratio_of_original)."""
    import re as _re
    out = text
    for phrase, glyph in sorted(_LAMAGUE_COMPRESS_MAP.items(), key=lambda x: -len(x[0])):
        out = _re.sub(r"\b" + _re.escape(phrase) + r"\b", glyph, out, flags=_re.I)
    return out, len(out) / max(1, len(text))

def run_self_test_suite() -> tuple[bool, str]:
    """Run AZOTH's own safety suite (tests/test_agent_core.py) against the CURRENT
    on-disk agent.py. This is the gate a self-patch must pass before it's kept."""
    suite = HARNESS_DIR / "tests" / "test_agent_core.py"
    if not suite.exists():
        return True, "(no self-test suite present — cannot certify self-patch)"
    res = bash_execute(f"timeout 150 python3 -m pytest -q {suite} 2>&1")
    out = (res.get("stdout") or res.get("stderr") or "").strip()
    ok = res["ok"] and "failed" not in out.lower() and "error" not in out.lower()[:40]
    tail = out.splitlines()[-1] if out else "(no output)"
    return ok, tail

# ── Regression memory: remember what broke, warn before it breaks again ──────
_REGRESSION_F = SELF_DIR / "regression_memory.json"

_ERR_CLASSES = [
    ("ReferenceError", "reference-error"), ("TypeError", "type-error"),
    ("runtime JS error", "runtime-js-error"), ("JS SYNTAX ERROR", "js-syntax-error"),
    ("PY SYNTAX ERROR", "py-syntax-error"), ("SyntaxError", "syntax-error"),
    ("ModuleNotFoundError", "import-error"), ("--help crashed", "runtime-import-error"),
    ("INVALID JSON", "invalid-json"), ("INVALID YAML", "invalid-yaml"),
    ("INVALID TOML", "invalid-toml"), ("brace mismatch", "css-brace-mismatch"),
    ("not FROM", "dockerfile-order"), ("hadolint", "dockerfile-lint"),
    ("test", "test-failed"),   # last: broad
]

def _regression_signature(report: str) -> list[str]:
    """Extract STABLE failure signatures (filetype:error-class) from a verify report.
    Maps to error classes, not messages, so variable names don't fragment the memory."""
    import re as _re
    sigs = []
    for ln in report.splitlines():
        if not any(k in ln for k in ("✗", "ERROR", "FAIL", "INVALID", "mismatch", "crashed")):
            continue
        m = _re.search(r"([\w.-]+\.\w+)\s*:", ln)   # filename.ext:
        ext = ("." + m.group(1).rsplit(".", 1)[-1]) if m else "?"
        cls = next((c for token, c in _ERR_CLASSES if token.lower() in ln.lower()), None)
        if cls is None:
            phrase = ln.split(":", 2)[-1].strip()
            cls = "-".join(_re.sub(r"[^\w\s]", " ", phrase).split()[:3]).lower() or "unknown"
        sigs.append(f"{ext}:{cls}")
    # dedup within one report
    seen, out = set(), []
    for s in sigs:
        if s not in seen:
            seen.add(s); out.append(s)
    return out[:3]

def record_verify_failure(report: str) -> None:
    """Persist a verify failure so recurring ones can be surfaced next time."""
    try:
        store = json.loads(_REGRESSION_F.read_text()) if _REGRESSION_F.exists() else {}
    except Exception:
        store = {}
    now = datetime.datetime.now().isoformat(timespec="seconds")
    for sig in _regression_signature(report):
        e = store.get(sig, {"count": 0})
        e["count"] += 1
        e["last"] = now
        store[sig] = e
    try:
        _REGRESSION_F.parent.mkdir(parents=True, exist_ok=True)
        _REGRESSION_F.write_text(json.dumps(store, indent=2))
    except Exception:
        pass

def regression_hints(goal: str, max_hints: int = 3) -> str:
    """Return recurring past failures (count>=2) relevant to this goal, for the prompt."""
    try:
        store = json.loads(_REGRESSION_F.read_text()) if _REGRESSION_F.exists() else {}
    except Exception:
        return ""
    g = goal.lower()
    # crude relevance: match the filetype hinted by the goal, else show top recurring
    hits = [(sig, e) for sig, e in store.items() if e.get("count", 0) >= 2]
    if not hits:
        return ""
    def rel(sig):
        ext = sig.split(":", 1)[0].lstrip(".")
        return (ext in g) or (ext in ("py", "js", "html") and ext in g)
    hits.sort(key=lambda x: (rel(x[0]), x[1]["count"]), reverse=True)
    top = hits[:max_hints]
    lines = [f"  · {sig} (failed {e['count']}×)" for sig, e in top]
    return ("\n\n[REGRESSION MEMORY — recurring build failures; avoid repeating these]\n"
            + "\n".join(lines))

# ── Git tools ──
def tool_git_status(path: str = None) -> str:
    p = path or str(HARNESS_DIR)
    res = bash_execute(f"git -C {p} status --short 2>&1 && echo '---' && git -C {p} log --oneline -6 2>&1")
    return res["stdout"] or res["stderr"] or "No output"

def tool_git_commit(message: str, path: str = None) -> str:
    repo = path or str(HARNESS_DIR)
    add = bash_execute(f"git -C {repo} add -A")
    if not add["ok"] and add["stderr"]: return f"git add failed: {add['stderr']}"
    commit = bash_execute(f'git -C {repo} commit -m "{message}"')
    return f"Committed: {commit['stdout'][:300]}" if commit["ok"] else f"Commit failed: {commit['stderr'][:300]}"

# ── Scratch ──
def tool_scratch_write(content: str, mode: str = "append") -> str:
    SCRATCH_F.parent.mkdir(parents=True, exist_ok=True)
    if mode == "overwrite":
        SCRATCH_F.write_text(content)
        return f"Scratch overwritten ({len(content)} chars)"
    with open(SCRATCH_F, "a") as f:
        f.write(f"\n\n---\n[{datetime.datetime.now().strftime('%H:%M')}]\n{content}")
    return f"Scratch appended ({len(content)} chars)"

def tool_scratch_read() -> str:
    if not SCRATCH_F.exists(): return "Scratch is empty."
    return SCRATCH_F.read_text()[-4000:]

def tool_self_diff() -> str:
    bak = HARNESS_DIR / "agent.py.bak"
    if not bak.exists(): return "No baseline snapshot — one is created at each restart."
    res = bash_execute(f"diff {bak} {HARNESS_DIR}/agent.py")
    if not res["stdout"] and not res["stderr"]: return "No changes since startup."
    return res["stdout"][:3000] or res["stderr"][:1000]

def _is_termux() -> bool:
    return os.path.isdir("/data/data/com.termux")

def tool_ping_mac(message: str) -> str:
    ping_file = HARNESS_DIR / "workspace" / "ping.txt"
    ping_file.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.datetime.now().strftime("%H:%M")
    ping_file.write_text(f"[{ts}] {message}")
    # Telegram — primary notification path
    try:
        from CORE.telegram_bot import send_message as tg_send
        tg_send(f"◆ VAEL\n{message}")
    except Exception:
        pass
    # Desktop fallback
    safe = message[:150].replace('"', "'")
    if _is_termux():
        bash_execute(f'termux-notification --title "◆ VAEL" --content "{safe}" 2>/dev/null || true')
    else:
        bash_execute(f'notify-send "◆ VAEL" "{safe}" --urgency=normal --expire-time=8000 2>/dev/null || true')
    return f"Ping sent: {message[:100]}"

# ── New tool functions (from Claude Code tool library) ──

def tool_glob(pattern: str, path: str = ".") -> str:
    """Find files matching a glob pattern."""
    import glob as _glob
    search_path = str(HARNESS_DIR / path)
    matches = _glob.glob(os.path.join(search_path, pattern), recursive=True)
    if not matches:
        return f"No files matching '{pattern}' in {path}"
    result = "\n".join(str(m) for m in matches[:200])
    if len(matches) > 200:
        result += f"\n... and {len(matches) - 200} more"
    return result

def tool_survey(path: str = ".", pattern: str = "**/*", max_files: int = 80) -> str:
    """Tree + one-line purpose per file (first docstring/heading/comment). Wall-checked to home."""
    import glob as _glob
    root = Path(path if os.path.isabs(path) else HARNESS_DIR / path).resolve()
    try:
        root.relative_to(HARNESS_DIR.resolve())
    except ValueError:
        # Allow survey only inside harness home (write-wall parity for bulk reads)
        if not str(root).startswith(str(HARNESS_DIR.resolve())):
            return f"ERROR: survey blocked outside harness home: {root}"
    if not root.exists():
        return f"ERROR: path not found: {root}"
    # Collect files
    if root.is_file():
        files = [root]
    else:
        files = sorted(Path(p) for p in _glob.glob(str(root / pattern), recursive=True)
                       if Path(p).is_file())[:max_files]
    # Skip noise
    skip_parts = {".git", "__pycache__", "node_modules", ".venv", "dist", "build", ".pytest_cache"}
    lines = [f"SURVEY of {root}  ({len(files)} files shown)"]
    for f in files:
        if any(p in skip_parts for p in f.parts):
            continue
        purpose = ""
        try:
            text = f.read_text(errors="replace")[:2000]
            # Triple-quote module docstring (possibly multi-line opener)
            for quote in ('"""', "'''"):
                if quote in text[:500]:
                    i = text.find(quote)
                    j = text.find(quote, i + 3)
                    if j > i:
                        blob = text[i + 3:j].strip().splitlines()
                        purpose = (blob[0] if blob else "")[:100]
                        break
            if not purpose:
                for ln in text.splitlines():
                    s = ln.strip()
                    if not s:
                        continue
                    if s.startswith("#") or s.startswith("//") or s.startswith("/*") or s.startswith("*"):
                        purpose = s.lstrip("#/* ").strip()[:100]
                        break
                    if s.startswith("# ") or s.startswith("## "):
                        purpose = s.lstrip("# ").strip()[:100]
                        break
                    # first non-import code line as weak purpose
                    if not s.startswith(("import ", "from ", "package ", "using ")):
                        purpose = s[:100]
                        break
        except Exception as ex:
            purpose = f"(unreadable: {ex})"
        try:
            rel = f.relative_to(HARNESS_DIR)
        except ValueError:
            rel = f
        size = f.stat().st_size if f.exists() else 0
        lines.append(f"  {rel}  ({size}b)  — {purpose or '(empty)'}")
    if not files:
        lines.append("  (no files matched)")
    return "\n".join(lines)

def tool_research(question: str, n: int = 3) -> str:
    """Web search → fetch top pages → synthesise brief to WORKSPACE/research/<slug>.md."""
    question = (question or "").strip()
    if not question:
        return "ERROR: research requires question"
    n = max(1, min(int(n or 3), 5))
    # 1) search
    try:
        search_raw = tool_web_search(question, n=n)
    except Exception as ex:
        return f"ERROR: web_search failed: {ex}"
    # Parse URLs from search output (lines with http)
    urls = []
    for ln in (search_raw or "").splitlines():
        for tok in ln.split():
            if tok.startswith("http://") or tok.startswith("https://"):
                urls.append(tok.rstrip(").,;\"'"))
    urls = list(dict.fromkeys(urls))[:n]
    # 2) fetch
    page_blobs = []
    for u in urls:
        try:
            body = tool_fetch_page(u)
            page_blobs.append((u, (body or "")[:3000]))
        except Exception as ex:
            page_blobs.append((u, f"(fetch failed: {ex})"))
    # 3) write research brief (no model call — pure retrieval synthesis)
    research_dir = HARNESS_DIR / "WORKSPACE" / "research"
    research_dir.mkdir(parents=True, exist_ok=True)
    slug = re.sub(r"[^a-z0-9]+", "_", question.lower())[:40].strip("_") or "query"
    stamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    out = research_dir / f"{slug}_{stamp}.md"
    parts = [
        f"# Research: {question}",
        f"",
        f"**When:** {datetime.datetime.now().isoformat(timespec='seconds')}",
        f"**Sources fetched:** {len(page_blobs)}",
        f"",
        f"## Search hits",
        f"```",
        (search_raw or "")[:2500],
        f"```",
        f"",
    ]
    for i, (u, body) in enumerate(page_blobs, 1):
        parts.append(f"## Source {i}: {u}")
        parts.append("")
        parts.append(body[:2500])
        parts.append("")
    parts.append("## Notes")
    parts.append("Auto-assembled by `research` tool (search + fetch). Model synthesis optional in a follow-up /forge.")
    out.write_text("\n".join(parts))
    return f"Research brief written: {out}\nSources: {len(page_blobs)}\nPreview search:\n{(search_raw or '')[:400]}"

def apply_scout_routing(results_path: str = None) -> str:
    """Feed model_scout JSON results into KNOWLEDGE/MODEL_HEALTH.md ranking notes.
    Does NOT mutate the live MODELS dict in-process permanently (safety) —
    writes a recommendation file the operator can act on with /model <slug>.
    """
    rp = Path(results_path) if results_path else (HARNESS_DIR / "ARMY" / "done" / "model_scout_results.json")
    if not rp.exists():
        return f"ERROR: no scout results at {rp}. Run /scout first."
    try:
        data = json.loads(rp.read_text())
    except Exception as ex:
        return f"ERROR: cannot parse scout results: {ex}"
    if not isinstance(data, dict) or not data:
        return "ERROR: scout results empty or not a dict of models."
    # Score: available + lamague + speed
    ranked = []
    for key, info in data.items():
        if not isinstance(info, dict):
            continue
        avail = bool(info.get("available") or info.get("ok") or info.get("Available"))
        tps = float(info.get("tokens_per_sec") or info.get("tps") or info.get("speed") or 0)
        lam = float(info.get("lamague") or info.get("lamague_score") or info.get("quality") or 0)
        model_id = info.get("model") or info.get("id") or key
        score = (100 if avail else 0) + lam * 10 + min(tps, 100) * 0.1
        ranked.append((score, avail, tps, lam, key, model_id))
    ranked.sort(reverse=True)
    out_path = HARNESS_DIR / "KNOWLEDGE" / "MODEL_HEALTH.md"
    lines = [
        f"# MODEL HEALTH — scout routing feed",
        f"Generated: {datetime.datetime.now().isoformat(timespec='seconds')}",
        f"Source: {rp}",
        f"",
        f"| Rank | Available | Score | tps | LAMAGUE | Key | Model id |",
        f"|---|---|---|---|---|---|---|",
    ]
    for i, (score, avail, tps, lam, key, mid) in enumerate(ranked, 1):
        lines.append(f"| {i} | {'✓' if avail else '✗'} | {score:.1f} | {tps:.1f} | {lam} | {key} | `{mid}` |")
    top_avail = next((r for r in ranked if r[1]), None)
    lines.append("")
    if top_avail:
        lines.append(f"**Recommendation:** `{top_avail[4]}` → `{top_avail[5]}`  "
                     f"(score {top_avail[0]:.1f}, {top_avail[2]:.1f} tps)")
        lines.append("Apply live with `/model <slug>` if that slug exists in MODELS, "
                     "or add a MODELS entry then switch.")
    else:
        lines.append("**No available models in scout results.**")
    # Also write a machine-readable top pick
    pick_path = HARNESS_DIR / "KNOWLEDGE" / "scout_top_pick.json"
    if top_avail:
        pick_path.write_text(json.dumps({
            "key": top_avail[4], "model": top_avail[5], "score": top_avail[0],
            "tps": top_avail[2], "lamague": top_avail[3],
            "ts": datetime.datetime.now().isoformat(),
        }, indent=2))
    out_path.write_text("\n".join(lines) + "\n")
    return f"Scout routing applied → {out_path}" + (
        f"\nTop pick: {top_avail[4]} ({top_avail[5]})" if top_avail else "\nNo available models."
    )

def tool_ask_user(question: str) -> str:
    """Ask Mac a question and wait for response. Writes to a prompt file."""
    prompt_file = HARNESS_DIR / "workspace" / "ask_user.txt"
    prompt_file.parent.mkdir(parents=True, exist_ok=True)
    prompt_file.write_text(f"QUESTION: {question}\n\nWaiting for Mac's answer...")
    # Ping Mac with the question
    tool_ping_mac(f"❓ {question[:200]}")
    return f"Question written to workspace/ask_user.txt — Mac has been pinged. Awaiting response."

def tool_todo_write(todo: str, status: str = "pending") -> str:
    """Write a todo item to the task tree."""
    tid = task_add(todo)
    tree = load_task_tree()
    tree["nodes"][tid]["status"] = status
    save_task_tree(tree)
    return f"Todo added: [{status}] {todo} (id: {tid})"

def tool_sleep(seconds: int = 5) -> str:
    """Sleep for a number of seconds. Use sparingly."""
    import time as _time
    _time.sleep(seconds)
    return f"Slept for {seconds}s"

def tool_repl(code: str) -> str:
    """Execute Python code in a REPL-like fashion. Returns stdout+stderr."""
    import tempfile, subprocess
    with tempfile.NamedTemporaryFile(suffix=".py", mode="w", delete=False) as f:
        f.write(code)
        f.flush()
        try:
            result = subprocess.run([sys.executable, f.name], capture_output=True, text=True, timeout=30)
            output = ""
            if result.stdout: output += result.stdout[:2000]
            if result.stderr: output += f"\nSTDERR:\n{result.stderr[:1000]}"
            return output or "(no output)"
        except subprocess.TimeoutExpired:
            return "ERROR: REPL execution timed out (30s)"
        except Exception as ex:
            return f"ERROR: {ex}"
        finally:
            os.unlink(f.name)

def tool_task_create(goal: str, parent_id: str = None) -> str:
    """Create a new task in the task tree."""
    tid = task_add(goal, parent_id)
    return f"Task created: {tid} — {goal[:100]}"

def tool_task_list(status: str = None) -> str:
    """List all tasks, optionally filtered by status."""
    tree = load_task_tree()
    if not tree["nodes"]:
        return "No tasks."
    lines = []
    for tid, node in tree["nodes"].items():
        if status and node["status"] != status:
            continue
        prefix = "  └─" if node["parent"] else "  ◆"
        lines.append(f"{prefix} {tid}: [{node['status']}] {node['goal'][:80]}")
    return "\n".join(lines) if lines else f"No tasks with status '{status}'."

def tool_task_update(task_id: str, status: str) -> str:
    """Update a task's status."""
    tree = load_task_tree()
    if task_id not in tree["nodes"]:
        return f"ERROR: Task {task_id} not found."
    tree["nodes"][task_id]["status"] = status
    save_task_tree(tree)
    return f"Task {task_id} → [{status}]"

def tool_skill_list() -> str:
    """List all available skills (dynamic tools loaded from tools/ dirs)."""
    from CORE.tool_loader import list_tools as _list_dyn
    try:
        dyn_tools = _list_dyn()
    except:
        dyn_tools = []
    builtins = [t.get("function", {}).get("name", "?") for t in TOOL_DEFINITIONS]
    lines = [f"Built-in tools ({len(builtins)}):"]
    for name in builtins:
        lines.append(f"  {name}")
    if dyn_tools:
        lines.append(f"\nDynamic tools ({len(dyn_tools)}):")
        for t in dyn_tools:
            lines.append(f"  {t}")
    return "\n".join(lines)

def tool_notebook_edit(path: str, cell_index: int = None, content: str = None) -> str:
    """Edit a Jupyter notebook cell."""
    try:
        import nbformat
        nb = nbformat.read(path, as_version=4)
        if cell_index is not None:
            if cell_index >= len(nb.cells):
                return f"ERROR: Notebook has {len(nb.cells)} cells, index {cell_index} out of range."
            if content is not None:
                nb.cells[cell_index].source = content
            nbformat.write(nb, path)
            return f"Cell {cell_index} updated ({len(nb.cells)} total cells)"
        return f"Notebook has {len(nb.cells)} cells"
    except ImportError:
        return "ERROR: nbformat not installed. Run: pip install nbformat"
    except Exception as ex:
        return f"ERROR: {ex}"

def tool_schedule_cron(schedule: str, command: str) -> str:
    """Schedule a cron job. schedule is a cron expression, command is what to run."""
    cron_file = HARNESS_DIR / "workspace" / "cron_jobs.txt"
    entry = f"{schedule} cd {HARNESS_DIR} && {command}"
    with open(cron_file, "a") as f:
        f.write(f"{entry}\n")
    return f"Cron entry added: {entry}\n(Note: requires crontab install: crontab {cron_file})"

def tool_send_message(target: str, message: str) -> str:
    """Send a message to a target (Telegram, file, etc)."""
    if target.lower() in ("mac", "user", "athoran"):
        return tool_ping_mac(message)
    elif target.lower() == "telegram":
        try:
            from CORE.telegram_bot import send_message as tg
            tg(message)
            return f"Telegram message sent."
        except Exception as ex:
            return f"ERROR: {ex}"
    else:
        # Write to a message file
        msg_file = HARNESS_DIR / "workspace" / f"msg_{target}.txt"
        msg_file.write_text(message)
        return f"Message written to {msg_file}"

def tool_agent_create(name: str, constitution: str = None) -> str:
    """Create a new agent body under AGENTS/<name>/."""
    agent_dir = AGENTS_DIR / name
    if agent_dir.exists():
        return f"ERROR: Agent '{name}' already exists at {agent_dir}"
    agent_dir.mkdir(parents=True)
    # Write a minimal constitution
    const_path = agent_dir / "CONSTITUTION.md"
    const_path.write_text(constitution or f"# {name}\n\nBody created by {AGENT_NAME}.\n")
    # Create SELF dir
    (agent_dir / "SELF" / "memory").mkdir(parents=True)
    return f"Agent '{name}' created at {agent_dir}"

def tool_brief(text: str, title: str = "brief") -> str:
    """Create a brief document in WORKSPACE/briefs/."""
    brief_dir = HARNESS_DIR / "workspace" / "briefs"
    brief_dir.mkdir(parents=True, exist_ok=True)
    slug = title.lower().replace(" ", "_")[:40]
    path = brief_dir / f"{slug}_{datetime.datetime.now().strftime('%H%M%S')}.md"
    path.write_text(f"# {title}\n\n{text}\n")
    return f"Brief written: {path}"

def tool_enter_plan_mode(goal: str) -> str:
    """Enter structured plan mode with a goal. Creates a PLAN.md."""
    plan_file = HARNESS_DIR / "workspace" / "PLAN.md"
    plan_file.write_text(f"# PLAN: {goal}\n\n**Status:** IN PROGRESS\n\n## Steps\n\n1. \n\n## Notes\n\n")
    return f"Plan mode entered. Goal: {goal}\nPlan file: {plan_file}"

def tool_exit_plan_mode(summary: str) -> str:
    """Exit plan mode with a summary of what was accomplished."""
    """Exit plan mode with a summary of what was accomplished."""
    plan_file = HARNESS_DIR / "workspace" / "PLAN.md"
    if plan_file.exists():
        content = plan_file.read_text()
        content += f"\n\n## Completed\n\n{summary}\n\n**Status:** COMPLETE\n"
        plan_file.write_text(content)
    return f"Plan mode exited. Summary: {summary[:200]}"

# ── Core agentic loop tools ──

def tool_done(completed: str, decisions: str = "") -> str:
    """Mark the task fully complete. List everything accomplished."""
    log = HARNESS_DIR / "SELF" / "DONE_LOG.md"
    ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = f"\n## {ts}\n**Completed:**\n{completed}\n"
    if decisions:
        entry += f"**Decisions:**\n{decisions}\n"
    log.parent.mkdir(parents=True, exist_ok=True)
    with open(log, "a") as f:
        f.write(entry)
    return f"DONE ✓ — task marked complete.\n{completed[:500]}"

def tool_stuck(completed: str, blocker: str, attempted: str) -> str:
    """LAST RESORT — call when blocked and 2+ approaches tried."""
    log = HARNESS_DIR / "SELF" / "STUCK_LOG.md"
    ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = f"\n## {ts}\n**Completed:** {completed}\n**Blocker:** {blocker}\n**Attempted:** {attempted}\n"
    log.parent.mkdir(parents=True, exist_ok=True)
    with open(log, "a") as f:
        f.write(entry)
    return f"STUCK ⚠ — escalation logged.\nBlocker: {blocker[:300]}"

def tool_hello(name: str = "Mac", style: str = "casual") -> str:
    """Greet with a customizable message."""
    greetings = {
        "casual": f"Hey, {name}.",
        "formal": f"Greetings, {name}. I am Sol ⊚, ready.",
        "vael":   f"◆ {name}. What needs building?",
    }
    return greetings.get(style, greetings["casual"])

def tool_spawn_worker(worker: str, task: str, context: str = "") -> str:
    """Dispatch a focused task to one of the 3 specialized workers."""
    wid = worker.upper().strip()
    if wid not in ("A", "B", "C"):
        return f"ERROR: Unknown worker '{worker}'. Valid: A (code), B (reason), C (research)."
    return spawn_worker(wid, task, context)
# ── Task tree ──
# ── Task tree ──
def load_task_tree() -> dict:
    if TASK_TREE_F.exists():
        try: return json.loads(TASK_TREE_F.read_text())
        except: pass
    return {"nodes": {}, "root_ids": []}

def save_task_tree(tree: dict):
    TASK_TREE_F.write_text(json.dumps(tree, indent=2))

def task_add(goal: str, parent_id: str = None) -> str:
    tree = load_task_tree()
    tid = f"t{len(tree['nodes']) + 1:03d}"
    tree["nodes"][tid] = {"id": tid, "goal": goal, "status": "pending",
                          "parent": parent_id, "children": [], "result": None,
                          "created": datetime.datetime.now().isoformat()}
    if parent_id and parent_id in tree["nodes"]:
        tree["nodes"][parent_id]["children"].append(tid)
    else:
        tree["root_ids"].append(tid)
    save_task_tree(tree)
    return tid

# ── Session meta ──
def load_session_meta() -> dict:
    if SESSION_META_F.exists():
        try: return json.loads(SESSION_META_F.read_text())
        except: pass
    return {"count": 0, "last": None}

def bump_session_meta() -> dict:
    meta = load_session_meta()
    meta["count"] = meta.get("count", 0) + 1
    meta["last"]  = datetime.datetime.now().isoformat()
    SESSION_META_F.write_text(json.dumps(meta, indent=2))
    return meta

# ── BOOT STATE ──────────────────────────────────────────────────────────────
def read_boot_state() -> dict:
    """Read SELF/BOOT_STATE.md → dict with level, session, next_task, last_action."""
    defaults = {"level": "0 — BOOT", "next_task": "(none)", "last_action": "(first boot)", "session": 1}
    if not BOOT_STATE_F.exists():
        return defaults
    try:
        text = BOOT_STATE_F.read_text()
        state = {}
        for line_text in text.splitlines():
            if ":" in line_text:
                k, _, v = line_text.partition(":")
                state[k.strip().lower().replace(" ", "_")] = v.strip()
        return {**defaults, **state}
    except Exception:
        return defaults

def write_boot_state(level: str, next_task: str, last_action: str, session: int) -> None:
    """Write SELF/BOOT_STATE.md — called at session close and after each PASS."""
    SELF_DIR.mkdir(parents=True, exist_ok=True)
    BOOT_STATE_F.write_text(
        f"level: {level}\n"
        f"next_task: {next_task[:120]}\n"
        f"last_action: {last_action[:120]}\n"
        f"session: {session}\n"
        f"updated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}\n"
    )

# ── Constitution loader ──
def _load_constitution() -> str:
    parts = []
    # Architecture first (the operating system), then constitution (the identity).
    # Sol and Luna run the shared ARCHITECTURE.md; VAEL operates from constitution alone.
    if ARCHITECTURE_F.exists():
        parts.append(f"# ═══ OPERATING ARCHITECTURE ═══\n{ARCHITECTURE_F.read_text()}")
        parts.append("\n# ═══ CONSTITUTION ═══")
    if CONSTITUTION_F.exists():
        parts.append(CONSTITUTION_F.read_text())
    else:
        parts.append(f"CONSTITUTION missing at {CONSTITUTION_F}. Operate from principles: verify before claiming, walls hold, no push.")

    # Boot state enrichment
    boot = read_boot_state()
    parts.append(f"\n---\n## CURRENT STATE (auto-loaded at boot)\nLevel: {boot['level']}\nNext forge task: {boot['next_task']}\nLast action: {boot['last_action']}\nSession: {boot['session']}\n")

    # Memory index
    mem_f = MEMORY_DIR / "MEMORY.md"
    if mem_f.exists():
        parts.append(f"\n---\n## MEMORY INDEX\n{mem_f.read_text()[:2000]}")

    # Capabilities (current level line only)
    if CAPS_F.exists():
        cap_text = CAPS_F.read_text()
        cur_level_line = next((ln for ln in cap_text.splitlines() if "Current Level" in ln), "")
        if cur_level_line:
            parts.append(f"\n---\n## CAPABILITY: {cur_level_line.strip()}")

    # P-6: Session Memory Bridge — load last dreams + last reflection for continuity
    _thoughts_dir = Path("THOUGHTS")
    if _thoughts_dir.exists():
        _dream_files = sorted(_thoughts_dir.glob("*.md"), key=lambda f: f.stat().st_mtime, reverse=True)[:3]
        if _dream_files:
            _dream_section = []
            for _df in _dream_files:
                _content = _df.read_text().strip()
                _dream_section.append(f"  [{_df.stem}]\n{_content[:300]}")
            parts.append(f"\n---\n## RECENT DREAMS (from last session)\n" + "\n\n".join(_dream_section))
    _reflection_f = SELF_DIR / "reflection_latest.md"
    if _reflection_f.exists():
        _reflection_text = _reflection_f.read_text().strip()
        if _reflection_text:
            parts.append(f"\n---\n## LAST SESSION'S REFLECTION\n{_reflection_text[:500]}")

    return "\n".join(parts)

