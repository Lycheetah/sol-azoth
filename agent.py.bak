# Aliases so old names still resolve
MODEL_ALIASES = {
    "deepseek": "flash", "deepseek-chat": "flash", "deepseek-r1": "pro", "deepseek-reasoner": "pro",
    "deepseek-v4-flash": "flash", "deepseek-v4-pro": "pro", "v4": "flash", "v4flash": "flash",
    "v4pro": "pro", "v4-flash": "flash", "v4-pro": "pro",
    "gemini": "gem", "gemini-flash": "gem", "gemini-pro": "gempro",
    "super49b": "nemo", "nemotron": "nemo", "maverick": "mav", "llama8b": "lite",
    "gptoss": "gpt20", "gpt": "gpt20", "gpt-oss": "gpt20",
}
def _resolve_alias(name: str) -> str:
    name = (name or "").strip().lower()
    if name in MODELS: return name
    return MODEL_ALIASES.get(name, name)

# Drop slugs whose key/client is missing
